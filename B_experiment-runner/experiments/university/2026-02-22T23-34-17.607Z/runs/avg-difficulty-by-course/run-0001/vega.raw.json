{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Difficulty Rating by Course",
  "height": {
    "step": 20
  },
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "y": {
      "field": "course_code",
      "type": "nominal",
      "title": "Course",
      "sort": {
        "field": "average_difficulty",
        "order": "descending"
      }
    },
    "x": {
      "field": "average_difficulty",
      "type": "quantitative",
      "title": "Average Difficulty",
      "scale": {
        "domain": [
          0,
          5
        ]
      }
    },
    "tooltip": [
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "average_difficulty",
        "type": "quantitative",
        "title": "Average Difficulty"
      }
    ]
  }
}
