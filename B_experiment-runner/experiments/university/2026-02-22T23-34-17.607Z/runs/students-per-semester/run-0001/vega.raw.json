{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Number of Students by Semester",
  "width": 600,
  "height": 360,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "semester",
      "type": "ordinal",
      "axis": {
        "title": "Semester"
      },
      "sort": {
        "field": "semester",
        "order": "ascending"
      }
    },
    "y": {
      "field": "student_count",
      "type": "quantitative",
      "axis": {
        "title": "Student Count"
      }
    },
    "tooltip": [
      {
        "field": "semester",
        "type": "ordinal",
        "title": "Semester"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Students"
      }
    ]
  }
}
