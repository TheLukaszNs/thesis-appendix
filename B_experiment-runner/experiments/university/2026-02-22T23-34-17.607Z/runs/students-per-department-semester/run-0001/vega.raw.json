{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Student count by department and current semester",
  "width": 700,
  "height": {
    "step": 20
  },
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "y": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "title": "Department"
      },
      "sort": null
    },
    "x": {
      "aggregate": "sum",
      "field": "student_count",
      "type": "quantitative",
      "axis": {
        "title": "Student count"
      },
      "stack": "zero"
    },
    "color": {
      "field": "current_semester",
      "type": "ordinal",
      "legend": {
        "title": "Current semester"
      }
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "current_semester",
        "type": "ordinal",
        "title": "Current semester"
      },
      {
        "aggregate": "sum",
        "field": "student_count",
        "type": "quantitative",
        "title": "Students"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": "transparent"
    }
  }
}
