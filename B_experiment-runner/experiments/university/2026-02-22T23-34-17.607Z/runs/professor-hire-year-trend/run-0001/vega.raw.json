{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Professors Hired per Year",
  "width": 700,
  "height": 360,
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "hire_year",
      "type": "ordinal",
      "axis": {
        "title": "Hire Year",
        "labelAngle": 0
      },
      "sort": {
        "field": "hire_year",
        "order": "ascending"
      }
    },
    "y": {
      "field": "professors_hired",
      "type": "quantitative",
      "axis": {
        "title": "Professors Hired"
      }
    },
    "tooltip": [
      {
        "field": "hire_year",
        "type": "ordinal",
        "title": "Year"
      },
      {
        "field": "professors_hired",
        "type": "quantitative",
        "title": "Professors Hired"
      }
    ]
  }
}
