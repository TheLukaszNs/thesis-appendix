{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Number of courses offered by each department.",
  "data": {
    "name": "query_result"
  },
  "width": 700,
  "height": {
    "step": 30
  },
  "mark": {
    "type": "bar",
    "cornerRadius": 3
  },
  "encoding": {
    "x": {
      "field": "course_count",
      "type": "quantitative",
      "axis": {
        "title": "Number of courses",
        "grid": true
      }
    },
    "y": {
      "field": "department_name",
      "type": "nominal",
      "sort": "-x",
      "axis": {
        "title": "Department",
        "labelLimit": 300
      }
    },
    "color": {
      "field": "department_code",
      "type": "nominal",
      "legend": {
        "title": "Dept. code"
      }
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "department_code",
        "type": "nominal",
        "title": "Code"
      },
      {
        "field": "course_count",
        "type": "quantitative",
        "title": "Courses"
      }
    ]
  },
  "title": "Courses per Department"
}
