{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Students with Highest Total Scholarship Amounts",
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "last_name",
      "type": "nominal",
      "title": "Last name",
      "sort": {
        "field": "total_amount",
        "order": "descending"
      }
    },
    "x": {
      "field": "total_amount",
      "type": "quantitative",
      "title": "Total scholarship amount"
    },
    "tooltip": [
      {
        "field": "first_name",
        "type": "nominal",
        "title": "First name"
      },
      {
        "field": "last_name",
        "type": "nominal",
        "title": "Last name"
      },
      {
        "field": "student_id",
        "type": "nominal",
        "title": "Student ID"
      },
      {
        "field": "total_amount",
        "type": "quantitative",
        "title": "Total amount"
      }
    ]
  }
}
