{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Grades by Course Type — Winter vs Summer",
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadius": 3
      },
      "encoding": {
        "x": {
          "field": "course_type",
          "type": "nominal",
          "axis": {
            "title": "Course Type",
            "labelAngle": 0
          }
        },
        "xOffset": {
          "field": "semester"
        },
        "y": {
          "field": "avg_component_average",
          "type": "quantitative",
          "axis": {
            "title": "Avg Component Average"
          }
        },
        "color": {
          "field": "semester",
          "type": "nominal",
          "title": "Semester",
          "scale": {
            "domain": [
              "WINTER",
              "SUMMER"
            ],
            "range": [
              "#1f77b4",
              "#ff7f0e"
            ]
          }
        },
        "tooltip": [
          {
            "field": "course_type",
            "type": "nominal",
            "title": "Course Type"
          },
          {
            "field": "semester",
            "type": "nominal",
            "title": "Semester"
          },
          {
            "field": "avg_component_average",
            "type": "quantitative",
            "title": "Avg Component Avg"
          },
          {
            "field": "avg_exam_score",
            "type": "quantitative",
            "title": "Avg Exam Score"
          },
          {
            "field": "num_grades",
            "type": "quantitative",
            "title": "Num Grades"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 80,
        "stroke": "black",
        "strokeWidth": 0.5
      },
      "encoding": {
        "x": {
          "field": "course_type",
          "type": "nominal"
        },
        "xOffset": {
          "field": "semester"
        },
        "y": {
          "field": "avg_exam_score",
          "type": "quantitative",
          "axis": {
            "title": "Avg Exam Score"
          }
        },
        "color": {
          "field": "semester",
          "type": "nominal",
          "legend": null,
          "scale": {
            "domain": [
              "WINTER",
              "SUMMER"
            ],
            "range": [
              "#1f77b4",
              "#ff7f0e"
            ]
          }
        },
        "tooltip": [
          {
            "field": "course_type",
            "type": "nominal",
            "title": "Course Type"
          },
          {
            "field": "semester",
            "type": "nominal",
            "title": "Semester"
          },
          {
            "field": "avg_component_average",
            "type": "quantitative",
            "title": "Avg Component Avg"
          },
          {
            "field": "avg_exam_score",
            "type": "quantitative",
            "title": "Avg Exam Score"
          },
          {
            "field": "num_grades",
            "type": "quantitative",
            "title": "Num Grades"
          }
        ]
      }
    }
  ]
}
