{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Distribution of Individual Scholarship Amounts (bucketed)",
  "data": {
    "name": "query_result"
  },
  "width": 700,
  "height": 400,
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadius": 2
      },
      "encoding": {
        "x": {
          "field": "bucket_number",
          "type": "ordinal",
          "title": "Bucket number (lower to higher amounts)"
        },
        "y": {
          "field": "count",
          "type": "quantitative",
          "title": "Count"
        },
        "tooltip": [
          {
            "field": "bucket_min",
            "type": "quantitative",
            "title": "Bucket min"
          },
          {
            "field": "bucket_max",
            "type": "quantitative",
            "title": "Bucket max"
          },
          {
            "field": "count",
            "type": "quantitative",
            "title": "Count"
          },
          {
            "field": "pct",
            "type": "quantitative",
            "title": "Pct of total (%)"
          },
          {
            "field": "cumulative_pct",
            "type": "quantitative",
            "title": "Cumulative pct (%)"
          }
        ],
        "color": {
          "value": "#4C78A8"
        }
      }
    },
    {
      "mark": {
        "type": "line",
        "point": true,
        "strokeWidth": 2,
        "clip": true
      },
      "encoding": {
        "x": {
          "field": "bucket_number",
          "type": "ordinal"
        },
        "y": {
          "field": "cumulative_pct",
          "type": "quantitative",
          "title": "Cumulative %"
        },
        "tooltip": [
          {
            "field": "bucket_min",
            "type": "quantitative",
            "title": "Bucket min"
          },
          {
            "field": "bucket_max",
            "type": "quantitative",
            "title": "Bucket max"
          },
          {
            "field": "count",
            "type": "quantitative",
            "title": "Count"
          },
          {
            "field": "pct",
            "type": "quantitative",
            "title": "Pct of total (%)"
          },
          {
            "field": "cumulative_pct",
            "type": "quantitative",
            "title": "Cumulative pct (%)"
          }
        ],
        "color": {
          "value": "#E45756"
        }
      }
    }
  ],
  "resolve": {
    "scale": {
      "y": "independent"
    }
  }
}
