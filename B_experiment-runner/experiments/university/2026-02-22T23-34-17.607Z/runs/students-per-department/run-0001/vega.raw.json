{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Number of students by department",
  "width": 700,
  "height": {
    "step": 28
  },
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "y": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "title": "Department"
      },
      "sort": {
        "field": "student_count",
        "op": "sum",
        "order": "descending"
      }
    },
    "x": {
      "field": "student_count",
      "type": "quantitative",
      "axis": {
        "title": "Number of students"
      }
    },
    "color": {
      "value": "#4C78A8"
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "department_code",
        "type": "nominal",
        "title": "Code"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Students"
      },
      {
        "field": "department_id",
        "type": "nominal",
        "title": "Department ID"
      }
    ]
  }
}
