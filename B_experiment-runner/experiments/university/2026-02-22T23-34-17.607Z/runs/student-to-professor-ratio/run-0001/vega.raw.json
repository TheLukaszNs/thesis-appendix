{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Student-to-Professor Ratio by Department",
  "width": 700,
  "height": 320,
  "mark": {
    "type": "bar",
    "cornerRadiusTopLeft": 3,
    "cornerRadiusTopRight": 3
  },
  "encoding": {
    "y": {
      "field": "department_name",
      "type": "nominal",
      "title": "Department",
      "sort": {
        "encoding": "x",
        "order": "descending"
      }
    },
    "x": {
      "field": "student_to_professor_ratio",
      "type": "quantitative",
      "title": "Students per Professor",
      "axis": {
        "grid": true
      }
    },
    "color": {
      "field": "students_count",
      "type": "quantitative",
      "title": "Number of Students",
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "department_code",
        "type": "nominal",
        "title": "Code"
      },
      {
        "field": "students_count",
        "type": "quantitative",
        "title": "Students"
      },
      {
        "field": "professors_count",
        "type": "quantitative",
        "title": "Professors"
      },
      {
        "field": "student_to_professor_ratio",
        "type": "quantitative",
        "title": "Students / Professor",
        "format": ".2f"
      },
      {
        "field": "department_id",
        "type": "nominal",
        "title": "Department ID"
      }
    ]
  }
}
