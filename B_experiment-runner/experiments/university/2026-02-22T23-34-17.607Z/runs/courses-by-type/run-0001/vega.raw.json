{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Number of courses by course type",
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "y": {
      "field": "course_type",
      "type": "nominal",
      "sort": "-x",
      "axis": {
        "title": "Course type"
      }
    },
    "x": {
      "field": "course_count",
      "type": "quantitative",
      "axis": {
        "title": "Number of courses"
      }
    },
    "color": {
      "value": "#4C78A8"
    },
    "tooltip": [
      {
        "field": "course_type",
        "type": "nominal",
        "title": "Course type"
      },
      {
        "field": "course_count",
        "type": "quantitative",
        "title": "Course count"
      }
    ]
  }
}
