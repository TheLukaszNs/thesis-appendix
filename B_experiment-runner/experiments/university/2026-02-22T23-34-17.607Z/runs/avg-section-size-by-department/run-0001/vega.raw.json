{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average maximum section size per department",
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "y": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "title": "Department"
      },
      "sort": "ascending"
    },
    "x": {
      "field": "avg_max_section_size",
      "type": "quantitative",
      "axis": {
        "title": "Average max section size"
      }
    },
    "color": {
      "field": "department_code",
      "type": "nominal",
      "legend": {
        "title": "Department code"
      }
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "department_code",
        "type": "nominal",
        "title": "Code"
      },
      {
        "field": "avg_max_section_size",
        "type": "quantitative",
        "title": "Avg max size"
      }
    ]
  }
}
