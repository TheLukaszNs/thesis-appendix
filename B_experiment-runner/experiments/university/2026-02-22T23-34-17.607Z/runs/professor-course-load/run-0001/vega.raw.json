{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Number of course sections taught by each professor",
  "width": 700,
  "height": {
    "step": 18
  },
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "section_count",
      "type": "quantitative",
      "title": "Section count"
    },
    "y": {
      "field": "professor_id",
      "type": "nominal",
      "title": "Professor (ID)",
      "sort": {
        "field": "section_count",
        "op": "sum",
        "order": "descending"
      }
    },
    "tooltip": [
      {
        "field": "first_name",
        "type": "nominal",
        "title": "First name"
      },
      {
        "field": "last_name",
        "type": "nominal",
        "title": "Last name"
      },
      {
        "field": "section_count",
        "type": "quantitative",
        "title": "Sections"
      },
      {
        "field": "professor_id",
        "type": "nominal",
        "title": "Professor ID"
      }
    ]
  }
}
