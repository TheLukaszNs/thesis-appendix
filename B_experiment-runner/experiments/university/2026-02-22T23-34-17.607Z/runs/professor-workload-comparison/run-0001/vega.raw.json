{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Distinct Courses Taught per Professor",
  "width": 700,
  "height": {
    "step": 22
  },
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "y": {
      "field": "professor_name",
      "type": "nominal",
      "sort": {
        "field": "distinct_course_count",
        "op": "sum",
        "order": "descending"
      },
      "axis": {
        "title": null
      }
    },
    "x": {
      "field": "distinct_course_count",
      "type": "quantitative",
      "axis": {
        "title": "Number of Distinct Courses"
      }
    },
    "color": {
      "field": "distinct_course_count",
      "type": "quantitative",
      "legend": null,
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "professor_name",
        "type": "nominal",
        "title": "Professor"
      },
      {
        "field": "distinct_course_count",
        "type": "quantitative",
        "title": "Distinct Courses"
      },
      {
        "field": "professor_id",
        "type": "nominal",
        "title": "Professor ID"
      }
    ]
  }
}
