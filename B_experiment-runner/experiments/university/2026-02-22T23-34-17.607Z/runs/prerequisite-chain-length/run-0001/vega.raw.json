{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Courses that are prerequisites for the most other courses",
  "width": 480,
  "height": 120,
  "mark": {
    "type": "bar",
    "cornerRadius": 3
  },
  "encoding": {
    "x": {
      "field": "num_dependent_courses",
      "type": "quantitative",
      "title": "Number of dependent courses",
      "axis": {
        "grid": false
      }
    },
    "y": {
      "field": "course_code",
      "type": "nominal",
      "title": "Course code",
      "sort": {
        "encoding": "x"
      }
    },
    "tooltip": [
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Course code"
      },
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course name"
      },
      {
        "field": "num_dependent_courses",
        "type": "quantitative",
        "title": "Dependent courses"
      }
    ]
  }
}
