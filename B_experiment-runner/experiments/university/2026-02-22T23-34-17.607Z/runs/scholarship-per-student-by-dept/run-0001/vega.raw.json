{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Scholarship Amount per Student by Department",
  "width": 700,
  "height": {
    "step": 36
  },
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "y": {
      "field": "department_name",
      "type": "nominal",
      "sort": null,
      "axis": {
        "title": null,
        "labelLimit": 400
      }
    },
    "x": {
      "field": "avg_scholarship_amount",
      "type": "quantitative",
      "axis": {
        "title": "Average Scholarship Amount",
        "format": ".2f"
      }
    },
    "color": {
      "field": "avg_scholarship_amount",
      "type": "quantitative",
      "legend": null
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Student Count"
      },
      {
        "field": "avg_scholarship_amount",
        "type": "quantitative",
        "title": "Avg Scholarship",
        "format": ".2f"
      },
      {
        "field": "department_id",
        "type": "nominal",
        "title": "Department ID"
      }
    ]
  }
}
