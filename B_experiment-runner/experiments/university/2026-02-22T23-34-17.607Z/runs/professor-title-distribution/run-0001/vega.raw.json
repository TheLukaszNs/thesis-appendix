{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Distribution of academic titles among professors",
  "mark": {
    "type": "bar",
    "cornerRadius": 3
  },
  "encoding": {
    "y": {
      "field": "academic_title",
      "type": "nominal",
      "title": "Academic title",
      "sort": {
        "field": "professor_count",
        "order": "descending"
      }
    },
    "x": {
      "field": "professor_count",
      "type": "quantitative",
      "title": "Number of professors"
    },
    "color": {
      "field": "percentage",
      "type": "quantitative",
      "title": "Share (%)",
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "academic_title",
        "type": "nominal",
        "title": "Academic title"
      },
      {
        "field": "professor_count",
        "type": "quantitative",
        "title": "Professor count"
      },
      {
        "field": "percentage",
        "type": "quantitative",
        "title": "Percentage",
        "format": ".2f"
      }
    ]
  },
  "width": 640,
  "height": {
    "step": 24
  }
}
