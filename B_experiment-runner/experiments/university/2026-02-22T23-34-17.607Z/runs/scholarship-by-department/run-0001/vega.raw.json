{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Departments by total scholarship amount",
  "width": 700,
  "height": {
    "step": 30
  },
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "y": {
      "field": "dept_name",
      "type": "nominal",
      "title": "Department",
      "sort": {
        "field": "total_amount",
        "order": "descending"
      }
    },
    "x": {
      "field": "total_amount",
      "type": "quantitative",
      "title": "Total scholarship amount (PLN)",
      "axis": {
        "format": ","
      }
    },
    "color": {
      "field": "scholarship_count",
      "type": "quantitative",
      "title": "Number of scholarships",
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "dept_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "dept_code",
        "type": "nominal",
        "title": "Dept code"
      },
      {
        "field": "total_amount",
        "type": "quantitative",
        "title": "Total amount",
        "format": ","
      },
      {
        "field": "scholarship_count",
        "type": "quantitative",
        "title": "Scholarship count"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Students receiving scholarships"
      }
    ]
  }
}
