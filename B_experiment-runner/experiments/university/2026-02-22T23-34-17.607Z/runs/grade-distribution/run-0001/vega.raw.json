{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Distribution of Final Grades Across All Courses",
  "mark": {
    "type": "bar",
    "cornerRadius": 2
  },
  "encoding": {
    "x": {
      "field": "grade",
      "type": "nominal",
      "axis": {
        "title": "Final Grade"
      },
      "sort": {
        "field": "count",
        "order": "descending"
      }
    },
    "y": {
      "field": "count",
      "type": "quantitative",
      "axis": {
        "title": "Number of Records"
      }
    },
    "color": {
      "field": "percent",
      "type": "quantitative",
      "legend": {
        "title": "Percent (%)"
      },
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "grade",
        "type": "nominal",
        "title": "Grade"
      },
      {
        "field": "count",
        "type": "quantitative",
        "title": "Count"
      },
      {
        "field": "percent",
        "type": "quantitative",
        "title": "Percent (%)"
      }
    ]
  }
}
