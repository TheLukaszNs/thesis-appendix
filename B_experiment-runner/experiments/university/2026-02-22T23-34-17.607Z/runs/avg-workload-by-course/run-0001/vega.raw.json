{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Average reported workload hours for each course",
  "title": "Average Reported Workload Hours by Course",
  "data": {
    "name": "query_result"
  },
  "width": 700,
  "height": 520,
  "mark": {
    "type": "bar",
    "cornerRadius": 3
  },
  "encoding": {
    "y": {
      "field": "course_code",
      "type": "nominal",
      "axis": {
        "title": "Course code"
      },
      "sort": {
        "field": "average_workload_hours",
        "order": "descending"
      }
    },
    "x": {
      "field": "average_workload_hours",
      "type": "quantitative",
      "axis": {
        "title": "Average workload hours"
      }
    },
    "color": {
      "field": "average_workload_hours",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      },
      "legend": {
        "title": "Avg hrs"
      }
    },
    "tooltip": [
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Course code"
      },
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course name"
      },
      {
        "field": "average_workload_hours",
        "type": "quantitative",
        "title": "Avg workload (hrs)",
        "format": ".2f"
      },
      {
        "field": "course_id",
        "type": "nominal",
        "title": "Course ID"
      }
    ]
  }
}
