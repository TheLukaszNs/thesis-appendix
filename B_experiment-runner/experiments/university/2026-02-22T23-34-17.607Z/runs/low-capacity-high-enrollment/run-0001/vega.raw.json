{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Top course sections by overbooked ratio (enrolled / max_students).",
  "title": "Top 10 Course Sections by Overbooked Ratio (enrolled / max_students)",
  "data": {
    "name": "query_result"
  },
  "width": 700,
  "height": 400,
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "y": {
      "field": "section_id",
      "type": "nominal",
      "title": "Section ID",
      "sort": "-x"
    },
    "x": {
      "field": "overbooked_ratio",
      "type": "quantitative",
      "title": "Overbooked Ratio (enrolled / max_students)",
      "axis": {
        "format": ".2f"
      }
    },
    "color": {
      "field": "semester_type",
      "type": "nominal",
      "title": "Semester"
    },
    "tooltip": [
      {
        "field": "course_id",
        "type": "nominal",
        "title": "Course ID"
      },
      {
        "field": "section_number",
        "type": "quantitative",
        "title": "Section #"
      },
      {
        "field": "academic_year",
        "type": "nominal",
        "title": "Academic Year"
      },
      {
        "field": "semester_type",
        "type": "nominal",
        "title": "Semester"
      },
      {
        "field": "enrolled_count",
        "type": "quantitative",
        "title": "Enrolled"
      },
      {
        "field": "max_students",
        "type": "quantitative",
        "title": "Max Students"
      },
      {
        "field": "overbooked_ratio",
        "type": "quantitative",
        "title": "Overbooked Ratio",
        "format": ".3f"
      }
    ]
  }
}
