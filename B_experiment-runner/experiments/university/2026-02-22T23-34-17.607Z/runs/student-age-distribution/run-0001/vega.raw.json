{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Age distribution of students",
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "age_label",
      "type": "nominal",
      "title": "Age",
      "sort": null
    },
    "y": {
      "field": "student_count",
      "type": "quantitative",
      "title": "Number of students"
    },
    "color": {
      "condition": {
        "test": "datum.age_label === 'Unknown'",
        "value": "#d62728"
      },
      "value": "#1f77b4"
    },
    "tooltip": [
      {
        "field": "age_label",
        "type": "nominal",
        "title": "Age"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Count"
      },
      {
        "field": "percentage",
        "type": "quantitative",
        "title": "Share (%)"
      }
    ]
  }
}
