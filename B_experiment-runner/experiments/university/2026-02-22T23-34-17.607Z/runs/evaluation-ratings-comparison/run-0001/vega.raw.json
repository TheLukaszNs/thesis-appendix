{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Ratings Comparison",
  "width": 600,
  "height": 360,
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadius": 3
      },
      "encoding": {
        "x": {
          "value": "Overall",
          "type": "nominal",
          "axis": {
            "title": "Rating Type"
          }
        },
        "y": {
          "field": "avg_overall",
          "type": "quantitative",
          "axis": {
            "title": "Average Rating"
          },
          "scale": {
            "domain": [
              0,
              5
            ]
          }
        },
        "color": {
          "value": "#1f77b4"
        },
        "tooltip": [
          {
            "field": "avg_overall",
            "type": "quantitative",
            "title": "Avg Overall"
          },
          {
            "field": "evaluations_count",
            "type": "quantitative",
            "title": "Evaluations Count"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "bar",
        "cornerRadius": 3
      },
      "encoding": {
        "x": {
          "value": "Professor",
          "type": "nominal"
        },
        "y": {
          "field": "avg_professor",
          "type": "quantitative"
        },
        "color": {
          "value": "#ff7f0e"
        },
        "tooltip": [
          {
            "field": "avg_professor",
            "type": "quantitative",
            "title": "Avg Professor"
          },
          {
            "field": "evaluations_count",
            "type": "quantitative",
            "title": "Evaluations Count"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "bar",
        "cornerRadius": 3
      },
      "encoding": {
        "x": {
          "value": "Content",
          "type": "nominal"
        },
        "y": {
          "field": "avg_content",
          "type": "quantitative"
        },
        "color": {
          "value": "#2ca02c"
        },
        "tooltip": [
          {
            "field": "avg_content",
            "type": "quantitative",
            "title": "Avg Content"
          },
          {
            "field": "evaluations_count",
            "type": "quantitative",
            "title": "Evaluations Count"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "bar",
        "cornerRadius": 3
      },
      "encoding": {
        "x": {
          "value": "Difficulty",
          "type": "nominal"
        },
        "y": {
          "field": "avg_difficulty",
          "type": "quantitative"
        },
        "color": {
          "value": "#d62728"
        },
        "tooltip": [
          {
            "field": "avg_difficulty",
            "type": "quantitative",
            "title": "Avg Difficulty"
          },
          {
            "field": "evaluations_count",
            "type": "quantitative",
            "title": "Evaluations Count"
          }
        ]
      }
    }
  ],
  "config": {
    "view": {
      "stroke": "transparent"
    },
    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 13
    }
  }
}
