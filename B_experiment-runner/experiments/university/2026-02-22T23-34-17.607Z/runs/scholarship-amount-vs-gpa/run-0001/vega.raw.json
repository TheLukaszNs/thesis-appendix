{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": {
    "text": "Average GPA by Scholarship Amount Range",
    "subtitle": "Average GPA and student count for each scholarship range"
  },
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "scholarship_range",
      "type": "ordinal",
      "axis": {
        "title": "Scholarship Range"
      },
      "sort": null
    },
    "y": {
      "field": "average_gpa",
      "type": "quantitative",
      "axis": {
        "title": "Average GPA"
      }
    },
    "color": {
      "field": "average_gpa",
      "type": "quantitative",
      "legend": null
    },
    "tooltip": [
      {
        "field": "scholarship_range",
        "type": "nominal",
        "title": "Scholarship Range"
      },
      {
        "field": "average_gpa",
        "type": "quantitative",
        "title": "Average GPA"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Student Count"
      }
    ]
  }
}
