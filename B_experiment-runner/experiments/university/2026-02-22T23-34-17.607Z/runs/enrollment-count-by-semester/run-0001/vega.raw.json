{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Enrollments per Semester and Academic Year",
  "width": 600,
  "height": 360,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "academic_year",
      "type": "ordinal",
      "axis": {
        "title": "Academic Year"
      }
    },
    "xOffset": {
      "field": "semester_type",
      "type": "nominal"
    },
    "y": {
      "field": "enrollment_count",
      "type": "quantitative",
      "axis": {
        "title": "Enrollment Count"
      }
    },
    "color": {
      "field": "semester_type",
      "type": "nominal",
      "title": "Semester Type"
    },
    "tooltip": [
      {
        "field": "academic_year",
        "type": "ordinal",
        "title": "Academic Year"
      },
      {
        "field": "semester_type",
        "type": "nominal",
        "title": "Semester"
      },
      {
        "field": "enrollment_count",
        "type": "quantitative",
        "title": "Enrollments"
      }
    ]
  }
}
