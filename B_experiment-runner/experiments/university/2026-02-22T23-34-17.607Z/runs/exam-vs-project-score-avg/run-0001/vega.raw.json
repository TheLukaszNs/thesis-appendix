{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Exam vs Project Scores by Department",
  "width": 700,
  "height": {
    "step": 36
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadius": 3,
        "opacity": 0.85
      },
      "encoding": {
        "y": {
          "field": "department_name",
          "type": "nominal",
          "sort": {
            "field": "department_name",
            "order": "ascending"
          },
          "axis": {
            "title": null
          }
        },
        "x": {
          "field": "avg_exam_score",
          "type": "quantitative",
          "axis": {
            "title": "Average Score",
            "grid": true
          }
        },
        "xOffset": {
          "value": -6
        },
        "color": {
          "value": "#1f77b4"
        },
        "tooltip": [
          {
            "field": "department_name",
            "type": "nominal"
          },
          {
            "field": "avg_exam_score",
            "type": "quantitative",
            "title": "Avg Exam Score"
          },
          {
            "field": "avg_project_score",
            "type": "quantitative",
            "title": "Avg Project Score"
          },
          {
            "field": "exam_minus_project_diff",
            "type": "quantitative",
            "title": "Exam - Project"
          },
          {
            "field": "exam_vs_project",
            "type": "nominal",
            "title": "Which Higher?"
          },
          {
            "field": "score_count",
            "type": "quantitative",
            "title": "Score Count"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "bar",
        "cornerRadius": 3,
        "opacity": 0.85
      },
      "encoding": {
        "y": {
          "field": "department_name",
          "type": "nominal",
          "sort": {
            "field": "department_name",
            "order": "ascending"
          },
          "axis": null
        },
        "x": {
          "field": "avg_project_score",
          "type": "quantitative"
        },
        "xOffset": {
          "value": 6
        },
        "color": {
          "value": "#ff7f0e"
        },
        "tooltip": [
          {
            "field": "department_name",
            "type": "nominal"
          },
          {
            "field": "avg_exam_score",
            "type": "quantitative",
            "title": "Avg Exam Score"
          },
          {
            "field": "avg_project_score",
            "type": "quantitative",
            "title": "Avg Project Score"
          },
          {
            "field": "exam_minus_project_diff",
            "type": "quantitative",
            "title": "Exam - Project"
          },
          {
            "field": "exam_vs_project",
            "type": "nominal",
            "title": "Which Higher?"
          },
          {
            "field": "score_count",
            "type": "quantitative",
            "title": "Score Count"
          }
        ]
      }
    }
  ],
  "resolve": {
    "scale": {
      "x": "shared"
    }
  },
  "config": {
    "axis": {
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  }
}
