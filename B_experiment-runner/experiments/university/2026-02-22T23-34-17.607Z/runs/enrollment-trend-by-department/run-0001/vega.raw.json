{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "width": 700,
  "height": 420,
  "title": "Enrollment trends by department over academic years",
  "mark": {
    "type": "line",
    "point": true,
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "academic_year",
      "type": "ordinal",
      "title": "Academic year",
      "sort": null
    },
    "y": {
      "field": "enrollments_count",
      "type": "quantitative",
      "title": "Enrollments"
    },
    "color": {
      "field": "department_name",
      "type": "nominal",
      "title": "Department"
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "department_code",
        "type": "nominal",
        "title": "Dept code"
      },
      {
        "field": "department_id",
        "type": "nominal",
        "title": "Dept id"
      },
      {
        "field": "academic_year",
        "type": "nominal",
        "title": "Academic year"
      },
      {
        "field": "enrollments_count",
        "type": "quantitative",
        "title": "Enrollments"
      }
    ]
  }
}
