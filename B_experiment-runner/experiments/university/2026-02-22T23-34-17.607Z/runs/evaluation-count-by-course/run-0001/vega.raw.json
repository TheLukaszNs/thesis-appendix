{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Evaluations Submitted per Course",
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "y": {
      "field": "course_code",
      "type": "nominal",
      "sort": "-x",
      "axis": {
        "title": "Course code",
        "labelLimit": 300
      }
    },
    "x": {
      "field": "evaluation_count",
      "type": "quantitative",
      "axis": {
        "title": "Number of evaluations"
      }
    },
    "color": {
      "field": "evaluation_count",
      "type": "quantitative",
      "legend": null
    },
    "tooltip": [
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Course code"
      },
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course name"
      },
      {
        "field": "evaluation_count",
        "type": "quantitative",
        "title": "Evaluation count"
      }
    ]
  }
}
