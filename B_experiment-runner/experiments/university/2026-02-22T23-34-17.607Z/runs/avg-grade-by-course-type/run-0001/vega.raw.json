{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Grade by Course Type",
  "width": 600,
  "height": 300,
  "mark": {
    "type": "bar",
    "cornerRadius": 3
  },
  "encoding": {
    "y": {
      "field": "course_type",
      "type": "nominal",
      "axis": {
        "title": "Course Type"
      },
      "sort": {
        "field": "average_grade",
        "op": "max",
        "order": "descending"
      }
    },
    "x": {
      "field": "average_grade",
      "type": "quantitative",
      "axis": {
        "title": "Average Grade",
        "format": ".2f"
      }
    },
    "tooltip": [
      {
        "field": "course_type",
        "type": "nominal",
        "title": "Course Type"
      },
      {
        "field": "average_grade",
        "type": "quantitative",
        "title": "Average Grade",
        "format": ".2f"
      }
    ]
  }
}
