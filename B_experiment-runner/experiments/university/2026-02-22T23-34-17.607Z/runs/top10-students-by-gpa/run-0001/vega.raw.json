{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Top 10 students by GPA",
  "width": 650,
  "height": 360,
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadius": 3,
        "opacity": 0.85
      },
      "encoding": {
        "x": {
          "field": "gpa",
          "type": "quantitative",
          "title": "GPA"
        },
        "y": {
          "field": "last_name",
          "type": "nominal",
          "title": "Last name",
          "sort": {
            "field": "gpa",
            "order": "descending"
          }
        },
        "tooltip": [
          {
            "field": "first_name",
            "type": "nominal",
            "title": "First name"
          },
          {
            "field": "last_name",
            "type": "nominal",
            "title": "Last name"
          },
          {
            "field": "index_number",
            "type": "nominal",
            "title": "Index number"
          },
          {
            "field": "email",
            "type": "nominal",
            "title": "Email"
          },
          {
            "field": "student_id",
            "type": "nominal",
            "title": "Student ID"
          },
          {
            "field": "gpa",
            "type": "quantitative",
            "title": "GPA"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 4,
        "baseline": "middle",
        "fontWeight": "normal"
      },
      "encoding": {
        "x": {
          "field": "gpa",
          "type": "quantitative"
        },
        "y": {
          "field": "last_name",
          "type": "nominal",
          "sort": {
            "field": "gpa",
            "order": "descending"
          }
        },
        "text": {
          "field": "gpa",
          "type": "quantitative",
          "format": ".2f"
        }
      }
    }
  ],
  "config": {
    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 13
    },
    "title": {
      "fontSize": 15
    }
  }
}
