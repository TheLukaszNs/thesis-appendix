{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average exam, project, and attendance scores by grade value",
  "width": 640,
  "height": 400,
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadius": 3
      },
      "encoding": {
        "x": {
          "field": "grade_value",
          "type": "ordinal",
          "axis": {
            "title": "Grade value"
          }
        },
        "y": {
          "field": "avg_exam_score",
          "type": "quantitative",
          "axis": {
            "title": "Average score"
          }
        },
        "xOffset": {
          "value": -14
        },
        "color": {
          "value": "#1f77b4"
        },
        "tooltip": [
          {
            "field": "grade_value",
            "type": "nominal",
            "title": "Grade value"
          },
          {
            "field": "avg_exam_score",
            "type": "quantitative",
            "title": "Avg exam score"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "bar",
        "cornerRadius": 3
      },
      "encoding": {
        "x": {
          "field": "grade_value",
          "type": "ordinal"
        },
        "y": {
          "field": "avg_project_score",
          "type": "quantitative"
        },
        "xOffset": {
          "value": 0
        },
        "color": {
          "value": "#ff7f0e"
        },
        "tooltip": [
          {
            "field": "grade_value",
            "type": "nominal",
            "title": "Grade value"
          },
          {
            "field": "avg_project_score",
            "type": "quantitative",
            "title": "Avg project score"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "bar",
        "cornerRadius": 3
      },
      "encoding": {
        "x": {
          "field": "grade_value",
          "type": "ordinal"
        },
        "y": {
          "field": "avg_attendance_score",
          "type": "quantitative"
        },
        "xOffset": {
          "value": 14
        },
        "color": {
          "value": "#2ca02c"
        },
        "tooltip": [
          {
            "field": "grade_value",
            "type": "nominal",
            "title": "Grade value"
          },
          {
            "field": "avg_attendance_score",
            "type": "quantitative",
            "title": "Avg attendance score"
          }
        ]
      }
    }
  ]
}
