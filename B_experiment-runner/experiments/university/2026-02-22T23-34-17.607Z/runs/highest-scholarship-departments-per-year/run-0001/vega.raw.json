{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Department with Highest Total Scholarships per Academic Year",
  "width": 600,
  "height": 400,
  "layer": [
    {
      "mark": {
        "type": "bar"
      },
      "encoding": {
        "x": {
          "field": "academic_year",
          "type": "ordinal",
          "title": "Academic Year",
          "axis": {
            "labelAngle": 0
          }
        },
        "y": {
          "field": "total_amount",
          "type": "quantitative",
          "title": "Total Scholarship Amount"
        },
        "color": {
          "field": "department_name",
          "type": "nominal",
          "title": "Department"
        },
        "tooltip": [
          {
            "field": "academic_year",
            "type": "nominal",
            "title": "Academic Year"
          },
          {
            "field": "department_name",
            "type": "nominal",
            "title": "Department"
          },
          {
            "field": "total_amount",
            "type": "quantitative",
            "title": "Total Amount"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "dy": -8,
        "fontWeight": "bold"
      },
      "encoding": {
        "x": {
          "field": "academic_year",
          "type": "ordinal"
        },
        "y": {
          "field": "total_amount",
          "type": "quantitative"
        },
        "text": {
          "field": "department_name",
          "type": "nominal"
        },
        "tooltip": [
          {
            "field": "academic_year",
            "type": "nominal",
            "title": "Academic Year"
          },
          {
            "field": "department_name",
            "type": "nominal",
            "title": "Department"
          },
          {
            "field": "total_amount",
            "type": "quantitative",
            "title": "Total Amount"
          }
        ]
      }
    }
  ]
}
