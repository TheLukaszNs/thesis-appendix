{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Grade distribution by department (percent)",
  "data": {
    "name": "query_result"
  },
  "width": 800,
  "height": 400,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "labelAngle": -40,
        "labelOverlap": "parity",
        "title": "Department"
      }
    },
    "y": {
      "field": "pct_of_department",
      "type": "quantitative",
      "axis": {
        "title": "Percent of department (%)"
      }
    },
    "color": {
      "field": "grade_value",
      "type": "nominal",
      "legend": {
        "title": "Grade"
      }
    },
    "order": {
      "field": "grade_value",
      "sort": "descending"
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "grade_value",
        "type": "nominal",
        "title": "Grade"
      },
      {
        "field": "grade_count",
        "type": "quantitative",
        "title": "Count"
      },
      {
        "field": "pct_of_department",
        "type": "quantitative",
        "title": "Pct of dept (%)"
      }
    ]
  }
}
