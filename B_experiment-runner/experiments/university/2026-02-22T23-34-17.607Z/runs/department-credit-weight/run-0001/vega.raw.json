{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Distribution of course credit values by department",
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "department_code",
      "type": "ordinal",
      "axis": {
        "title": "Department",
        "labelAngle": -40
      }
    },
    "y": {
      "aggregate": "sum",
      "field": "course_count",
      "type": "quantitative",
      "stack": "normalize",
      "axis": {
        "title": "Percent of department",
        "format": "%"
      }
    },
    "color": {
      "field": "credits",
      "type": "nominal",
      "legend": {
        "title": "Credits"
      }
    },
    "order": {
      "field": "credits",
      "type": "ordinal"
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "credits",
        "type": "nominal",
        "title": "Credits"
      },
      {
        "field": "course_count",
        "type": "quantitative",
        "title": "Course count"
      },
      {
        "field": "percent_of_department",
        "type": "quantitative",
        "title": "Percent of department (%)"
      }
    ]
  }
}
