{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Top 10 Professors by Average Student Evaluation Rating",
  "height": 400,
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "last_name",
      "type": "nominal",
      "sort": {
        "field": "avg_professor_rating",
        "order": "descending"
      },
      "axis": {
        "title": "Professor last name"
      }
    },
    "x": {
      "field": "avg_professor_rating",
      "type": "quantitative",
      "axis": {
        "title": "Average rating (students)"
      },
      "scale": {
        "domain": [
          0,
          5
        ]
      }
    },
    "color": {
      "field": "eval_count",
      "type": "quantitative",
      "legend": {
        "title": "Evaluation count"
      },
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "first_name",
        "type": "nominal",
        "title": "First name"
      },
      {
        "field": "last_name",
        "type": "nominal",
        "title": "Last name"
      },
      {
        "field": "avg_professor_rating",
        "type": "quantitative",
        "title": "Avg rating"
      },
      {
        "field": "eval_count",
        "type": "quantitative",
        "title": "Evaluations"
      },
      {
        "field": "professor_id",
        "type": "nominal",
        "title": "Professor ID"
      }
    ]
  }
}
