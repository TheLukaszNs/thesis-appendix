{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Mandatory vs Optional Prerequisites",
  "mark": {
    "type": "bar",
    "cornerRadius": 3
  },
  "encoding": {
    "x": {
      "field": "prerequisite_type",
      "type": "nominal",
      "axis": {
        "title": "Prerequisite Type",
        "labelAngle": 0
      },
      "sort": [
        "mandatory",
        "optional"
      ]
    },
    "y": {
      "field": "total_count",
      "type": "quantitative",
      "axis": {
        "title": "Total Count"
      }
    },
    "color": {
      "field": "prerequisite_type",
      "type": "nominal",
      "legend": {
        "title": "Type"
      }
    },
    "tooltip": [
      {
        "field": "prerequisite_type",
        "type": "nominal",
        "title": "Prerequisite Type"
      },
      {
        "field": "total_count",
        "type": "quantitative",
        "title": "Count"
      }
    ]
  }
}
