{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Total Credits by Department",
  "height": {
    "step": 28
  },
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "dept_name",
      "type": "nominal",
      "sort": {
        "field": "total_credits",
        "order": "descending"
      },
      "axis": {
        "title": "Department"
      }
    },
    "x": {
      "field": "total_credits",
      "type": "quantitative",
      "axis": {
        "title": "Total Credits"
      }
    },
    "color": {
      "field": "dept_code",
      "type": "nominal",
      "legend": {
        "title": "Dept Code"
      }
    },
    "tooltip": [
      {
        "field": "dept_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "dept_code",
        "type": "nominal",
        "title": "Dept Code"
      },
      {
        "field": "total_credits",
        "type": "quantitative",
        "title": "Total Credits"
      }
    ]
  }
}
