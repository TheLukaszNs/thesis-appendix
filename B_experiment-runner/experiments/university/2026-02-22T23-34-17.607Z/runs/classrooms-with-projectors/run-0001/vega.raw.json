{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Percentage of Classrooms with Projectors by Building",
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "building",
      "type": "nominal",
      "axis": {
        "title": "Building"
      },
      "sort": null
    },
    "y": {
      "field": "projector_pct",
      "type": "quantitative",
      "axis": {
        "title": "% Classrooms with Projectors"
      },
      "scale": {
        "domain": [
          0,
          100
        ]
      }
    },
    "color": {
      "field": "projector_pct",
      "type": "quantitative",
      "legend": null,
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "building",
        "type": "nominal",
        "title": "Building"
      },
      {
        "field": "projector_pct",
        "type": "quantitative",
        "title": "Projector %",
        "format": ".2f"
      },
      {
        "field": "projector_count",
        "type": "quantitative",
        "title": "Projector Count"
      },
      {
        "field": "total_classrooms",
        "type": "quantitative",
        "title": "Total Classrooms"
      }
    ]
  }
}
