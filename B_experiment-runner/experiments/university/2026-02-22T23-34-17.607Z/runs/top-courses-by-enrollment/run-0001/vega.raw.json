{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Top 15 Courses by Total Enrollments",
  "width": 700,
  "height": 420,
  "encoding": {
    "y": {
      "field": "course_name",
      "type": "nominal",
      "sort": {
        "encoding": "x",
        "order": "descending"
      },
      "axis": {
        "title": "Course"
      }
    },
    "x": {
      "field": "total_enrollments",
      "type": "quantitative",
      "axis": {
        "title": "Total Enrollments"
      }
    },
    "color": {
      "field": "course_code",
      "type": "nominal",
      "legend": null
    },
    "tooltip": [
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "total_enrollments",
        "type": "quantitative",
        "title": "Total Enrollments"
      },
      {
        "field": "course_id",
        "type": "nominal",
        "title": "Course ID"
      }
    ]
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadius": 4
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 6
      },
      "encoding": {
        "text": {
          "field": "total_enrollments",
          "type": "quantitative"
        }
      }
    }
  ]
}
