{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Professors with Lowest Average Grades (Strictest Graders)",
  "width": 700,
  "height": 500,
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "y": {
      "field": "professor_name",
      "type": "nominal",
      "axis": {
        "title": "Professor"
      },
      "sort": {
        "field": "average_grade",
        "order": "ascending"
      }
    },
    "x": {
      "field": "average_grade",
      "type": "quantitative",
      "axis": {
        "title": "Average Grade"
      }
    },
    "color": {
      "field": "num_grades",
      "type": "quantitative",
      "legend": {
        "title": "Number of Grades"
      }
    },
    "tooltip": [
      {
        "field": "professor_name",
        "type": "nominal",
        "title": "Professor"
      },
      {
        "field": "average_grade",
        "type": "quantitative",
        "title": "Average Grade"
      },
      {
        "field": "num_grades",
        "type": "quantitative",
        "title": "Number of Grades"
      },
      {
        "field": "professor_id",
        "type": "nominal",
        "title": "Professor ID"
      }
    ]
  }
}
