{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "width": 700,
  "height": {
    "step": 30
  },
  "title": {
    "text": "Average overall score by professors' academic title",
    "subtitle": "Bar length = avg overall score. Color = avg exam score. Hover for counts and component averages."
  },
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "y": {
      "field": "academic_title",
      "type": "nominal",
      "axis": {
        "title": "Academic Title"
      },
      "sort": {
        "field": "avg_overall_score",
        "op": "mean",
        "order": "descending"
      }
    },
    "x": {
      "field": "avg_overall_score",
      "type": "quantitative",
      "axis": {
        "title": "Average Overall Score"
      }
    },
    "color": {
      "field": "avg_exam_score",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      },
      "legend": {
        "title": "Avg Exam Score"
      }
    },
    "tooltip": [
      {
        "field": "academic_title",
        "type": "nominal",
        "title": "Academic Title"
      },
      {
        "field": "grade_count",
        "type": "quantitative",
        "title": "Grade Count"
      },
      {
        "field": "avg_overall_score",
        "type": "quantitative",
        "title": "Avg Overall Score"
      },
      {
        "field": "avg_exam_score",
        "type": "quantitative",
        "title": "Avg Exam Score"
      },
      {
        "field": "avg_project_score",
        "type": "quantitative",
        "title": "Avg Project Score"
      },
      {
        "field": "avg_attendance_score",
        "type": "quantitative",
        "title": "Avg Attendance Score"
      }
    ]
  }
}
