{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Average attendance score for each course",
  "data": {
    "name": "query_result"
  },
  "title": "Average Attendance Score by Course",
  "width": 700,
  "height": 400,
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3
  },
  "encoding": {
    "x": {
      "field": "course_code",
      "type": "nominal",
      "axis": {
        "title": "Course Code",
        "labelAngle": -45,
        "labelOverlap": "parity"
      },
      "sort": "ascending"
    },
    "y": {
      "field": "avg_attendance_score",
      "type": "quantitative",
      "axis": {
        "title": "Average Attendance Score"
      },
      "scale": {
        "nice": true
      }
    },
    "tooltip": [
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "avg_attendance_score",
        "type": "quantitative",
        "title": "Avg Attendance Score"
      }
    ]
  }
}
