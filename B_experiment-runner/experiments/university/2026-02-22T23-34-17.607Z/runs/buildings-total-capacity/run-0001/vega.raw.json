{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Total seating capacity per building",
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "building",
      "type": "ordinal",
      "axis": {
        "title": "Building"
      },
      "sort": "ascending"
    },
    "y": {
      "field": "total_capacity",
      "type": "quantitative",
      "axis": {
        "title": "Total capacity"
      }
    },
    "tooltip": [
      {
        "field": "building",
        "type": "ordinal",
        "title": "Building"
      },
      {
        "field": "total_capacity",
        "type": "quantitative",
        "title": "Total capacity"
      }
    ],
    "color": {
      "value": "#4C78A8"
    }
  }
}
