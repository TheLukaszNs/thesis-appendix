            "title": "Academic Year"
          },
          {
            "field": "semester_type",
            "type": "nominal",
            "title": "Semester"
          },
          {
            "field": "average_grade",
            "type": "quantitative",
            "title": "Average Grade"
          },
          {
            "field": "grade_count",
            "type": "quantitative",
            "title": "Grade Count"
          }
        ]
      }
    }
