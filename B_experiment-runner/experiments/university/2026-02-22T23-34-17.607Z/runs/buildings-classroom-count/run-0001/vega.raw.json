{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Classrooms per Building",
  "width": 700,
  "height": 400,
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadius": 3
      },
      "encoding": {
        "x": {
          "field": "building",
          "type": "nominal",
          "axis": {
            "title": "Building",
            "labelAngle": -45
          },
          "sort": {
            "field": "classroom_count",
            "order": "descending"
          }
        },
        "y": {
          "field": "classroom_count",
          "type": "quantitative",
          "axis": {
            "title": "Number of Classrooms"
          }
        },
        "tooltip": [
          {
            "field": "building",
            "type": "nominal",
            "title": "Building"
          },
          {
            "field": "classroom_count",
            "type": "quantitative",
            "title": "Classroom Count"
          }
        ],
        "color": {
          "value": "#4C78A8"
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "dy": -6,
        "fontWeight": "bold"
      },
      "encoding": {
        "x": {
          "field": "building",
          "type": "nominal",
          "sort": {
            "field": "classroom_count",
            "order": "descending"
          }
        },
        "y": {
          "field": "classroom_count",
          "type": "quantitative"
        },
        "text": {
          "field": "classroom_count",
          "type": "quantitative"
        }
      }
    }
  ]
}
