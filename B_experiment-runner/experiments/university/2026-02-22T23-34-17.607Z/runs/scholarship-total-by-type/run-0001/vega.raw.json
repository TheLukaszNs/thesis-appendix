{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Total Scholarship Amount by Scholarship Type",
  "width": 600,
  "height": 200,
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "y": {
      "field": "scholarship_type",
      "type": "nominal",
      "title": "Scholarship Type",
      "sort": {
        "field": "total_amount",
        "order": "descending"
      }
    },
    "x": {
      "field": "total_amount",
      "type": "quantitative",
      "title": "Total Amount (USD)"
    },
    "tooltip": [
      {
        "field": "scholarship_type",
        "type": "nominal",
        "title": "Scholarship Type"
      },
      {
        "field": "total_amount",
        "type": "quantitative",
        "title": "Total Amount",
        "format": "$,.0f"
      }
    ],
    "color": {
      "value": "#4C78A8"
    }
  }
}
