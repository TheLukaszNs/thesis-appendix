{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Percentage of students who would recommend each course",
  "width": 700,
  "height": {
    "step": 22
  },
  "layer": [
    {
      "mark": {
        "type": "bar"
      },
      "encoding": {
        "y": {
          "field": "course_code",
          "type": "nominal",
          "title": "Course",
          "sort": {
            "field": "recommend_pct",
            "order": "descending"
          }
        },
        "x": {
          "field": "recommend_pct",
          "type": "quantitative",
          "title": "Recommend (%)",
          "axis": {
            "format": ".2f"
          }
        },
        "color": {
          "field": "recommend_pct",
          "type": "quantitative",
          "legend": null
        },
        "tooltip": [
          {
            "field": "course_name",
            "type": "nominal",
            "title": "Course name"
          },
          {
            "field": "course_code",
            "type": "nominal",
            "title": "Course code"
          },
          {
            "field": "recommend_pct",
            "type": "quantitative",
            "title": "Recommend (%)",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 4,
        "baseline": "middle",
        "color": "black"
      },
      "encoding": {
        "y": {
          "field": "course_code",
          "type": "nominal",
          "sort": {
            "field": "recommend_pct",
            "order": "descending"
          }
        },
        "x": {
          "field": "recommend_pct",
          "type": "quantitative"
        },
        "text": {
          "field": "recommend_pct",
          "type": "quantitative",
          "format": ".2f"
        }
      }
    }
  ]
}
