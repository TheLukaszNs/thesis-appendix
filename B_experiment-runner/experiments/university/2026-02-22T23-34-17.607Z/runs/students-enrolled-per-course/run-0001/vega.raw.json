{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Enrolled students per course",
  "height": {
    "step": 22
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadius": 3
      },
      "encoding": {
        "y": {
          "field": "course_code",
          "type": "nominal",
          "title": "Course code",
          "sort": {
            "field": "enrolled_students",
            "order": "descending"
          }
        },
        "x": {
