          "type": "quantitative",
          "title": "Enrolled students"
        },
        "tooltip": [
          {
            "field": "course_code",
            "type": "nominal",
            "title": "Course code"
          },
          {
            "field": "course_name",
            "type": "nominal",
            "title": "Course name"
          },
          {
            "field": "enrolled_students",
            "type": "quantitative",
            "title": "Enrolled students"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 4
      },
      "encoding": {
        "y": {
          "field": "course_code",
          "type": "nominal",
          "sort": {
            "field": "enrolled_students",
            "order": "descending"
          }
        },
        "x": {
          "field": "enrolled_students",
          "type": "quantitative"
        },
        "text": {
          "field": "enrolled_students",
          "type": "quantitative"
        }
      }
