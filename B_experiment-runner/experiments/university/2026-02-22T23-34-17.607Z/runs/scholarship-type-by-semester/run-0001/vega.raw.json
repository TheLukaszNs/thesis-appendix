{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Scholarship counts by type for each semester type",
  "width": 600,
  "height": 320,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "semester_type",
      "type": "nominal",
      "axis": {
        "title": "Semester Type"
      }
    },
    "xOffset": {
      "field": "scholarship_type"
    },
    "y": {
      "field": "scholarship_count",
      "type": "quantitative",
      "axis": {
        "title": "Scholarship Count"
      }
    },
    "color": {
      "field": "scholarship_type",
      "type": "nominal",
      "legend": {
        "title": "Scholarship Type"
      }
    },
    "tooltip": [
      {
        "field": "semester_type",
        "type": "nominal",
        "title": "Semester Type"
      },
      {
        "field": "scholarship_type",
        "type": "nominal",
        "title": "Scholarship Type"
      },
      {
        "field": "scholarship_count",
        "type": "quantitative",
        "title": "Count"
      }
    ]
  }
}
