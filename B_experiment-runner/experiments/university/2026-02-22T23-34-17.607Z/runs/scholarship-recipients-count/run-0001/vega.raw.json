{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Number of Students by Scholarship Type",
  "width": 400,
  "height": 300,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "scholarship_type",
      "type": "nominal",
      "title": "Scholarship Type",
      "sort": {
        "field": "student_count",
        "order": "descending"
      }
    },
    "y": {
      "field": "student_count",
      "type": "quantitative",
      "title": "Number of Students"
    },
    "tooltip": [
      {
        "field": "scholarship_type",
        "type": "nominal",
        "title": "Scholarship Type"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Student Count"
      }
    ]
  }
}
