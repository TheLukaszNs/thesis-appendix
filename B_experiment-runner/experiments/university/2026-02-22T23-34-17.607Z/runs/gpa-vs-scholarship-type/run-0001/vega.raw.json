{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Average GPA by Scholarship Type",
  "data": {
    "name": "query_result"
  },
  "width": 500,
  "height": 300,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "scholarship_type",
      "type": "nominal",
      "axis": {
        "title": "Scholarship Type"
      }
    },
    "y": {
      "field": "avg_gpa",
      "type": "quantitative",
      "axis": {
        "title": "Average GPA"
      }
    },
    "color": {
      "field": "scholarship_type",
      "type": "nominal",
      "legend": null
    },
    "tooltip": [
      {
        "field": "scholarship_type",
        "type": "nominal",
        "title": "Scholarship Type"
      },
      {
        "field": "avg_gpa",
        "type": "quantitative",
        "title": "Average GPA"
      }
    ]
  }
}
