{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Overall Evaluation Rating per Department",
  "width": 700,
  "height": {
    "step": 30
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadius": 3
      },
      "encoding": {
        "x": {
          "field": "avg_overall_rating",
          "type": "quantitative",
          "title": "Average Overall Rating",
          "scale": {
            "domain": [
              0,
              5
            ]
          }
        },
        "y": {
          "field": "department_name",
          "type": "nominal",
          "title": null,
          "sort": {
            "field": "avg_overall_rating",
            "order": "descending"
          }
        },
        "color": {
          "field": "avg_overall_rating",
          "type": "quantitative",
          "title": "Avg Rating",
          "scale": {
            "scheme": "blues"
          }
        },
        "tooltip": [
          {
            "field": "department_name",
            "type": "nominal",
            "title": "Department"
          },
          {
            "field": "avg_overall_rating",
            "type": "quantitative",
            "title": "Avg Overall Rating"
          },
          {
            "field": "evaluations_count",
            "type": "quantitative",
            "title": "Evaluations Count"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 4
      },
      "encoding": {
        "x": {
          "field": "avg_overall_rating",
          "type": "quantitative"
        },
        "y": {
          "field": "department_name",
          "type": "nominal",
          "sort": {
            "field": "avg_overall_rating",
            "order": "descending"
          }
        },
        "text": {
          "field": "avg_overall_rating",
          "type": "quantitative",
          "format": ".2f"
        },
        "detail": {
          "field": "department_id",
          "type": "nominal"
        }
      }
    }
  ]
}
