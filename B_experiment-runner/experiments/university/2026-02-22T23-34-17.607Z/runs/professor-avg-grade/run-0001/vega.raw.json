{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Grade by Professor",
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "y": {
      "field": "last_name",
      "type": "nominal",
      "title": "Professor (last name)",
      "sort": {
        "field": "average_grade",
        "order": "descending"
      }
    },
    "x": {
      "field": "average_grade",
      "type": "quantitative",
      "title": "Average Grade"
    },
    "tooltip": [
      {
        "field": "first_name",
        "type": "nominal",
        "title": "First name"
      },
      {
        "field": "last_name",
        "type": "nominal",
        "title": "Last name"
      },
      {
        "field": "average_grade",
        "type": "quantitative",
        "title": "Average grade"
      },
      {
        "field": "grade_count",
        "type": "quantitative",
        "title": "Grade count"
      },
      {
        "field": "professor_id",
        "type": "nominal",
        "title": "Professor ID"
      }
    ]
  },
  "height": {
    "step": 25
  }
}
