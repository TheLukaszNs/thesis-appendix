{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Total Scholarship Amounts per Academic Year",
  "width": 640,
  "height": 320,
  "mark": {
    "type": "bar",
    "cornerRadius": 3
  },
  "encoding": {
    "x": {
      "field": "academic_year",
      "type": "ordinal",
      "axis": {
        "title": "Academic Year"
      },
      "sort": "ascending"
    },
    "y": {
      "field": "total_amount",
      "type": "quantitative",
      "axis": {
        "title": "Total Amount (USD)"
      }
    },
    "tooltip": [
      {
        "field": "academic_year",
        "type": "nominal",
        "title": "Academic Year"
      },
      {
        "field": "total_amount",
        "type": "quantitative",
        "title": "Total Amount",
        "format": "$,.2f"
      }
    ]
  }
}
