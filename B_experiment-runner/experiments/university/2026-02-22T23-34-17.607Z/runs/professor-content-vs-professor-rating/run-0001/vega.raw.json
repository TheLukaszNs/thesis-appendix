{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Content Rating vs Average Professor Rating by Professor",
  "width": 700,
  "height": 450,
  "layer": [
    {
      "mark": {
        "type": "point",
        "filled": true,
        "opacity": 0.9
      },
      "encoding": {
        "x": {
          "field": "average_content_rating",
          "type": "quantitative",
          "title": "Average Content Rating",
          "scale": {
            "domain": [
              1,
              5
            ]
          }
        },
        "y": {
          "field": "average_professor_rating",
          "type": "quantitative",
          "title": "Average Professor Rating",
          "scale": {
            "domain": [
              1,
              5
            ]
          }
        },
        "size": {
          "field": "evaluation_count",
          "type": "quantitative",
          "title": "Evaluation Count",
          "scale": {
            "range": [
              60,
              360
            ]
          }
        },
        "color": {
          "field": "evaluation_count",
          "type": "quantitative",
          "legend": {
            "title": "Evaluation Count"
          },
          "scale": {
            "scheme": "blues"
          }
        },
        "tooltip": [
          {
            "field": "professor_name",
            "type": "nominal",
            "title": "Professor"
          },
          {
            "field": "evaluation_count",
            "type": "quantitative",
            "title": "Evaluations"
          },
          {
            "field": "average_content_rating",
            "type": "quantitative",
            "title": "Avg Content",
            "format": ".2f"
          },
          {
            "field": "average_professor_rating",
            "type": "quantitative",
            "title": "Avg Professor",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "dy": -12,
        "fontSize": 11,
        "opacity": 0.9
      },
      "encoding": {
        "x": {
          "field": "average_content_rating",
          "type": "quantitative"
        },
        "y": {
          "field": "average_professor_rating",
          "type": "quantitative"
        },
        "text": {
          "field": "professor_name",
          "type": "nominal"
        },
        "tooltip": [
          {
            "field": "professor_name",
            "type": "nominal",
            "title": "Professor"
          },
          {
            "field": "evaluation_count",
            "type": "quantitative",
            "title": "Evaluations"
          },
          {
            "field": "average_content_rating",
            "type": "quantitative",
            "title": "Avg Content",
            "format": ".2f"
          },
          {
            "field": "average_professor_rating",
            "type": "quantitative",
            "title": "Avg Professor",
            "format": ".2f"
          }
        ]
      }
    }
  ]
}
