{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "width": 600,
  "height": {
    "step": 30
  },
  "title": "Percentage of students who would recommend courses, by department",
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "y": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "title": null
      },
      "sort": {
        "field": "recommend_pct",
        "order": "descending"
      }
    },
    "x": {
      "field": "recommend_pct",
      "type": "quantitative",
      "axis": {
        "title": "Recommend (%)",
        "format": ".2f"
      },
      "scale": {
        "domain": [
          0,
          100
        ]
      }
    },
    "color": {
      "value": "#4C78A8"
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "recommend_pct",
        "type": "quantitative",
        "title": "Recommend (%)",
        "format": ".2f"
      },
      {
        "field": "department_id",
        "type": "nominal",
        "title": "Department ID"
      }
    ]
  }
}
