{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Number of course sections taught in each building",
  "width": 700,
  "height": 420,
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "y": {
      "field": "building",
      "type": "nominal",
      "title": "Building",
      "sort": "-x"
    },
    "x": {
      "field": "section_count",
      "type": "quantitative",
      "title": "Section count"
    },
    "color": {
      "field": "section_count",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      },
      "legend": {
        "title": "Sections"
      }
    },
    "tooltip": [
      {
        "field": "building",
        "type": "nominal",
        "title": "Building"
      },
      {
        "field": "section_count",
        "type": "quantitative",
        "title": "Section count"
      }
    ]
  }
}
