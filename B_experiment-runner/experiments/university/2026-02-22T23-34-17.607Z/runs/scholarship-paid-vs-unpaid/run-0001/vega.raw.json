{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Scholarships: Paid vs Not Paid",
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "scholarships_count",
      "type": "quantitative",
      "title": "Number of Scholarships"
    },
    "y": {
      "field": "status",
      "type": "nominal",
      "title": "Payment Status",
      "sort": [
        "Paid",
        "Not Paid"
      ]
    },
    "color": {
      "field": "status",
      "type": "nominal",
      "legend": {
        "title": "Status"
      }
    },
    "tooltip": [
      {
        "field": "status",
        "type": "nominal",
        "title": "Status"
      },
      {
        "field": "scholarships_count",
        "type": "quantitative",
        "title": "Count"
      }
    ]
  }
}
