{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Courses offered in the most sections (ranked)",
  "height": {
    "step": 22
  },
  "layer": [
    {
      "mark": {
        "type": "bar"
      },
      "encoding": {
        "x": {
          "field": "sections_offered",
          "type": "quantitative",
          "title": "Sections offered"
        },
        "y": {
          "field": "course_code",
          "type": "nominal",
          "title": "Course code",
          "sort": "-x"
        },
        "color": {
          "field": "sections_offered",
          "type": "quantitative",
          "legend": null
        },
        "tooltip": [
          {
            "field": "course_code",
            "type": "nominal",
            "title": "Course code"
          },
          {
            "field": "course_name",
            "type": "nominal",
            "title": "Course name"
          },
          {
            "field": "sections_offered",
            "type": "quantitative",
            "title": "Sections offered"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 4
      },
      "encoding": {
        "x": {
          "field": "sections_offered",
          "type": "quantitative"
        },
        "y": {
          "field": "course_code",
          "type": "nominal",
          "sort": "-x"
        },
        "text": {
          "field": "sections_offered",
          "type": "quantitative"
        }
      }
    }
  ]
}
