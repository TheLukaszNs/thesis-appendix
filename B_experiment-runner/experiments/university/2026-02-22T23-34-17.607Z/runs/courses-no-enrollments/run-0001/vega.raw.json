{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Courses with No Enrollments",
  "mark": "bar",
  "encoding": {
    "x": {
      "aggregate": "count",
      "field": "course_id",
      "type": "quantitative",
      "title": "Record count"
    },
    "y": {
      "field": "course_code",
      "type": "nominal",
      "title": "Course Code",
      "sort": "ascending"
    },
    "tooltip": [
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "course_id",
        "type": "nominal",
        "title": "Course ID"
      }
    ]
  },
  "height": {
    "step": 28
  }
}
