{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Professor Ratings by Academic Year",
  "width": 700,
  "height": 350,
  "layer": [
    {
      "mark": {
        "type": "line",
        "interpolate": "monotone"
      },
      "encoding": {
        "x": {
          "field": "academic_year",
          "type": "ordinal",
          "title": "Academic Year",
          "sort": "ascending"
        },
        "y": {
          "field": "avg_professor_rating",
          "type": "quantitative",
          "title": "Avg Professor Rating"
        },
        "tooltip": [
          {
            "field": "academic_year",
            "type": "ordinal",
            "title": "Academic Year"
          },
          {
            "field": "avg_professor_rating",
            "type": "quantitative",
            "title": "Avg Professor Rating"
          },
          {
            "field": "evaluation_count",
            "type": "quantitative",
            "title": "Evaluation Count"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true
      },
      "encoding": {
        "x": {
          "field": "academic_year",
          "type": "ordinal",
          "sort": "ascending"
        },
        "y": {
          "field": "avg_professor_rating",
          "type": "quantitative"
        },
        "size": {
          "field": "evaluation_count",
          "type": "quantitative",
          "title": "Evaluation Count"
        },
        "tooltip": [
          {
            "field": "academic_year",
            "type": "ordinal",
            "title": "Academic Year"
          },
          {
            "field": "avg_professor_rating",
            "type": "quantitative",
            "title": "Avg Professor Rating"
          },
          {
            "field": "evaluation_count",
            "type": "quantitative",
            "title": "Evaluation Count"
          }
        ]
      }
    }
  ],
  "config": {
    "axis": {
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  }
}
