{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average sections per professor by department",
  "width": 700,
  "height": 180,
  "mark": {
    "type": "bar",
    "cornerRadius": 3
  },
  "encoding": {
    "x": {
      "field": "avg_sections_per_professor",
      "type": "quantitative",
      "title": "Avg sections per professor"
    },
    "y": {
      "field": "department_name",
      "type": "nominal",
      "title": "Department",
      "sort": "-x"
    },
    "color": {
      "field": "professor_count",
      "type": "quantitative",
      "title": "Professor count",
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "department_code",
        "type": "nominal",
        "title": "Code"
      },
      {
        "field": "professor_count",
        "type": "quantitative",
        "title": "Professors"
      },
      {
        "field": "total_sections",
        "type": "quantitative",
        "title": "Total sections"
      },
      {
        "field": "avg_sections_per_professor",
        "type": "quantitative",
        "title": "Avg per professor"
      }
    ]
  }
}
