{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average GPA by Enrollment Year",
  "width": 640,
  "height": 360,
  "mark": {
    "type": "line",
    "point": true,
    "interpolate": "monotone"
  },
  "encoding": {
    "x": {
      "field": "enrollment_year",
      "type": "temporal",
      "timeUnit": "year",
      "title": "Enrollment Year",
      "axis": {
        "format": "%Y"
      }
    },
    "y": {
      "field": "average_gpa",
      "type": "quantitative",
      "title": "Average GPA"
    },
    "tooltip": [
      {
        "field": "enrollment_year",
        "type": "temporal",
        "timeUnit": "year",
        "title": "Enrollment Year"
      },
      {
        "field": "average_gpa",
        "type": "quantitative",
        "title": "Average GPA"
      }
    ]
  }
}
