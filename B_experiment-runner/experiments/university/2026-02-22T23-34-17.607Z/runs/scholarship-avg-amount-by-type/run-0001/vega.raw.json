{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Scholarship Amount by Type",
  "width": 500,
  "height": 300,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "scholarship_type",
      "type": "nominal",
      "axis": {
        "title": "Scholarship Type"
      },
      "sort": "ascending"
    },
    "y": {
      "field": "average_amount",
      "type": "quantitative",
      "axis": {
        "title": "Average Amount (USD)",
        "format": "$,.2f"
      }
    },
    "color": {
      "field": "scholarship_type",
      "type": "nominal",
      "legend": null
    },
    "tooltip": [
      {
        "field": "scholarship_type",
        "type": "nominal",
        "title": "Type"
      },
      {
        "field": "average_amount",
        "type": "quantitative",
        "title": "Average Amount",
        "format": "$,.2f"
      }
    ]
  }
}
