{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average GPA by Current Semester",
  "width": 600,
  "height": 320,
  "layer": [
    {
      "mark": {
        "type": "line",
        "interpolate": "monotone"
      },
      "encoding": {
        "x": {
          "field": "semester",
          "type": "quantitative",
          "title": "Current semester"
        },
        "y": {
          "field": "avg_gpa",
          "type": "quantitative",
          "title": "Average GPA"
        },
        "tooltip": [
          {
            "field": "semester",
            "type": "quantitative",
            "title": "Semester"
          },
          {
            "field": "avg_gpa",
            "type": "quantitative",
            "title": "Average GPA"
          },
          {
            "field": "student_count",
            "type": "quantitative",
            "title": "Student count"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "stroke": "black"
      },
      "encoding": {
        "x": {
          "field": "semester",
          "type": "quantitative"
        },
        "y": {
          "field": "avg_gpa",
          "type": "quantitative"
        },
        "size": {
          "field": "student_count",
          "type": "quantitative",
          "title": "Student count"
        },
        "tooltip": [
          {
            "field": "semester",
            "type": "quantitative",
            "title": "Semester"
          },
          {
            "field": "avg_gpa",
            "type": "quantitative",
            "title": "Average GPA"
          },
          {
            "field": "student_count",
            "type": "quantitative",
            "title": "Student count"
          }
        ]
      }
    }
  ]
}
