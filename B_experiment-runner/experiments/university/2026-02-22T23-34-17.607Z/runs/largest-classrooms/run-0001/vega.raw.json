{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Top 10 Largest Classrooms by Capacity",
  "width": 700,
  "height": 360,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "y": {
      "field": "room_number",
      "type": "nominal",
      "axis": {
        "title": "Room number"
      },
      "sort": {
        "field": "capacity",
        "order": "descending"
      }
    },
    "x": {
      "field": "capacity",
      "type": "quantitative",
      "axis": {
        "title": "Capacity"
      }
    },
    "color": {
      "field": "building",
      "type": "nominal",
      "legend": {
        "title": "Building"
      }
    },
    "tooltip": [
      {
        "field": "building",
        "type": "nominal",
        "title": "Building"
      },
      {
        "field": "room_number",
        "type": "nominal",
        "title": "Room"
      },
      {
        "field": "capacity",
        "type": "quantitative",
        "title": "Capacity"
      },
      {
        "field": "has_computers",
        "type": "nominal",
        "title": "Has computers"
      },
      {
        "field": "has_projector",
        "type": "nominal",
        "title": "Has projector"
      },
      {
        "field": "id",
        "type": "nominal",
        "title": "ID"
      }
    ]
  }
}
