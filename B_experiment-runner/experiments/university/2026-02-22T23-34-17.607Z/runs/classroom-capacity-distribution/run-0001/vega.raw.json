{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Distribution of Classroom Capacities",
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "capacity",
      "type": "ordinal",
      "title": "Capacity (seats)",
      "sort": "ascending"
    },
    "y": {
      "field": "classroom_count",
      "type": "quantitative",
      "title": "Number of Classrooms"
    },
    "color": {
      "field": "pct_of_total",
      "type": "quantitative",
      "title": "% of Total",
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "capacity",
        "type": "quantitative",
        "title": "Capacity"
      },
      {
        "field": "classroom_count",
        "type": "quantitative",
        "title": "Number of Classrooms"
      },
      {
        "field": "pct_of_total",
        "type": "quantitative",
        "title": "% of Total"
      }
    ]
  }
}
