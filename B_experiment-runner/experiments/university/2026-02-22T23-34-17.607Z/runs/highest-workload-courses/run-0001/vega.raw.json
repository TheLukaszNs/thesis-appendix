{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Top 10 courses by average reported workload (hours)",
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "y": {
      "field": "course_code",
      "type": "nominal",
      "title": "Course code",
      "sort": {
        "field": "average_workload_hours",
        "order": "descending"
      }
    },
    "x": {
      "field": "average_workload_hours",
      "type": "quantitative",
      "title": "Average workload (hours)",
      "axis": {
        "grid": true
      }
    },
    "color": {
      "field": "evaluations_count",
      "type": "quantitative",
      "title": "Evaluations count",
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Course code"
      },
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course name"
      },
      {
        "field": "average_workload_hours",
        "type": "quantitative",
        "title": "Avg workload (hrs)"
      },
      {
        "field": "evaluations_count",
        "type": "quantitative",
        "title": "Evaluations"
      },
      {
        "field": "course_id",
        "type": "nominal",
        "title": "Course ID"
      }
    ]
  },
  "width": 700,
  "height": 400
}
