{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Exam Score by Course",
  "width": 800,
  "height": 420,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "course_code",
      "type": "nominal",
      "axis": {
        "title": "Course Code",
        "labelAngle": -45
      },
      "sort": {
        "field": "avg_exam_score",
        "order": "descending"
      }
    },
    "y": {
      "field": "avg_exam_score",
      "type": "quantitative",
      "axis": {
        "title": "Average Exam Score"
      },
      "scale": {
        "domain": [
          0,
          100
        ]
      }
    },
    "color": {
      "field": "avg_exam_score",
      "type": "quantitative",
      "legend": null
    },
    "tooltip": [
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "avg_exam_score",
        "type": "quantitative",
        "title": "Avg Exam Score",
        "format": ".2f"
      }
    ]
  }
}
