{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Course sections per semester and academic year",
  "width": 640,
  "height": 360,
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3
  },
  "encoding": {
    "x": {
      "field": "academic_year",
      "type": "ordinal",
      "axis": {
        "title": "Academic Year"
      },
      "sort": "ascending"
    },
    "xOffset": {
      "field": "semester_type",
      "type": "nominal"
    },
    "y": {
      "field": "section_count",
      "type": "quantitative",
      "axis": {
        "title": "Number of Sections"
      }
    },
    "color": {
      "field": "semester_type",
      "type": "nominal",
      "legend": {
        "title": "Semester"
      }
    },
    "tooltip": [
      {
        "field": "academic_year",
        "type": "nominal",
        "title": "Academic Year"
      },
      {
        "field": "semester_type",
        "type": "nominal",
        "title": "Semester"
      },
      {
        "field": "section_count",
        "type": "quantitative",
        "title": "Section Count"
      }
    ]
  }
}
