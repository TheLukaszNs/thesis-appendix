{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Overall Course Evaluation by Professor",
  "width": 700,
  "height": {
    "step": 20
  },
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "avg_overall_rating",
      "type": "quantitative",
      "title": "Average Overall Rating",
      "scale": {
        "domain": [
          0,
          5
        ]
      }
    },
    "y": {
      "field": "professor_last_name",
      "type": "nominal",
      "title": "Professor (last name)",
      "sort": {
        "field": "avg_overall_rating",
        "order": "descending"
      }
    },
    "tooltip": [
      {
        "field": "professor_first_name",
        "type": "nominal",
        "title": "First name"
      },
      {
        "field": "professor_last_name",
        "type": "nominal",
        "title": "Last name"
      },
      {
        "field": "avg_overall_rating",
        "type": "quantitative",
        "title": "Avg Rating",
        "format": ".2f"
      }
    ]
  }
}
