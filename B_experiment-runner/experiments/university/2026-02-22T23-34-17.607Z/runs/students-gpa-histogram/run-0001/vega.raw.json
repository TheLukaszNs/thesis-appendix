{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Histogram of student GPAs",
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "gpa_bin",
      "type": "ordinal",
      "axis": {
        "title": "GPA bin"
      },
      "sort": null
    },
    "y": {
      "field": "student_count",
      "type": "quantitative",
      "axis": {
        "title": "Number of students"
      }
    },
    "tooltip": [
      {
        "field": "gpa_bin",
        "type": "nominal",
        "title": "GPA bin"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Students"
      },
      {
        "field": "min_gpa",
        "type": "nominal",
        "title": "Min GPA"
      },
      {
        "field": "max_gpa",
        "type": "nominal",
        "title": "Max GPA"
      }
    ]
  }
}
