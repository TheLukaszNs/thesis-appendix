{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average fill rate of course sections",
  "width": 480,
  "height": 100,
  "layer": [
    {
      "mark": {
        "type": "bar",
        "color": "#4C78A8"
      },
      "encoding": {
        "y": {
          "value": "All sections",
          "type": "nominal"
        },
        "x": {
          "field": "avg_fill_rate",
          "type": "quantitative",
          "axis": {
            "title": "Average fill rate",
            "format": "%"
          },
          "scale": {
            "domain": [
              0,
              1
            ]
          }
        },
        "tooltip": [
          {
            "field": "avg_fill_rate",
            "type": "quantitative",
            "format": ".1%"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 6,
        "dy": 0,
        "fontWeight": "bold"
      },
      "encoding": {
        "y": {
          "value": "All sections",
          "type": "nominal"
        },
        "x": {
          "field": "avg_fill_rate",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              1
            ]
          }
        },
        "text": {
          "field": "avg_fill_rate",
          "type": "quantitative",
          "format": ".1%"
        }
      }
    }
  ]
}
