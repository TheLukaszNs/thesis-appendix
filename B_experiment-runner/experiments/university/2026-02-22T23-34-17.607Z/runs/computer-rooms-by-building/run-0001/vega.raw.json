{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Number of computer labs per building",
  "width": 600,
  "height": 320,
  "mark": {
    "type": "bar",
    "cornerRadius": 3
  },
  "encoding": {
    "x": {
      "field": "building",
      "type": "nominal",
      "axis": {
        "title": "Building"
      },
      "sort": {
        "field": "building",
        "order": "ascending"
      }
    },
    "y": {
      "field": "computer_labs",
      "type": "quantitative",
      "axis": {
        "title": "Computer labs"
      }
    },
    "tooltip": [
      {
        "field": "building",
        "type": "nominal",
        "title": "Building"
      },
      {
        "field": "computer_labs",
        "type": "quantitative",
        "title": "Computer labs"
      }
    ],
    "color": {
      "value": "#4C78A8"
    }
  }
}
