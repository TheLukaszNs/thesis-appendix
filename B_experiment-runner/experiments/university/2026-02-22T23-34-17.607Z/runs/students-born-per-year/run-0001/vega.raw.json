{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Number of students by birth year",
  "width": 700,
  "height": 400,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "birth_year",
      "type": "ordinal",
      "title": "Birth year",
      "sort": "ascending"
    },
    "y": {
      "field": "student_count",
      "type": "quantitative",
      "title": "Number of students"
    },
    "tooltip": [
      {
        "field": "birth_year",
        "type": "ordinal",
        "title": "Birth year"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Students"
      }
    ]
  }
}
