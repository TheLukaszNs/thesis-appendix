{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Exam Score by Grade Value",
  "width": 520,
  "height": 360,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "grade_value",
      "type": "nominal",
      "axis": {
        "title": "Grade Value"
      },
      "sort": "ascending"
    },
    "y": {
      "field": "avg_exam_score",
      "type": "quantitative",
      "axis": {
        "title": "Average Exam Score"
      },
      "scale": {
        "nice": true
      }
    },
    "tooltip": [
      {
        "field": "grade_value",
        "type": "nominal",
        "title": "Grade Value"
      },
      {
        "field": "avg_exam_score",
        "type": "quantitative",
        "title": "Avg Exam Score",
        "format": ".2f"
      }
    ]
  }
}
