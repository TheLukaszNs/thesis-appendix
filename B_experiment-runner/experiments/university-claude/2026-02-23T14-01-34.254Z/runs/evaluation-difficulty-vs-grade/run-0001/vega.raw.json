{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Correlation between Course Difficulty Rating and Average Grade",
  "description": "Scatter plot showing the relationship between average difficulty rating and average grade per course",
  "data": {
    "name": "query_result"
  },
  "mark": {
    "type": "circle",
    "size": 200,
    "opacity": 0.7
  },
  "encoding": {
    "x": {
      "field": "avg_difficulty_rating",
      "type": "quantitative",
      "title": "Average Difficulty Rating",
      "scale": {
        "zero": false
      }
    },
    "y": {
      "field": "avg_grade",
      "type": "quantitative",
      "title": "Average Grade",
      "scale": {
        "zero": false
      }
    },
    "color": {
      "field": "course_code",
      "type": "nominal",
      "title": "Course Code",
      "legend": {
        "labelLimit": 200
      }
    },
    "tooltip": [
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "avg_difficulty_rating",
        "type": "quantitative",
        "title": "Avg Difficulty Rating",
        "format": ".2f"
      },
      {
        "field": "avg_grade",
        "type": "quantitative",
        "title": "Avg Grade",
        "format": ".2f"
      },
      {
        "field": "enrollment_count",
        "type": "quantitative",
        "title": "Enrollments"
      }
    ]
  },
  "width": 600,
  "height": 400
}
