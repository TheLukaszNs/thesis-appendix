{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Student Enrollment per Year",
  "description": "Number of students enrolled at the university by year",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "enrollment_year",
      "type": "ordinal",
      "title": "Enrollment Year",
      "axis": {
        "labelAngle": 0
      }
    },
    "y": {
      "field": "student_count",
      "type": "quantitative",
      "title": "Number of Students"
    },
    "tooltip": [
      {
        "field": "enrollment_year",
        "type": "ordinal",
        "title": "Year"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Students Enrolled"
      }
    ]
  }
}
