{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Student Enrollment by Course",
  "description": "Number of active students enrolled in each course",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "code",
      "type": "nominal",
      "title": "Course Code",
      "axis": {
        "labelAngle": -45,
        "labelAlign": "right"
      }
    },
    "y": {
      "field": "enrollment_count",
      "type": "quantitative",
      "title": "Number of Students"
    },
    "tooltip": [
      {
        "field": "code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "enrollment_count",
        "type": "quantitative",
        "title": "Enrollment Count"
      }
    ],
    "color": {
      "field": "enrollment_count",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      },
      "title": "Number of Students"
    }
  },
  "width": 900,
  "height": 400
}
