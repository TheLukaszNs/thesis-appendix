{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Number of Students by Scholarship Type",
  "description": "Distribution of students across different scholarship types",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "scholarship_type",
      "type": "nominal",
      "title": "Scholarship Type",
      "axis": {
        "labelAngle": 0
      }
    },
    "y": {
      "field": "student_count",
      "type": "quantitative",
      "title": "Number of Students"
    },
    "color": {
      "field": "scholarship_type",
      "type": "nominal",
      "legend": false
    },
    "tooltip": [
      {
        "field": "scholarship_type",
        "type": "nominal",
        "title": "Scholarship Type"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Student Count"
      }
    ]
  }
}
