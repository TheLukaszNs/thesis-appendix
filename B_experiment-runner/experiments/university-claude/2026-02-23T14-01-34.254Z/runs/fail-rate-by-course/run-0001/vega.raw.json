{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Courses by Failure Rate",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "code",
      "type": "nominal",
      "sort": {
        "field": "failure_rate",
        "order": "descending"
      },
      "title": "Course Code"
    },
    "x": {
      "field": "failure_rate",
      "type": "quantitative",
      "title": "Failure Rate"
    },
    "color": {
      "field": "failure_rate",
      "type": "quantitative",
      "scale": {
        "scheme": "reds"
      },
      "title": "Failure Rate"
    },
    "tooltip": [
      {
        "field": "code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "failure_rate",
        "type": "quantitative",
        "title": "Failure Rate",
        "format": ".2%"
      },
      {
        "field": "failed_count",
        "type": "quantitative",
        "title": "Failed Students"
      },
      {
        "field": "total_grades",
        "type": "quantitative",
        "title": "Total Grades"
      }
    ]
  },
  "height": 400,
  "width": 600
}
