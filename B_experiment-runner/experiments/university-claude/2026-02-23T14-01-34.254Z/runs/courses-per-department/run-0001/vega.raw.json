{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Number of Courses by Department",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "labelAngle": -45,
        "labelAlign": "right"
      },
      "title": "Department"
    },
    "y": {
      "field": "course_count",
      "type": "quantitative",
      "title": "Number of Courses"
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "course_count",
        "type": "quantitative",
        "title": "Course Count"
      }
    ]
  }
}
