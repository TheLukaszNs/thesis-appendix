{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Percentage of Students Who Would Recommend Each Course",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "name",
      "type": "nominal",
      "sort": "-x",
      "title": "Course Name"
    },
    "x": {
      "field": "recommend_percentage",
      "type": "quantitative",
      "title": "Recommendation Percentage (%)",
      "scale": {
        "domain": [
          0,
          100
        ]
      }
    },
    "color": {
      "field": "recommend_percentage",
      "type": "quantitative",
      "scale": {
        "scheme": "greens"
      },
      "title": "Recommendation %"
    },
    "tooltip": [
      {
        "field": "code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "recommend_percentage",
        "type": "quantitative",
        "title": "Recommendation %",
        "format": ".2f"
      },
      {
        "field": "recommend_count",
        "type": "quantitative",
        "title": "Recommending Students"
      },
      {
        "field": "total_evaluations",
        "type": "quantitative",
        "title": "Total Evaluations"
      }
    ]
  },
  "width": 600,
  "height": 400
}
