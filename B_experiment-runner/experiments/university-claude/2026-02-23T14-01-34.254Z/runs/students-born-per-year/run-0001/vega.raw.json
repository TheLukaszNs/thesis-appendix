{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Number of Students by Birth Year",
  "description": "Distribution of students across birth years",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "birth_year",
      "type": "ordinal",
      "title": "Birth Year",
      "axis": {
        "labelAngle": -45
      }
    },
    "y": {
      "field": "student_count",
      "type": "quantitative",
      "title": "Number of Students"
    },
    "tooltip": [
      {
        "field": "birth_year",
        "type": "ordinal",
        "title": "Birth Year"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Student Count"
      }
    ]
  }
}
