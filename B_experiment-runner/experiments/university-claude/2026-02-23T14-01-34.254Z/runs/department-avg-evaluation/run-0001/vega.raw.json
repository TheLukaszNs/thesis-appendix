{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Average Overall Evaluation Rating per Department",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "labelAngle": -45,
        "labelAlign": "right"
      },
      "title": "Department"
    },
    "y": {
      "field": "avg_overall_rating",
      "type": "quantitative",
      "title": "Average Overall Rating",
      "scale": {
        "domain": [
          0,
          5
        ]
      }
    },
    "color": {
      "field": "avg_overall_rating",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      },
      "title": "Average Rating"
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "department_code",
        "type": "nominal",
        "title": "Code"
      },
      {
        "field": "avg_overall_rating",
        "type": "quantitative",
        "title": "Average Rating",
        "format": ".2f"
      }
    ]
  },
  "width": 600,
  "height": 400
}
