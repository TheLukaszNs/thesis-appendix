{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Average Fill Rate of Course Sections",
  "data": {
    "name": "query_result"
  },
  "mark": {
    "type": "gauge",
    "innerRadius": 50,
    "cornerRadius": 5,
    "stroke": null
  },
  "encoding": {
    "theta": {
      "field": "average_fill_rate",
      "type": "quantitative",
      "scale": {
        "type": "linear",
        "domain": [
          0,
          1
        ]
      }
    },
    "color": {
      "field": "average_fill_rate",
      "type": "quantitative",
      "scale": {
        "scheme": "reds",
        "domain": [
          0,
          1
        ]
      },
      "legend": null
    }
  },
  "layer": [
    {
      "mark": {
        "type": "text",
        "radiusOffset": 0,
        "fontSize": 32,
        "fontWeight": "bold"
      },
      "encoding": {
        "text": {
          "field": "average_fill_rate",
          "type": "quantitative",
          "format": ".2%"
        }
      }
    }
  ],
  "config": {
    "view": {
      "continuousWidth": 300,
      "continuousHeight": 300
    }
  }
}
