{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Evaluations Submitted per Course",
  "description": "Bar chart showing the number of course evaluations submitted for each course",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "course_code",
      "type": "nominal",
      "title": "Course Code",
      "sort": "-y"
    },
    "y": {
      "field": "evaluation_count",
      "type": "quantitative",
      "title": "Number of Evaluations"
    },
    "tooltip": [
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "evaluation_count",
        "type": "quantitative",
        "title": "Evaluations Submitted"
      }
    ]
  },
  "width": 900,
  "height": 400
}
