{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Average Scholarship Amount per Student by Department",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "avg_scholarship_per_student",
      "type": "quantitative",
      "title": "Average Scholarship per Student (PLN)",
      "axis": {
        "format": "$,.0f"
      }
    },
    "y": {
      "field": "department_name",
      "type": "nominal",
      "title": "Department",
      "sort": "-x"
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "department_code",
        "type": "nominal",
        "title": "Code"
      },
      {
        "field": "avg_scholarship_per_student",
        "type": "quantitative",
        "title": "Avg Scholarship per Student",
        "format": ",.2f"
      }
    ],
    "color": {
      "field": "avg_scholarship_per_student",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      },
      "title": "Average Scholarship (PLN)"
    }
  },
  "width": 600,
  "height": 300
}
