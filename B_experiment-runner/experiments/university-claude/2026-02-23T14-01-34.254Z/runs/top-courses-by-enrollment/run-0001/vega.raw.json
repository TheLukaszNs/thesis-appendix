{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Top 15 Most Popular Courses by Total Enrollment",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "name",
      "type": "nominal",
      "sort": "-x",
      "axis": {
        "label": true,
        "labelFontSize": 11
      }
    },
    "x": {
      "field": "total_enrollment",
      "type": "quantitative",
      "axis": {
        "title": "Total Enrollment"
      }
    },
    "color": {
      "field": "total_enrollment",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      },
      "legend": {
        "title": "Enrollment Count"
      }
    },
    "tooltip": [
      {
        "field": "code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "total_enrollment",
        "type": "quantitative",
        "title": "Total Enrollment"
      }
    ]
  },
  "height": 400,
  "width": 600
}
