{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Students Count by Department and Current Semester",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "semester",
      "type": "ordinal",
      "title": "Current Semester"
    },
    "y": {
      "field": "student_count",
      "type": "quantitative",
      "title": "Student Count"
    },
    "color": {
      "field": "department",
      "type": "nominal",
      "title": "Department",
      "scale": {
        "scheme": "category10"
      }
    },
    "tooltip": [
      {
        "field": "department",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "semester",
        "type": "ordinal",
        "title": "Semester"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Student Count"
      }
    ]
  },
  "width": 800,
  "height": 400
}
