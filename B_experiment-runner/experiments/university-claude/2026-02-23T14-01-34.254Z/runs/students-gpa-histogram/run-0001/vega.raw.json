{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Distribution of Student GPAs",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "gpa_range",
      "type": "nominal",
      "title": "GPA Range",
      "sort": [
        "0.0-1.0",
        "1.0-2.0",
        "2.0-3.0",
        "3.0-4.0",
        "4.0+"
      ]
    },
    "y": {
      "field": "student_count",
      "type": "quantitative",
      "title": "Number of Students"
    },
    "tooltip": [
      {
        "field": "gpa_range",
        "type": "nominal",
        "title": "GPA Range"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Student Count"
      }
    ]
  }
}
