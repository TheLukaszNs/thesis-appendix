{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Total Scholarship Amount by Type",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "scholarship_type",
      "type": "nominal",
      "title": "Scholarship Type"
    },
    "y": {
      "field": "total_amount",
      "type": "quantitative",
      "title": "Total Amount ($)"
    },
    "tooltip": [
      {
        "field": "scholarship_type",
        "type": "nominal",
        "title": "Scholarship Type"
      },
      {
        "field": "total_amount",
        "type": "quantitative",
        "title": "Total Amount",
        "format": "$,.2f"
      }
    ]
  }
}
