{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Course Sections by Building",
  "description": "Number of course sections taught in each building",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "building",
      "type": "nominal",
      "title": "Building",
      "sort": "ascending"
    },
    "y": {
      "field": "section_count",
      "type": "quantitative",
      "title": "Number of Sections"
    },
    "tooltip": [
      {
        "field": "building",
        "type": "nominal",
        "title": "Building"
      },
      {
        "field": "section_count",
        "type": "quantitative",
        "title": "Section Count"
      }
    ]
  }
}
