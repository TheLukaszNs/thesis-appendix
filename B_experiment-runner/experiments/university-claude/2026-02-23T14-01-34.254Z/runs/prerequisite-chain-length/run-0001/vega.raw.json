{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Courses by Number of Dependent Courses (Prerequisites)",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "name",
      "type": "nominal",
      "sort": "-x",
      "title": "Course Name"
    },
    "x": {
      "field": "num_courses_requiring_this_prerequisite",
      "type": "quantitative",
      "title": "Number of Courses Requiring This as Prerequisite"
    },
    "color": {
      "field": "num_courses_requiring_this_prerequisite",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      },
      "title": "Count"
    },
    "tooltip": [
      {
        "field": "code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "num_courses_requiring_this_prerequisite",
        "type": "quantitative",
        "title": "Courses Requiring This"
      }
    ]
  },
  "width": 600,
  "height": 400
}
