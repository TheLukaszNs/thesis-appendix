{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Number of Professors Hired Per Year",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "hire_year",
      "type": "ordinal",
      "title": "Year",
      "axis": {
        "labelAngle": -45
      }
    },
    "y": {
      "field": "num_professors_hired",
      "type": "quantitative",
      "title": "Number of Professors Hired"
    },
    "tooltip": [
      {
        "field": "hire_year",
        "type": "ordinal",
        "title": "Year"
      },
      {
        "field": "num_professors_hired",
        "type": "quantitative",
        "title": "Professors Hired"
      }
    ]
  }
}
