{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Average Grade Given by Each Professor",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "professor_name",
      "type": "nominal",
      "axis": {
        "labelAngle": -45,
        "labelAlign": "right"
      },
      "title": "Professor Name"
    },
    "y": {
      "field": "average_grade",
      "type": "quantitative",
      "title": "Average Grade"
    },
    "tooltip": [
      {
        "field": "professor_name",
        "type": "nominal",
        "title": "Professor"
      },
      {
        "field": "average_grade",
        "type": "quantitative",
        "title": "Average Grade",
        "format": ".2f"
      }
    ]
  },
  "width": 900,
  "height": 400
}
