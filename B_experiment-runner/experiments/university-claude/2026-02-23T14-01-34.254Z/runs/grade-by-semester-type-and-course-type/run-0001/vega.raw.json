{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Average Grades by Course Type: Winter vs Summer Semesters",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "course_type",
      "type": "nominal",
      "title": "Course Type",
      "axis": {
        "labelAngle": 0
      }
    },
    "y": {
      "field": "avg_grade",
      "type": "quantitative",
      "title": "Average Grade",
      "scale": {
        "domain": [
          0,
          4
        ]
      }
    },
    "color": {
      "field": "semester_type",
      "type": "nominal",
      "title": "Semester Type",
      "scale": {
        "domain": [
          "WINTER",
          "SUMMER"
        ],
        "range": [
          "#1f77b4",
          "#ff7f0e"
        ]
      }
    },
    "xOffset": {
      "field": "semester_type"
    },
    "tooltip": [
      {
        "field": "semester_type",
        "type": "nominal",
        "title": "Semester"
      },
      {
        "field": "course_type",
        "type": "nominal",
        "title": "Course Type"
      },
      {
        "field": "avg_grade",
        "type": "quantitative",
        "title": "Average Grade",
        "format": ".2f"
      },
      {
        "field": "grade_count",
        "type": "quantitative",
        "title": "Grade Count"
      }
    ]
  }
}
