{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Distribution of Final Grades Across All Courses",
  "data": {
    "name": "query_result"
  },
  "width": 900,
  "height": 500,
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "final_grade",
      "type": "ordinal",
      "title": "Final Grade",
      "sort": "ascending"
    },
    "y": {
      "field": "student_count",
      "type": "quantitative",
      "title": "Number of Students"
    },
    "color": {
      "field": "final_grade",
      "type": "ordinal",
      "scale": {
        "scheme": "viridis"
      },
      "legend": false
    },
    "tooltip": [
      {
        "field": "final_grade",
        "type": "ordinal",
        "title": "Grade"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Student Count"
      }
    ]
  }
}
