{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Average Reported Workload Hours by Course",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "course_code",
      "type": "nominal",
      "title": "Course Code",
      "sort": "-y"
    },
    "y": {
      "field": "average_workload_hours",
      "type": "quantitative",
      "title": "Average Workload Hours"
    },
    "tooltip": [
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "average_workload_hours",
        "type": "quantitative",
        "title": "Average Workload Hours",
        "format": ".2f"
      }
    ]
  },
  "width": 800,
  "height": 400
}
