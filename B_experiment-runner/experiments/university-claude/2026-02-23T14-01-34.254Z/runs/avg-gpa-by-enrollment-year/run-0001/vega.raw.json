{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Average GPA by Year of Enrollment",
  "description": "Trend of average GPA across enrollment years with student count",
  "data": {
    "name": "query_result"
  },
  "mark": {
    "type": "line",
    "point": true,
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "enrollment_year",
      "type": "ordinal",
      "title": "Enrollment Year",
      "axis": {
        "labelAngle": 0
      }
    },
    "y": {
      "field": "average_gpa",
      "type": "quantitative",
      "title": "Average GPA",
      "scale": {
        "zero": false
      }
    },
    "tooltip": [
      {
        "field": "enrollment_year",
        "type": "ordinal",
        "title": "Year"
      },
      {
        "field": "average_gpa",
        "type": "quantitative",
        "title": "Average GPA",
        "format": ".2f"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Student Count"
      }
    ]
  }
}
