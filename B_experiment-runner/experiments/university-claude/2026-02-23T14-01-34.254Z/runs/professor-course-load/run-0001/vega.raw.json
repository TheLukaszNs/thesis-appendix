{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Course Sections Taught by Professor",
  "description": "Bar chart showing the number of course sections each professor teaches",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "section_count",
      "type": "quantitative",
      "title": "Number of Sections",
      "axis": {
        "labelAngle": 0
      }
    },
    "y": {
      "field": "last_name",
      "type": "nominal",
      "title": "Professor",
      "sort": "-x"
    },
    "tooltip": [
      {
        "field": "first_name",
        "type": "nominal",
        "title": "First Name"
      },
      {
        "field": "last_name",
        "type": "nominal",
        "title": "Last Name"
      },
      {
        "field": "section_count",
        "type": "quantitative",
        "title": "Sections Taught"
      }
    ],
    "color": {
      "field": "section_count",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      },
      "title": "Number of Sections"
    }
  },
  "height": 600,
  "width": 400
}
