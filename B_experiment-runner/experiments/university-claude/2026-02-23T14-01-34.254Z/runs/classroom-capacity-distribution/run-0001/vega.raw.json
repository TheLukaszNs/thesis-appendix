{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Distribution of Classroom Capacities",
  "description": "Bar chart showing the count of classrooms by capacity",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "capacity",
      "type": "ordinal",
      "title": "Classroom Capacity",
      "axis": {
        "labelAngle": 0
      }
    },
    "y": {
      "field": "classroom_count",
      "type": "quantitative",
      "title": "Number of Classrooms"
    },
    "tooltip": [
      {
        "field": "capacity",
        "type": "ordinal",
        "title": "Capacity"
      },
      {
        "field": "classroom_count",
        "type": "quantitative",
        "title": "Classroom Count"
      }
    ]
  }
}
