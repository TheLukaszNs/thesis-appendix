{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Age Distribution of Students",
  "description": "Distribution of students by age",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "age",
      "type": "ordinal",
      "title": "Age (years)",
      "axis": {
        "labelAngle": 0
      }
    },
    "y": {
      "field": "student_count",
      "type": "quantitative",
      "title": "Number of Students"
    },
    "tooltip": [
      {
        "field": "age",
        "type": "ordinal",
        "title": "Age"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Student Count"
      }
    ]
  },
  "width": 600,
  "height": 400
}
