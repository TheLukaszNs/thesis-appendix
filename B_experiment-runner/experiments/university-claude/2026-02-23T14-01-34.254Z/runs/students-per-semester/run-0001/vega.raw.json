{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Number of Students by Semester",
  "description": "Bar chart showing student count distribution across semesters",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "current_semester",
      "type": "ordinal",
      "title": "Semester",
      "axis": {
        "labelAngle": 0
      }
    },
    "y": {
      "field": "student_count",
      "type": "quantitative",
      "title": "Number of Students"
    },
    "tooltip": [
      {
        "field": "current_semester",
        "type": "ordinal",
        "title": "Semester"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Student Count"
      }
    ]
  }
}
