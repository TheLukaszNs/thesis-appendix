{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Average Content Rating vs Professor Rating by Professor",
  "data": {
    "name": "query_result"
  },
  "width": 800,
  "height": 500,
  "mark": "circle",
  "encoding": {
    "x": {
      "field": "avg_content_rating",
      "type": "quantitative",
      "title": "Average Content Rating",
      "scale": {
        "domain": [
          0,
          5
        ]
      }
    },
    "y": {
      "field": "avg_professor_rating",
      "type": "quantitative",
      "title": "Average Professor Rating",
      "scale": {
        "domain": [
          0,
          5
        ]
      }
    },
    "size": {
      "field": "evaluation_count",
      "type": "quantitative",
      "title": "Number of Evaluations",
      "scale": {
        "range": [
          100,
          400
        ]
      }
    },
    "color": {
      "field": "evaluation_count",
      "type": "quantitative",
      "title": "Number of Evaluations",
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "first_name",
        "type": "nominal",
        "title": "First Name"
      },
      {
        "field": "last_name",
        "type": "nominal",
        "title": "Last Name"
      },
      {
        "field": "avg_content_rating",
        "type": "quantitative",
        "title": "Avg Content Rating",
        "format": ".2f"
      },
      {
        "field": "avg_professor_rating",
        "type": "quantitative",
        "title": "Avg Professor Rating",
        "format": ".2f"
      },
      {
        "field": "evaluation_count",
        "type": "quantitative",
        "title": "Evaluation Count"
      }
    ]
  }
}
