{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Mandatory vs Optional Prerequisites",
  "data": {
    "name": "query_result",
    "values": [
      {
        "is_mandatory": true,
        "count": "23"
      },
      {
        "is_mandatory": false,
        "count": "15"
      }
    ]
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "is_mandatory",
      "type": "nominal",
      "axis": {
        "title": "Prerequisite Type",
        "labelExpr": "datum.value ? 'Mandatory' : 'Optional'"
      }
    },
    "y": {
      "field": "count",
      "type": "quantitative",
      "axis": {
        "title": "Number of Prerequisites"
      }
    },
    "color": {
      "field": "is_mandatory",
      "type": "nominal",
      "scale": {
        "domain": [
          true,
          false
        ],
        "range": [
          "#e74c3c",
          "#3498db"
        ]
      },
      "legend": null
    },
    "tooltip": [
      {
        "field": "is_mandatory",
        "type": "nominal",
        "title": "Type",
        "format": "",
        "formatType": "json"
      },
      {
        "field": "count",
        "type": "quantitative",
        "title": "Count"
      }
    ]
  },
  "datasets": {
    "query_result": [
      {
        "is_mandatory": true,
        "count": "23"
      },
      {
        "is_mandatory": false,
        "count": "15"
      }
    ]
  }
}
