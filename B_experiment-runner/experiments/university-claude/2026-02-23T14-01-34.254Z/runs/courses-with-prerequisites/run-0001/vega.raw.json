{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Courses by Number of Prerequisites",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "name",
      "type": "nominal",
      "sort": {
        "field": "prerequisite_count",
        "order": "descending"
      },
      "title": "Course Name"
    },
    "x": {
      "field": "prerequisite_count",
      "type": "quantitative",
      "title": "Number of Prerequisites"
    },
    "color": {
      "field": "prerequisite_count",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      },
      "title": "Prerequisites"
    },
    "tooltip": [
      {
        "field": "code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "prerequisite_count",
        "type": "quantitative",
        "title": "Number of Prerequisites"
      }
    ]
  },
  "width": 600,
  "height": 400
}
