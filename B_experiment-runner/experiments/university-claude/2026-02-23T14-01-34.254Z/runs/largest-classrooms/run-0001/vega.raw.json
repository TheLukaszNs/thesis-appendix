{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "10 Largest Classrooms by Capacity",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "room_label",
      "type": "nominal",
      "sort": "-x",
      "title": "Classroom"
    },
    "x": {
      "field": "capacity",
      "type": "quantitative",
      "title": "Capacity"
    },
    "tooltip": [
      {
        "field": "building",
        "type": "nominal",
        "title": "Building"
      },
      {
        "field": "room_number",
        "type": "nominal",
        "title": "Room Number"
      },
      {
        "field": "capacity",
        "type": "quantitative",
        "title": "Capacity"
      }
    ]
  },
  "transform": [
    {
      "calculate": "datum.building + ' - Room ' + datum.room_number",
      "as": "room_label"
    }
  ]
}
