{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Enrollments per Semester and Academic Year",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "academic_year",
      "type": "nominal",
      "title": "Academic Year",
      "axis": {
        "labelAngle": -45
      }
    },
    "y": {
      "field": "enrollment_count",
      "type": "quantitative",
      "title": "Number of Enrollments"
    },
    "color": {
      "field": "semester_type",
      "type": "nominal",
      "title": "Semester Type",
      "scale": {
        "scheme": "category10"
      }
    },
    "tooltip": [
      {
        "field": "academic_year",
        "type": "nominal",
        "title": "Academic Year"
      },
      {
        "field": "semester_type",
        "type": "nominal",
        "title": "Semester Type"
      },
      {
        "field": "enrollment_count",
        "type": "quantitative",
        "title": "Enrollments"
      }
    ]
  }
}
