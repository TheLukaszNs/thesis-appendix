{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Professors Ranked by Average Overall Grade (Strictest Graders First)",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "first_name",
      "type": "nominal",
      "sort": {
        "field": "avg_overall_grade",
        "order": "ascending"
      },
      "title": "Professor"
    },
    "x": {
      "field": "avg_overall_grade",
      "type": "quantitative",
      "title": "Average Overall Grade"
    },
    "color": {
      "field": "avg_overall_grade",
      "type": "quantitative",
      "scale": {
        "scheme": "reds"
      },
      "title": "Avg Grade"
    },
    "tooltip": [
      {
        "field": "first_name",
        "type": "nominal",
        "title": "First Name"
      },
      {
        "field": "last_name",
        "type": "nominal",
        "title": "Last Name"
      },
      {
        "field": "total_grades",
        "type": "quantitative",
        "title": "Total Grades Given"
      },
      {
        "field": "avg_exam_score",
        "type": "quantitative",
        "title": "Avg Exam Score",
        "format": ".2f"
      },
      {
        "field": "avg_project_score",
        "type": "quantitative",
        "title": "Avg Project Score",
        "format": ".2f"
      },
      {
        "field": "avg_attendance_score",
        "type": "quantitative",
        "title": "Avg Attendance Score",
        "format": ".2f"
      },
      {
        "field": "avg_overall_grade",
        "type": "quantitative",
        "title": "Avg Overall Grade",
        "format": ".2f"
      }
    ]
  },
  "width": 600,
  "height": 500
}
