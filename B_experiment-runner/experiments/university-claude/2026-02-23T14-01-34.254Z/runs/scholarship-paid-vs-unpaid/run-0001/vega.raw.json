{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Scholarships: Paid vs Not Yet Paid",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "payment_status",
      "type": "nominal",
      "title": "Payment Status"
    },
    "y": {
      "field": "scholarship_count",
      "type": "quantitative",
      "title": "Number of Scholarships"
    },
    "color": {
      "field": "payment_status",
      "type": "nominal",
      "scale": {
        "domain": [
          "Paid",
          "Not Yet Paid"
        ],
        "range": [
          "#2ecc71",
          "#e74c3c"
        ]
      },
      "legend": null
    },
    "tooltip": [
      {
        "field": "payment_status",
        "type": "nominal",
        "title": "Status"
      },
      {
        "field": "scholarship_count",
        "type": "quantitative",
        "title": "Count"
      }
    ]
  }
}
