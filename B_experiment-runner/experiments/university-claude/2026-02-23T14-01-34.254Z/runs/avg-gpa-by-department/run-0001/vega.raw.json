{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Average GPA per Department",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "department",
      "type": "nominal",
      "axis": {
        "labelAngle": -45,
        "labelAlign": "right"
      },
      "title": "Department"
    },
    "y": {
      "field": "average_gpa",
      "type": "quantitative",
      "title": "Average GPA",
      "scale": {
        "domain": [
          3.9,
          4
        ]
      }
    },
    "tooltip": [
      {
        "field": "department",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "average_gpa",
        "type": "quantitative",
        "title": "Average GPA",
        "format": ".4f"
      }
    ]
  }
}
