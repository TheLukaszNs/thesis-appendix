{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Total Credits Offered by Department",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "name",
      "type": "nominal",
      "axis": {
        "labelAngle": -45,
        "labelAlign": "right"
      },
      "title": "Department"
    },
    "y": {
      "field": "total_credits",
      "type": "quantitative",
      "title": "Total Credits"
    },
    "tooltip": [
      {
        "field": "code",
        "type": "nominal",
        "title": "Department Code"
      },
      {
        "field": "name",
        "type": "nominal",
        "title": "Department Name"
      },
      {
        "field": "total_credits",
        "type": "quantitative",
        "title": "Total Credits"
      }
    ],
    "color": {
      "field": "total_credits",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      },
      "title": "Total Credits"
    }
  },
  "width": 600,
  "height": 400
}
