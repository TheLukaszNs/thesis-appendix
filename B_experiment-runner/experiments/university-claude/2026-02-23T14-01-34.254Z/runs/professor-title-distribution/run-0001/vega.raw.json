{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Distribution of Academic Titles Among Professors",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "professor_count",
      "type": "quantitative",
      "title": "Number of Professors",
      "axis": {
        "labelAngle": 0
      }
    },
    "y": {
      "field": "academic_title",
      "type": "nominal",
      "title": "Academic Title",
      "sort": "-x"
    },
    "tooltip": [
      {
        "field": "academic_title",
        "type": "nominal",
        "title": "Academic Title"
      },
      {
        "field": "professor_count",
        "type": "quantitative",
        "title": "Count"
      }
    ]
  },
  "width": 600,
  "height": 400
}
