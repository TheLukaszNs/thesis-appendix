{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Departments by Building",
  "description": "Overview of which departments are located in which buildings",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "building",
      "type": "nominal",
      "title": "Building",
      "sort": "ascending"
    },
    "x": {
      "aggregate": "count",
      "type": "quantitative",
      "title": "Number of Departments"
    },
    "color": {
      "field": "building",
      "type": "nominal",
      "legend": false
    },
    "tooltip": [
      {
        "field": "building",
        "type": "nominal",
        "title": "Building"
      },
      {
        "aggregate": "count",
        "type": "quantitative",
        "title": "Department Count"
      }
    ]
  }
}
