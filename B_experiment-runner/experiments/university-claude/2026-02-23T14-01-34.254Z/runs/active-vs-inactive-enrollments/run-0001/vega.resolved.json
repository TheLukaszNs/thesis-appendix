{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Active to Inactive Enrollments Ratio",
  "data": {
    "name": "query_result",
    "values": [
      {
        "active_count": "57",
        "inactive_count": "76",
        "active_to_inactive_ratio": "0.75"
      }
    ]
  },
  "transform": [
    {
      "calculate": "'Active: ' + datum.active_count + ' | Inactive: ' + datum.inactive_count + ' | Ratio: ' + datum.active_to_inactive_ratio + ':1'",
      "as": "tooltip_text"
    }
  ],
  "mark": {
    "type": "text",
    "fontSize": 24,
    "fontWeight": "bold",
    "align": "center"
  },
  "encoding": {
    "text": {
      "field": "active_to_inactive_ratio",
      "type": "nominal"
    },
    "tooltip": [
      {
        "field": "active_count",
        "type": "quantitative",
        "title": "Active Enrollments"
      },
      {
        "field": "inactive_count",
        "type": "quantitative",
        "title": "Inactive Enrollments"
      },
      {
        "field": "active_to_inactive_ratio",
        "type": "quantitative",
        "title": "Ratio (Active:Inactive)"
      }
    ]
  },
  "datasets": {
    "query_result": [
      {
        "active_count": "57",
        "inactive_count": "76",
        "active_to_inactive_ratio": "0.75"
      }
    ]
  }
}
