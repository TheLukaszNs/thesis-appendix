{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Scholarship Counts by Type and Semester",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "semester_type",
      "type": "nominal",
      "title": "Semester Type",
      "axis": {
        "labelAngle": 0
      }
    },
    "y": {
      "field": "scholarship_count",
      "type": "quantitative",
      "title": "Scholarship Count"
    },
    "color": {
      "field": "scholarship_type",
      "type": "nominal",
      "title": "Scholarship Type",
      "scale": {
        "scheme": "category10"
      }
    },
    "tooltip": [
      {
        "field": "semester_type",
        "type": "nominal",
        "title": "Semester Type"
      },
      {
        "field": "scholarship_type",
        "type": "nominal",
        "title": "Scholarship Type"
      },
      {
        "field": "scholarship_count",
        "type": "quantitative",
        "title": "Count"
      }
    ]
  }
}
