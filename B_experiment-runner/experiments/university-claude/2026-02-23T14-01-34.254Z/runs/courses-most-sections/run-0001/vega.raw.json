{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Courses by Number of Sections Offered",
  "description": "Bar chart showing which courses have been offered in the most sections overall",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "course_name",
      "type": "nominal",
      "sort": "-x",
      "title": "Course Name"
    },
    "x": {
      "field": "section_count",
      "type": "quantitative",
      "title": "Number of Sections"
    },
    "tooltip": [
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course"
      },
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "section_count",
        "type": "quantitative",
        "title": "Sections Offered"
      }
    ],
    "color": {
      "field": "section_count",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      },
      "title": "Number of Sections"
    }
  },
  "height": 400,
  "width": 600
}
