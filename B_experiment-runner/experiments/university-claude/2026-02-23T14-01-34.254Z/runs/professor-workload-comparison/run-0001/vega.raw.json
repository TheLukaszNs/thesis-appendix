{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Number of Distinct Courses Taught by Each Professor",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "first_name",
      "type": "nominal",
      "sort": "-x",
      "title": "Professor Name",
      "axis": {
        "labelExpr": "datum.value + ' ' + data('query_result')[indexof(data('query_result'), datum)].last_name"
      }
    },
    "x": {
      "field": "distinct_courses_taught",
      "type": "quantitative",
      "title": "Number of Distinct Courses"
    },
    "tooltip": [
      {
        "field": "first_name",
        "type": "nominal",
        "title": "First Name"
      },
      {
        "field": "last_name",
        "type": "nominal",
        "title": "Last Name"
      },
      {
        "field": "distinct_courses_taught",
        "type": "quantitative",
        "title": "Distinct Courses Taught"
      }
    ],
    "color": {
      "field": "distinct_courses_taught",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      },
      "title": "Number of Courses"
    }
  },
  "width": 600,
  "height": 800
}
