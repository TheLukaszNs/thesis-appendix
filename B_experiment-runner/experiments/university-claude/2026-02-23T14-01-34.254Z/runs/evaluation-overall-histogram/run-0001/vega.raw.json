{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Distribution of Overall Course Evaluation Ratings",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "overall_rating",
      "type": "ordinal",
      "title": "Rating (1-5)",
      "axis": {
        "labelAngle": 0
      }
    },
    "y": {
      "field": "count",
      "type": "quantitative",
      "title": "Number of Evaluations"
    },
    "color": {
      "field": "overall_rating",
      "type": "ordinal",
      "scale": {
        "scheme": "blues"
      },
      "legend": false
    },
    "tooltip": [
      {
        "field": "overall_rating",
        "type": "ordinal",
        "title": "Rating"
      },
      {
        "field": "count",
        "type": "quantitative",
        "title": "Count"
      },
      {
        "field": "percentage",
        "type": "quantitative",
        "title": "Percentage (%)"
      }
    ]
  }
}
