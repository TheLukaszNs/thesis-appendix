{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Average Attendance Score by Course",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "code",
      "type": "nominal",
      "title": "Course Code",
      "axis": {
        "labelAngle": -45
      }
    },
    "y": {
      "field": "average_attendance_score",
      "type": "quantitative",
      "title": "Average Attendance Score"
    },
    "tooltip": [
      {
        "field": "code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "average_attendance_score",
        "type": "quantitative",
        "title": "Average Attendance Score",
        "format": ".2f"
      }
    ]
  }
}
