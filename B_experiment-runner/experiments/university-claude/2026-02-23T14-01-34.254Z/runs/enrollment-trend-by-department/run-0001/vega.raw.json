{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Enrollment Trends by Department Over Academic Years",
  "description": "Line chart showing enrollment count trends across departments and academic years",
  "data": {
    "name": "query_result"
  },
  "mark": {
    "type": "line",
    "point": true,
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "academic_year",
      "type": "nominal",
      "title": "Academic Year",
      "axis": {
        "labelAngle": -45
      }
    },
    "y": {
      "field": "enrollment_count",
      "type": "quantitative",
      "title": "Enrollment Count"
    },
    "color": {
      "field": "department_name",
      "type": "nominal",
      "title": "Department"
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "academic_year",
        "type": "nominal",
        "title": "Academic Year"
      },
      {
        "field": "enrollment_count",
        "type": "quantitative",
        "title": "Enrollment Count"
      }
    ]
  },
  "width": 800,
  "height": 400
}
