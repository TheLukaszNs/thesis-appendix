{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Average Exam, Project, and Attendance Scores by Grade Value",
  "data": {
    "name": "query_result"
  },
  "width": 600,
  "height": 400,
  "mark": "line",
  "encoding": {
    "x": {
      "field": "grade_value",
      "type": "nominal",
      "title": "Grade Value",
      "axis": {
        "labelAngle": 0
      }
    },
    "y": {
      "type": "quantitative",
      "title": "Average Score",
      "scale": {
        "zero": false
      }
    },
    "color": {
      "field": "score_type",
      "type": "nominal",
      "title": "Score Type",
      "scale": {
        "scheme": "category10"
      }
    },
    "tooltip": [
      {
        "field": "grade_value",
        "type": "nominal",
        "title": "Grade Value"
      },
      {
        "field": "score_type",
        "type": "nominal",
        "title": "Score Type"
      },
      {
        "field": "score",
        "type": "quantitative",
        "title": "Average Score",
        "format": ".2f"
      }
    ]
  },
  "transform": [
    {
      "fold": [
        "avg_exam_score",
        "avg_project_score",
        "avg_attendance_score"
      ],
      "as": [
        "score_type",
        "score"
      ]
    },
    {
      "calculate": "datum.score_type === 'avg_exam_score' ? 'Exam' : datum.score_type === 'avg_project_score' ? 'Project' : 'Attendance'",
      "as": "score_type"
    }
  ]
}
