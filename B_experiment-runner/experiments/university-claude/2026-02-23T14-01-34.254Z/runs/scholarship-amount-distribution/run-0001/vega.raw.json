{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Distribution of Individual Scholarship Amounts",
  "description": "Shows the frequency and percentage distribution of scholarship amounts",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "amount",
      "type": "nominal",
      "title": "Scholarship Amount",
      "axis": {
        "labelAngle": -45
      }
    },
    "y": {
      "field": "count",
      "type": "quantitative",
      "title": "Number of Scholarships"
    },
    "color": {
      "field": "percentage",
      "type": "quantitative",
      "title": "Percentage (%)",
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "amount",
        "type": "nominal",
        "title": "Amount"
      },
      {
        "field": "count",
        "type": "quantitative",
        "title": "Count"
      },
      {
        "field": "percentage",
        "type": "quantitative",
        "title": "Percentage",
        "format": ".2f"
      }
    ]
  }
}
