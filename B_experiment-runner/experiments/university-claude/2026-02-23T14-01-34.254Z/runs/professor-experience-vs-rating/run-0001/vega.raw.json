{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Professor Hire Date vs. Evaluation Rating",
  "description": "Relationship between professor hire date and average evaluation rating",
  "data": {
    "name": "query_result"
  },
  "transform": [
    {
      "calculate": "year(datum.hire_date)",
      "as": "hire_year"
    }
  ],
  "mark": {
    "type": "circle",
    "opacity": 0.7,
    "size": 200
  },
  "encoding": {
    "x": {
      "field": "hire_date",
      "type": "temporal",
      "title": "Hire Date",
      "axis": {
        "format": "%Y",
        "labelAngle": -45
      }
    },
    "y": {
      "field": "avg_professor_rating",
      "type": "quantitative",
      "title": "Average Professor Rating",
      "scale": {
        "domain": [
          0,
          5
        ]
      }
    },
    "size": {
      "field": "evaluation_count",
      "type": "quantitative",
      "title": "Number of Evaluations",
      "scale": {
        "range": [
          100,
          400
        ]
      }
    },
    "color": {
      "field": "avg_professor_rating",
      "type": "quantitative",
      "title": "Avg Rating",
      "scale": {
        "scheme": "viridis"
      }
    },
    "tooltip": [
      {
        "field": "first_name",
        "type": "nominal",
        "title": "First Name"
      },
      {
        "field": "last_name",
        "type": "nominal",
        "title": "Last Name"
      },
      {
        "field": "hire_date",
        "type": "temporal",
        "title": "Hire Date",
        "format": "%Y-%m-%d"
      },
      {
        "field": "avg_professor_rating",
        "type": "quantitative",
        "title": "Avg Professor Rating",
        "format": ".2f"
      },
      {
        "field": "evaluation_count",
        "type": "quantitative",
        "title": "Evaluation Count"
      },
      {
        "field": "avg_overall_rating",
        "type": "quantitative",
        "title": "Avg Overall Rating",
        "format": ".2f"
      }
    ]
  },
  "width": 800,
  "height": 500
}
