{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Distribution of Credit Values for Courses by Department",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "department_code",
      "type": "nominal",
      "title": "Department",
      "axis": {
        "labelAngle": -45
      }
    },
    "y": {
      "field": "course_count",
      "type": "quantitative",
      "title": "Number of Courses"
    },
    "color": {
      "field": "credits",
      "type": "ordinal",
      "title": "Credits",
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "department_code",
        "type": "nominal",
        "title": "Code"
      },
      {
        "field": "credits",
        "type": "quantitative",
        "title": "Credits"
      },
      {
        "field": "course_count",
        "type": "quantitative",
        "title": "Course Count"
      }
    ]
  }
}
