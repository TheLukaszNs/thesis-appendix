{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Top 10 Students with Highest GPA",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "full_name",
      "type": "nominal",
      "sort": "-x",
      "title": "Student Name"
    },
    "x": {
      "field": "calculated_gpa",
      "type": "quantitative",
      "title": "GPA",
      "scale": {
        "domain": [
          0,
          5
        ]
      }
    },
    "color": {
      "field": "calculated_gpa",
      "type": "quantitative",
      "scale": {
        "scheme": "greens"
      },
      "title": "GPA"
    },
    "tooltip": [
      {
        "field": "first_name",
        "type": "nominal",
        "title": "First Name"
      },
      {
        "field": "last_name",
        "type": "nominal",
        "title": "Last Name"
      },
      {
        "field": "index_number",
        "type": "nominal",
        "title": "Index Number"
      },
      {
        "field": "calculated_gpa",
        "type": "quantitative",
        "title": "GPA",
        "format": ".2f"
      }
    ]
  },
  "transform": [
    {
      "calculate": "datum.first_name + ' ' + datum.last_name",
      "as": "full_name"
    }
  ],
  "width": 600,
  "height": 400
}
