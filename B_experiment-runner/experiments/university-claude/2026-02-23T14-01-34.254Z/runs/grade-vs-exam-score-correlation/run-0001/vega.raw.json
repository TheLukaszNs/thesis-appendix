{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Average Exam Score by Grade Value",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "grade_value",
      "type": "nominal",
      "title": "Grade Value"
    },
    "y": {
      "field": "average_exam_score",
      "type": "quantitative",
      "title": "Average Exam Score"
    },
    "tooltip": [
      {
        "field": "grade_value",
        "type": "nominal",
        "title": "Grade Value"
      },
      {
        "field": "average_exam_score",
        "type": "quantitative",
        "title": "Average Exam Score",
        "format": ".2f"
      }
    ]
  }
}
