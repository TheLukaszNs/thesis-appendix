{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Relationship Between Course Credits and Average Grade",
  "description": "Scatter plot showing the correlation between course credits and average exam grades",
  "data": {
    "name": "query_result"
  },
  "mark": {
    "type": "circle",
    "size": 200,
    "opacity": 0.7
  },
  "encoding": {
    "x": {
      "field": "credits",
      "type": "quantitative",
      "title": "Course Credits",
      "axis": {
        "labelExpr": "datum.value"
      }
    },
    "y": {
      "field": "avg_grade",
      "type": "quantitative",
      "title": "Average Grade (Exam Score)"
    },
    "size": {
      "field": "enrollment_count",
      "type": "quantitative",
      "title": "Number of Enrollments",
      "scale": {
        "range": [
          100,
          400
        ]
      }
    },
    "color": {
      "field": "credits",
      "type": "quantitative",
      "scale": {
        "scheme": "viridis"
      },
      "title": "Course Credits"
    },
    "tooltip": [
      {
        "field": "credits",
        "type": "quantitative",
        "title": "Credits"
      },
      {
        "field": "avg_grade",
        "type": "quantitative",
        "title": "Average Grade",
        "format": ".2f"
      },
      {
        "field": "enrollment_count",
        "type": "quantitative",
        "title": "Enrollments"
      }
    ]
  }
}
