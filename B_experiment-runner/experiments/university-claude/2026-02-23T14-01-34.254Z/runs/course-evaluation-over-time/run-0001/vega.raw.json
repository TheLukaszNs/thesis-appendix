{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Average Overall Evaluation Rating by Academic Year",
  "data": {
    "name": "query_result"
  },
  "mark": {
    "type": "line",
    "point": true,
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "academic_year",
      "type": "nominal",
      "title": "Academic Year",
      "axis": {
        "labelAngle": -45
      }
    },
    "y": {
      "field": "avg_overall_rating",
      "type": "quantitative",
      "title": "Average Overall Rating",
      "scale": {
        "domain": [
          0,
          5
        ]
      }
    },
    "tooltip": [
      {
        "field": "academic_year",
        "type": "nominal",
        "title": "Academic Year"
      },
      {
        "field": "avg_overall_rating",
        "type": "quantitative",
        "title": "Average Overall Rating",
        "format": ".2f"
      }
    ]
  }
}
