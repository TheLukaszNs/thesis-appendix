{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Average Professor Ratings Over Academic Years",
  "description": "Trend of average professor ratings across academic years",
  "data": {
    "name": "query_result"
  },
  "mark": {
    "type": "line",
    "point": true,
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "academic_year",
      "type": "nominal",
      "title": "Academic Year",
      "axis": {
        "labelAngle": -45
      }
    },
    "y": {
      "field": "avg_professor_rating",
      "type": "quantitative",
      "title": "Average Professor Rating",
      "scale": {
        "domain": [
          0,
          5
        ]
      }
    },
    "tooltip": [
      {
        "field": "academic_year",
        "type": "nominal",
        "title": "Academic Year"
      },
      {
        "field": "avg_professor_rating",
        "type": "quantitative",
        "title": "Average Rating",
        "format": ".2f"
      },
      {
        "field": "evaluation_count",
        "type": "quantitative",
        "title": "Number of Evaluations"
      }
    ]
  }
}
