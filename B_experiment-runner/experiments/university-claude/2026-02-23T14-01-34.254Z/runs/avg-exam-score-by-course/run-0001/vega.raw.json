{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Average Exam Score by Course",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "code",
      "type": "nominal",
      "title": "Course Code",
      "axis": {
        "labelAngle": -45
      }
    },
    "y": {
      "field": "average_exam_score",
      "type": "quantitative",
      "title": "Average Exam Score"
    },
    "tooltip": [
      {
        "field": "code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "average_exam_score",
        "type": "quantitative",
        "title": "Average Exam Score",
        "format": ".2f"
      }
    ],
    "color": {
      "field": "average_exam_score",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      },
      "title": "Average Score"
    }
  },
  "width": 800,
  "height": 400
}
