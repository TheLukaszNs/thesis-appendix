{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Computer Labs by Building",
  "description": "Count of computer labs in each building",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "building",
      "type": "nominal",
      "title": "Building",
      "sort": "ascending"
    },
    "y": {
      "field": "computer_lab_count",
      "type": "quantitative",
      "title": "Number of Computer Labs"
    },
    "tooltip": [
      {
        "field": "building",
        "type": "nominal",
        "title": "Building"
      },
      {
        "field": "computer_lab_count",
        "type": "quantitative",
        "title": "Computer Labs"
      }
    ]
  }
}
