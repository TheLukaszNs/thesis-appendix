{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Top 10 Courses by Average Reported Workload",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "name",
      "type": "nominal",
      "sort": "-x",
      "title": "Course Name"
    },
    "x": {
      "field": "avg_workload_hours",
      "type": "quantitative",
      "title": "Average Workload (hours)"
    },
    "tooltip": [
      {
        "field": "code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "avg_workload_hours",
        "type": "quantitative",
        "title": "Average Workload (hours)",
        "format": ".2f"
      }
    ]
  },
  "height": 400,
  "width": 600
}
