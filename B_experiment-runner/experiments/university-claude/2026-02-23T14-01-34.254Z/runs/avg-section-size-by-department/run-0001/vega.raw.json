{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Average Maximum Section Size per Department",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "labelAngle": -45,
        "labelAlign": "right"
      },
      "title": "Department"
    },
    "y": {
      "field": "avg_max_section_size",
      "type": "quantitative",
      "title": "Average Maximum Section Size"
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "avg_max_section_size",
        "type": "quantitative",
        "title": "Avg Max Section Size",
        "format": ".2f"
      }
    ]
  },
  "width": 600,
  "height": 400
}
