{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Percentage of Students Who Would Recommend Courses by Department",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "recommend_percentage",
      "type": "quantitative",
      "title": "Recommendation Percentage (%)",
      "scale": {
        "domain": [
          0,
          100
        ]
      }
    },
    "y": {
      "field": "department_name",
      "type": "nominal",
      "title": "Department",
      "sort": {
        "field": "recommend_percentage",
        "order": "descending"
      }
    },
    "color": {
      "field": "recommend_percentage",
      "type": "quantitative",
      "scale": {
        "scheme": "greens"
      },
      "title": "Recommendation %"
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "department_code",
        "type": "nominal",
        "title": "Code"
      },
      {
        "field": "recommend_percentage",
        "type": "quantitative",
        "title": "Recommendation %",
        "format": ".2f"
      },
      {
        "field": "recommend_count",
        "type": "quantitative",
        "title": "Recommending Students"
      },
      {
        "field": "total_evaluations",
        "type": "quantitative",
        "title": "Total Evaluations"
      }
    ]
  }
}
