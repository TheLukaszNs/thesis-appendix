{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Courses by Prerequisite Status",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "prerequisite_status",
      "type": "nominal",
      "title": "Prerequisite Status"
    },
    "y": {
      "field": "course_count",
      "type": "quantitative",
      "title": "Number of Courses"
    },
    "color": {
      "field": "prerequisite_status",
      "type": "nominal",
      "scale": {
        "domain": [
          "No prerequisites",
          "At least one prerequisite"
        ],
        "range": [
          "#2ecc71",
          "#e74c3c"
        ]
      },
      "legend": false
    },
    "tooltip": [
      {
        "field": "prerequisite_status",
        "type": "nominal",
        "title": "Status"
      },
      {
        "field": "course_count",
        "type": "quantitative",
        "title": "Course Count"
      }
    ]
  }
}
