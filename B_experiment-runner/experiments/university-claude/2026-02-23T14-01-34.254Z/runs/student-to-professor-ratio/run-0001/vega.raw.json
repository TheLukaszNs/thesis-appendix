{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Student-to-Professor Ratio per Department",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "department_code",
      "type": "nominal",
      "title": "Department Code",
      "sort": "-y"
    },
    "y": {
      "field": "student_to_professor_ratio",
      "type": "quantitative",
      "title": "Student-to-Professor Ratio"
    },
    "color": {
      "field": "student_to_professor_ratio",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      },
      "title": "Ratio"
    },
    "tooltip": [
      {
        "field": "department_code",
        "type": "nominal",
        "title": "Department Code"
      },
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department Name"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Student Count"
      },
      {
        "field": "professor_count",
        "type": "quantitative",
        "title": "Professor Count"
      },
      {
        "field": "student_to_professor_ratio",
        "type": "quantitative",
        "title": "Ratio",
        "format": ".2f"
      }
    ]
  },
  "width": 600,
  "height": 400
}
