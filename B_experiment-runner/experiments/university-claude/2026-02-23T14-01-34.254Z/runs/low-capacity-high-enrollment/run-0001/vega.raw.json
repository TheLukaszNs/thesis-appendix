{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Course Sections by Overbooked Ratio (Enrolled / Max Capacity)",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "code",
      "type": "nominal",
      "sort": "-x",
      "title": "Course Code"
    },
    "x": {
      "field": "overbooked_ratio",
      "type": "quantitative",
      "title": "Overbooked Ratio (Enrolled / Max)"
    },
    "color": {
      "field": "overbooked_ratio",
      "type": "quantitative",
      "scale": {
        "scheme": "reds"
      },
      "title": "Ratio"
    },
    "tooltip": [
      {
        "field": "code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "section_number",
        "type": "ordinal",
        "title": "Section"
      },
      {
        "field": "academic_year",
        "type": "nominal",
        "title": "Academic Year"
      },
      {
        "field": "semester_type",
        "type": "nominal",
        "title": "Semester"
      },
      {
        "field": "enrolled_count",
        "type": "quantitative",
        "title": "Enrolled"
      },
      {
        "field": "max_students",
        "type": "quantitative",
        "title": "Max Capacity"
      },
      {
        "field": "overbooked_ratio",
        "type": "quantitative",
        "title": "Overbooked Ratio",
        "format": ".2%"
      }
    ]
  },
  "height": 400,
  "width": 600
}
