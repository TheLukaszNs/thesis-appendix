{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Average Difficulty Rating by Course",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "code",
      "type": "nominal",
      "title": "Course Code",
      "sort": {
        "field": "code",
        "order": "ascending"
      }
    },
    "y": {
      "field": "avg_difficulty_rating",
      "type": "quantitative",
      "title": "Average Difficulty Rating",
      "scale": {
        "domain": [
          0,
          5
        ]
      }
    },
    "color": {
      "field": "avg_difficulty_rating",
      "type": "quantitative",
      "scale": {
        "scheme": "reds"
      },
      "title": "Avg Difficulty"
    },
    "tooltip": [
      {
        "field": "code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "avg_difficulty_rating",
        "type": "quantitative",
        "title": "Avg Difficulty Rating",
        "format": ".2f"
      }
    ]
  },
  "width": 900,
  "height": 400
}
