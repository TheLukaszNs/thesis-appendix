{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Percentage of Classrooms with Projectors by Building",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "building",
      "type": "nominal",
      "title": "Building",
      "sort": "ascending"
    },
    "y": {
      "field": "projector_percentage",
      "type": "quantitative",
      "title": "Projector Percentage (%)",
      "scale": {
        "domain": [
          0,
          100
        ]
      }
    },
    "color": {
      "field": "projector_percentage",
      "type": "quantitative",
      "scale": {
        "scheme": "viridis"
      },
      "title": "Percentage (%)"
    },
    "tooltip": [
      {
        "field": "building",
        "type": "nominal",
        "title": "Building"
      },
      {
        "field": "total_classrooms",
        "type": "quantitative",
        "title": "Total Classrooms"
      },
      {
        "field": "classrooms_with_projector",
        "type": "quantitative",
        "title": "Classrooms with Projector"
      },
      {
        "field": "projector_percentage",
        "type": "quantitative",
        "title": "Percentage (%)",
        "format": ".2f"
      }
    ]
  },
  "width": 800,
  "height": 400
}
