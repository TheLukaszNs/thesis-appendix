{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Departments by Total Scholarship Money",
  "description": "Ranking of departments by total scholarship funding awarded to students",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "department_name",
      "type": "nominal",
      "sort": "-x",
      "title": "Department"
    },
    "x": {
      "field": "total_scholarship_money",
      "type": "quantitative",
      "title": "Total Scholarship Money"
    },
    "color": {
      "field": "total_scholarship_money",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      },
      "title": "Total Scholarship ($)"
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "department_code",
        "type": "nominal",
        "title": "Code"
      },
      {
        "field": "total_scholarship_money",
        "type": "quantitative",
        "title": "Total Scholarship",
        "format": "$,.2f"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Student Count"
      }
    ]
  },
  "width": 600,
  "height": 300
}
