{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average GPA by Total Scholarship Amount Range",
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "amount_range",
      "type": "nominal",
      "title": "Scholarship Amount Range",
      "sort": [
        "<1k",
        "1k-4.9k",
        "5k-9.9k",
        ">=10k"
      ]
    },
    "y": {
      "field": "avg_gpa",
      "type": "quantitative",
      "title": "Average GPA"
    },
    "color": {
      "field": "student_count",
      "type": "quantitative",
      "title": "Student Count",
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "amount_range",
        "type": "nominal",
        "title": "Amount Range"
      },
      {
        "field": "avg_gpa",
        "type": "quantitative",
        "title": "Average GPA",
        "format": ".2f"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Student Count"
      }
    ]
  }
}
