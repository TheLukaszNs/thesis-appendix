{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Number of Departments per Building",
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "building",
      "type": "nominal",
      "axis": {
        "title": "Building"
      },
      "sort": {
        "field": "department_count",
        "op": "sum",
        "order": "descending"
      }
    },
    "y": {
      "field": "department_count",
      "type": "quantitative",
      "axis": {
        "title": "Number of Departments"
      }
    },
    "color": {
      "field": "department_count",
      "type": "quantitative",
      "legend": null
    },
    "tooltip": [
      {
        "field": "building",
        "type": "nominal",
        "title": "Building"
      },
      {
        "field": "department_count",
        "type": "quantitative",
        "title": "Departments"
      }
    ]
  },
  "width": 600,
  "height": 320
}
