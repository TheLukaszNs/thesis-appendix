{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Evaluations submitted per course",
  "width": 700,
  "height": 360,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "course_id",
      "type": "nominal",
      "axis": {
        "title": "course_id",
        "labelAngle": -40
      }
    },
    "y": {
      "field": "evaluations_count",
      "type": "quantitative",
      "axis": {
        "title": "evaluations_count"
      }
    },
    "color": {
      "field": "evaluations_count",
      "type": "quantitative",
      "legend": null
    },
    "tooltip": [
      {
        "field": "course_id",
        "type": "nominal",
        "title": "course_id"
      },
      {
        "field": "evaluations_count",
        "type": "quantitative",
        "title": "evaluations_count"
      }
    ]
  }
}
