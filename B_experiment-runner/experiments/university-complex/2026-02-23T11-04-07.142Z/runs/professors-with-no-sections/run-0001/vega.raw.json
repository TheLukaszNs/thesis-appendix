{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Number of professors who have never taught a course section",
  "width": 360,
  "height": 240,
  "mark": {
    "type": "bar",
    "color": "#4C78A8",
    "cornerRadius": 3
  },
  "encoding": {
    "x": {
      "field": "label",
      "type": "nominal",
      "axis": {
        "title": ""
      }
    },
    "y": {
      "field": "professors_never_taught",
      "type": "quantitative",
      "axis": {
        "title": "Professors",
        "grid": true
      }
    },
    "tooltip": [
      {
        "field": "label",
        "type": "nominal",
        "title": ""
      },
      {
        "field": "professors_never_taught",
        "type": "quantitative",
        "title": "Count"
      }
    ]
  }
}
