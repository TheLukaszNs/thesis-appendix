{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Top 10 Students by GPA",
  "width": "container",
  "height": 360,
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "full_name",
      "type": "nominal",
      "axis": {
        "title": "Student",
        "labelAngle": -40
      },
      "sort": {
        "field": "gpa",
        "op": "max",
        "order": "descending"
      }
    },
    "y": {
      "field": "gpa",
      "type": "quantitative",
      "axis": {
        "title": "GPA"
      }
    },
    "tooltip": [
      {
        "field": "full_name",
        "type": "nominal",
        "title": "Name"
      },
      {
        "field": "gpa",
        "type": "quantitative",
        "title": "GPA"
      },
      {
        "field": "index_number",
        "type": "nominal",
        "title": "Index Number"
      },
      {
        "field": "student_id",
        "type": "nominal",
        "title": "Student ID"
      }
    ]
  }
}
