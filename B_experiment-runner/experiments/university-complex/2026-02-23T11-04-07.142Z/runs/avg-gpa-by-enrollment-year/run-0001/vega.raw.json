{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": {
    "text": "Average GPA by Year of Enrollment",
    "anchor": "middle"
  },
  "width": 600,
  "height": 360,
  "mark": {
    "type": "line",
    "point": true,
    "interpolate": "monotone"
  },
  "encoding": {
    "x": {
      "field": "enrollment_year",
      "type": "ordinal",
      "axis": {
        "title": "Enrollment Year"
      }
    },
    "y": {
      "field": "avg_gpa",
      "type": "quantitative",
      "axis": {
        "title": "Average GPA"
      },
      "scale": {
        "zero": false
      }
    },
    "tooltip": [
      {
        "field": "enrollment_year",
        "type": "ordinal",
        "title": "Enrollment Year"
      },
      {
        "field": "avg_gpa",
        "type": "quantitative",
        "title": "Average GPA",
        "format": ".2f"
      }
    ]
  }
}
