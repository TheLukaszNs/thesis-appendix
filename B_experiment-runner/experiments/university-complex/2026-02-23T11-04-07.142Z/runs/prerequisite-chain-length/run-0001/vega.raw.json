{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Courses that are prerequisites for the most other courses",
  "width": 700,
  "height": 400,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "pr_course_code",
      "type": "nominal",
      "sort": {
        "field": "dependent_count",
        "order": "descending"
      },
      "axis": {
        "labelAngle": -45,
        "labelOverlap": "parity",
        "title": "Prerequisite course (code)"
      }
    },
    "y": {
      "field": "dependent_count",
      "type": "quantitative",
      "axis": {
        "title": "Number of courses that list this as a prerequisite"
      }
    },
    "tooltip": [
      {
        "field": "pr_course_code",
        "type": "nominal",
        "title": "Course code"
      },
      {
        "field": "pr_course_name",
        "type": "nominal",
        "title": "Course name"
      },
      {
        "field": "dependent_count",
        "type": "quantitative",
        "title": "Dependent count"
      }
    ],
    "color": {
      "field": "dependent_count",
      "type": "quantitative",
      "legend": null,
      "scale": {
        "scheme": "blues"
      }
    }
  }
}
