{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Total Scholarship Amount by Scholarship Type",
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "scholarship_type",
      "type": "nominal",
      "axis": {
        "title": "Scholarship Type"
      },
      "sort": {
        "field": "total_amount",
        "order": "descending"
      }
    },
    "y": {
      "field": "total_amount",
      "type": "quantitative",
      "axis": {
        "title": "Total Amount"
      }
    },
    "color": {
      "field": "scholarship_type",
      "type": "nominal",
      "legend": null
    },
    "tooltip": [
      {
        "field": "scholarship_type",
        "type": "nominal",
        "title": "Scholarship Type"
      },
      {
        "field": "total_amount",
        "type": "quantitative",
        "title": "Total Amount",
        "format": "$,.2f"
      }
    ]
  },
  "width": 600,
  "height": 400
}
