{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Classrooms by equipment type (projector only, computers only, both, neither)",
  "width": 600,
  "height": 320,
  "mark": {
    "type": "bar",
    "cornerRadius": 3
  },
  "encoding": {
    "x": {
      "field": "equipment_type",
      "type": "nominal",
      "title": "Equipment type",
      "sort": [
        "both",
        "projector_only",
        "computers_only",
        "neither"
      ]
    },
    "y": {
      "field": "classroom_count",
      "type": "quantitative",
      "title": "Number of classrooms",
      "axis": {
        "grid": true
      }
    },
    "color": {
      "field": "equipment_type",
      "type": "nominal",
      "legend": null
    },
    "tooltip": [
      {
        "field": "equipment_type",
        "type": "nominal",
        "title": "Equipment type"
      },
      {
        "field": "classroom_count",
        "type": "quantitative",
        "title": "Classrooms"
      }
    ]
  }
}
