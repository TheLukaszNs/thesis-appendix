{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Total seating capacity per building",
  "width": 600,
  "height": 400,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "building",
      "type": "nominal",
      "axis": {
        "title": "Building"
      }
    },
    "y": {
      "field": "total_capacity",
      "type": "quantitative",
      "axis": {
        "title": "Total seating capacity"
      }
    },
    "tooltip": [
      {
        "field": "building",
        "type": "nominal",
        "title": "Building"
      },
      {
        "field": "total_capacity",
        "type": "quantitative",
        "title": "Total capacity"
      }
    ]
  }
}
