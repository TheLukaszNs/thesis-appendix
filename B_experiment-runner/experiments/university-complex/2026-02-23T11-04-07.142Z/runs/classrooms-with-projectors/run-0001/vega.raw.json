{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Percentage of Classrooms with Projectors by Building",
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "building",
      "type": "nominal",
      "title": "Building"
    },
    "y": {
      "field": "projector_percentage",
      "type": "quantitative",
      "title": "Percent of Classrooms with Projectors (%)",
      "axis": {
        "format": ".1f"
      }
    },
    "tooltip": [
      {
        "field": "building",
        "type": "nominal",
        "title": "Building"
      },
      {
        "field": "projector_percentage",
        "type": "quantitative",
        "title": "Projector (%)",
        "format": ".1f"
      },
      {
        "field": "projector_count",
        "type": "quantitative",
        "title": "Projector Count"
      },
      {
        "field": "total_count",
        "type": "quantitative",
        "title": "Total Classrooms"
      }
    ]
  }
}
