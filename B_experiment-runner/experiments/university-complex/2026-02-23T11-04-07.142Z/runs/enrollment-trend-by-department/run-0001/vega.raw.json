{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Enrollment trends by department over academic years",
  "width": 700,
  "height": 400,
  "mark": {
    "type": "line",
    "point": true,
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "academic_year",
      "type": "ordinal",
      "title": "Academic Year",
      "axis": {
        "labelAngle": -40
      },
      "sort": {
        "field": "academic_year",
        "order": "ascending"
      }
    },
    "y": {
      "field": "enrollment_count",
      "type": "quantitative",
      "title": "Enrollment Count"
    },
    "color": {
      "field": "department_name",
      "type": "nominal",
      "title": "Department"
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "academic_year",
        "type": "ordinal",
        "title": "Academic Year"
      },
      {
        "field": "enrollment_count",
        "type": "quantitative",
        "title": "Enrollment Count"
      }
    ]
  }
}
