{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average exam score by course",
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "course_name",
      "type": "nominal",
      "axis": {
        "title": "Course",
        "labelAngle": -40,
        "labelOverlap": "parity"
      },
      "sort": {
        "field": "course_name",
        "order": "ascending"
      }
    },
    "y": {
      "field": "average_exam_score",
      "type": "quantitative",
      "axis": {
        "title": "Average Exam Score"
      }
    },
    "tooltip": [
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course"
      },
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Code"
      },
      {
        "field": "average_exam_score",
        "type": "quantitative",
        "title": "Average Exam Score",
        "format": ".2f"
      }
    ]
  }
}
