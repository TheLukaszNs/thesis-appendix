{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Students Enrolled per Course",
  "width": 800,
  "height": 420,
  "mark": {
    "type": "bar",
    "cornerRadius": 3
  },
  "encoding": {
    "x": {
      "field": "course_name",
      "type": "nominal",
      "axis": {
        "title": "Course",
        "labelAngle": -40
      },
      "sort": {
        "field": "enrolled_students",
        "order": "descending"
      }
    },
    "y": {
      "field": "enrolled_students",
      "type": "quantitative",
      "axis": {
        "title": "Enrolled Students"
      }
    },
    "tooltip": [
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course"
      },
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "enrolled_students",
        "type": "quantitative",
        "title": "Enrolled Students"
      },
      {
        "field": "course_id",
        "type": "nominal",
        "title": "Course ID"
      }
    ]
  }
}
