{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Distribution of classroom capacities",
  "mark": "bar",
  "width": 600,
  "height": 320,
  "encoding": {
    "x": {
      "field": "capacity",
      "type": "ordinal",
      "axis": {
        "title": "Capacity"
      },
      "sort": {
        "field": "capacity",
        "order": "ascending"
      }
    },
    "y": {
      "field": "classroom_count",
      "type": "quantitative",
      "axis": {
        "title": "Number of classrooms"
      }
    },
    "tooltip": [
      {
        "field": "capacity",
        "type": "ordinal",
        "title": "Capacity"
      },
      {
        "field": "classroom_count",
        "type": "quantitative",
        "title": "Classroom count"
      }
    ],
    "color": {
      "value": "#4C78A8"
    }
  }
}
