{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Credits by Course Type",
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "course_type",
      "type": "nominal",
      "axis": {
        "title": "Course Type"
      },
      "sort": "ascending"
    },
    "y": {
      "field": "avg_credits",
      "type": "quantitative",
      "axis": {
        "title": "Average Credits"
      },
      "scale": {
        "zero": true
      }
    },
    "tooltip": [
      {
        "field": "course_type",
        "type": "nominal",
        "title": "Course Type"
      },
      {
        "field": "avg_credits",
        "type": "quantitative",
        "title": "Average Credits",
        "format": ".2f"
      }
    ]
  }
}
