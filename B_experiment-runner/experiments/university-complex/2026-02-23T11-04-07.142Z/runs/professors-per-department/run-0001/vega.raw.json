{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Number of Professors per Department",
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "title": "Department"
      },
      "sort": {
        "field": "professor_count",
        "order": "descending"
      }
    },
    "y": {
      "field": "professor_count",
      "type": "quantitative",
      "axis": {
        "title": "Number of Professors"
      }
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "professor_count",
        "type": "quantitative",
        "title": "Professors"
      }
    ]
  }
}
