{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Number of course sections taught per building",
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "building",
      "type": "nominal",
      "axis": {
        "title": "Building"
      },
      "sort": {
        "field": "building",
        "order": "ascending"
      }
    },
    "y": {
      "field": "sections_count",
      "type": "quantitative",
      "axis": {
        "title": "Sections count"
      }
    },
    "tooltip": [
      {
        "field": "building",
        "type": "nominal",
        "title": "Building"
      },
      {
        "field": "sections_count",
        "type": "quantitative",
        "title": "Sections count"
      }
    ]
  }
}
