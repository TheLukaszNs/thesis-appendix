{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Top 10 Professors by Average Student Professor Rating",
  "width": 700,
  "height": 420,
  "mark": {
    "type": "bar",
    "cornerRadius": 2
  },
  "encoding": {
    "x": {
      "field": "professor_name",
      "type": "ordinal",
      "axis": {
        "labelAngle": -40,
        "labelOverlap": "parity",
        "title": "Professor"
      },
      "sort": {
        "field": "avg_professor_rating",
        "op": "max",
        "order": "descending"
      }
    },
    "y": {
      "field": "avg_professor_rating",
      "type": "quantitative",
      "axis": {
        "title": "Average Professor Rating"
      },
      "scale": {
        "domain": [
          0,
          5
        ]
      }
    },
    "color": {
      "field": "num_evaluations",
      "type": "quantitative",
      "title": "Number of evaluations",
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "professor_name",
        "type": "nominal",
        "title": "Professor"
      },
      {
        "field": "avg_professor_rating",
        "type": "quantitative",
        "title": "Avg Rating"
      },
      {
        "field": "num_evaluations",
        "type": "quantitative",
        "title": "# Evaluations"
      },
      {
        "field": "professor_id",
        "type": "nominal",
        "title": "Professor ID"
      }
    ]
  }
}
