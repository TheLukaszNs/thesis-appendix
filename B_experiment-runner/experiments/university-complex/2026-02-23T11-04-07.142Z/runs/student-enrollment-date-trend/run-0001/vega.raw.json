{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Distinct students enrolled per year",
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "enrollment_year",
      "type": "ordinal",
      "axis": {
        "title": "Enrollment year"
      },
      "sort": {
        "field": "enrollment_year",
        "order": "ascending"
      }
    },
    "y": {
      "field": "students_enrolled",
      "type": "quantitative",
      "axis": {
        "title": "Students enrolled"
      }
    },
    "tooltip": [
      {
        "field": "enrollment_year",
        "type": "ordinal",
        "title": "Year"
      },
      {
        "field": "students_enrolled",
        "type": "quantitative",
        "title": "Students enrolled"
      }
    ]
  }
}
