{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Distribution of individual scholarship amounts",
  "mark": {
    "type": "bar",
    "color": "#4C78A8",
    "size": 14
  },
  "encoding": {
    "x": {
      "field": "bucket_start",
      "type": "quantitative",
      "title": "Scholarship amount (bucket start)"
    },
    "x2": {
      "field": "bucket_end"
    },
    "y": {
      "field": "scholarship_count",
      "type": "quantitative",
      "title": "Number of scholarships"
    },
    "tooltip": [
      {
        "field": "bucket_start",
        "type": "quantitative",
        "title": "Bucket start"
      },
      {
        "field": "bucket_end",
        "type": "quantitative",
        "title": "Bucket end"
      },
      {
        "field": "scholarship_count",
        "type": "quantitative",
        "title": "Count"
      },
      {
        "field": "amount_bucket",
        "type": "quantitative",
        "title": "Bucket index"
      }
    ]
  }
}
