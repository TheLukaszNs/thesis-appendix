{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Sections per Professor by Department",
  "width": 700,
  "height": 400,
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "title": "Department",
        "labelAngle": -40
      }
    },
    "y": {
      "field": "avg_sections_per_professor",
      "type": "quantitative",
      "axis": {
        "title": "Average Sections per Professor"
      }
    },
    "color": {
      "value": "#4C78A8"
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "avg_sections_per_professor",
        "type": "quantitative",
        "title": "Avg Sections/Professor",
        "format": ".2f"
      },
      {
        "field": "professor_count",
        "type": "quantitative",
        "title": "Professor Count"
      },
      {
        "field": "total_sections",
        "type": "quantitative",
        "title": "Total Sections"
      },
      {
        "field": "department_id",
        "type": "nominal",
        "title": "Department ID"
      }
    ]
  }
}
