{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Total Scholarship Amount by Student (highest recipients)",
  "data": {
    "name": "query_result"
  },
  "width": 700,
  "height": 400,
  "mark": {
    "type": "bar",
    "tooltip": true,
    "cornerRadius": 3
  },
  "encoding": {
    "x": {
      "field": "student_name",
      "type": "nominal",
      "title": "Student",
      "sort": {
        "field": "total_scholarship_amount",
        "op": "sum",
        "order": "descending"
      }
    },
    "y": {
      "field": "total_scholarship_amount",
      "type": "quantitative",
      "title": "Total Scholarship Amount",
      "axis": {
        "format": "$,.2f"
      }
    },
    "tooltip": [
      {
        "field": "student_name",
        "type": "nominal",
        "title": "Student"
      },
      {
        "field": "student_index_number",
        "type": "nominal",
        "title": "Index Number"
      },
      {
        "field": "total_scholarship_amount",
        "type": "quantitative",
        "title": "Total Scholarship",
        "format": "$,.2f"
      },
      {
        "field": "student_id",
        "type": "nominal",
        "title": "Student ID"
      }
    ],
    "color": {
      "datum": "#4C78A8"
    }
  }
}
