{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average scholarship amount per student by department",
  "width": 800,
  "height": 420,
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "department_name",
      "type": "nominal",
      "title": "Department",
      "axis": {
        "labelAngle": -40,
        "labelLimit": 300
      }
    },
    "y": {
      "field": "avg_scholarship_amount_per_student",
      "type": "quantitative",
      "title": "Avg scholarship per student",
      "axis": {
        "format": ".2f"
      }
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "avg_scholarship_amount_per_student",
        "type": "quantitative",
        "title": "Avg scholarship per student",
        "format": ".2f"
      },
      {
        "field": "total_scholarship_amount",
        "type": "quantitative",
        "title": "Total scholarship amount",
        "format": ".2f"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Student count"
      }
    ]
  }
}
