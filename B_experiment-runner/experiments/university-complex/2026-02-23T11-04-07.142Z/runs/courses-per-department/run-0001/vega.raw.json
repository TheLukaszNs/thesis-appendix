{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Courses per Department",
  "width": 700,
  "height": 400,
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "title": "Department",
        "labelAngle": -45
      },
      "sort": {
        "field": "department_name",
        "order": "ascending"
      }
    },
    "y": {
      "field": "course_count",
      "type": "quantitative",
      "axis": {
        "title": "Number of Courses"
      }
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "course_count",
        "type": "quantitative",
        "title": "Courses"
      },
      {
        "field": "department_id",
        "type": "nominal",
        "title": "Department ID"
      }
    ]
  }
}
