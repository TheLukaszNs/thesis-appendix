{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Number of courses by course type",
  "mark": {
    "type": "bar",
    "cornerRadius": 3
  },
  "encoding": {
    "x": {
      "field": "course_type",
      "type": "nominal",
      "axis": {
        "title": "Course type",
        "labelAngle": -40
      },
      "sort": {
        "field": "course_count",
        "order": "descending"
      }
    },
    "y": {
      "field": "course_count",
      "type": "quantitative",
      "axis": {
        "title": "Number of courses"
      }
    },
    "tooltip": [
      {
        "field": "course_type",
        "type": "nominal",
        "title": "Course type"
      },
      {
        "field": "course_count",
        "type": "quantitative",
        "title": "Number of courses"
      }
    ]
  },
  "width": 600,
  "height": 360
}
