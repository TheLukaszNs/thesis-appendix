{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average exam score by academic year",
  "width": 640,
  "height": 320,
  "mark": {
    "type": "line",
    "point": true
  },
  "encoding": {
    "x": {
      "field": "academic_year",
      "type": "ordinal",
      "title": "Academic year",
      "axis": {
        "labelAngle": 0
      }
    },
    "y": {
      "field": "avg_exam_score",
      "type": "quantitative",
      "title": "Average exam score",
      "scale": {
        "zero": false
      }
    },
    "tooltip": [
      {
        "field": "academic_year",
        "type": "ordinal",
        "title": "Academic year"
      },
      {
        "field": "avg_exam_score",
        "type": "quantitative",
        "title": "Avg exam score",
        "format": ".2f"
      }
    ]
  }
}
