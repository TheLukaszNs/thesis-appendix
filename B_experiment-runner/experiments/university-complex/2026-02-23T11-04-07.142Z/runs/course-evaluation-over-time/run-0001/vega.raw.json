{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Overall Evaluation Rating by Academic Year",
  "width": 640,
  "height": 360,
  "mark": {
    "type": "line",
    "point": true
  },
  "encoding": {
    "x": {
      "field": "academic_year",
      "type": "ordinal",
      "axis": {
        "title": "Academic Year"
      }
    },
    "y": {
      "field": "avg_overall_rating",
      "type": "quantitative",
      "axis": {
        "title": "Average Overall Rating"
      }
    },
    "tooltip": [
      {
        "field": "academic_year",
        "type": "ordinal",
        "title": "Academic Year"
      },
      {
        "field": "avg_overall_rating",
        "type": "quantitative",
        "title": "Avg Overall Rating"
      }
    ]
  }
}
