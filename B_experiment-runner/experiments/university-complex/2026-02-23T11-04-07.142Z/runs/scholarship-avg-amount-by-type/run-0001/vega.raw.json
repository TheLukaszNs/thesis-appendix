{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average scholarship amount by type",
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "scholarship_type",
      "type": "nominal",
      "axis": {
        "title": "Scholarship Type"
      },
      "sort": "ascending"
    },
    "y": {
      "field": "avg_amount",
      "type": "quantitative",
      "axis": {
        "title": "Average amount"
      }
    },
    "tooltip": [
      {
        "field": "scholarship_type",
        "type": "nominal",
        "title": "Scholarship Type"
      },
      {
        "field": "avg_amount",
        "type": "quantitative",
        "title": "Average Amount",
        "format": ".2f"
      }
    ]
  },
  "width": 500,
  "height": 300
}
