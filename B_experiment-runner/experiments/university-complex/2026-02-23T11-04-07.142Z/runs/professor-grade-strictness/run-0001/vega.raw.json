{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Professors ordered by average exam score (lowest = strictest)",
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "professor_name",
      "type": "nominal",
      "axis": {
        "title": "Professor",
        "labelAngle": -40
      },
      "sort": {
        "field": "avg_grade",
        "order": "ascending"
      }
    },
    "y": {
      "field": "avg_grade",
      "type": "quantitative",
      "axis": {
        "title": "Average exam score"
      }
    },
    "tooltip": [
      {
        "field": "professor_name",
        "type": "nominal",
        "title": "Professor"
      },
      {
        "field": "avg_grade",
        "type": "quantitative",
        "title": "Avg grade",
        "format": ".2f"
      },
      {
        "field": "num_grades",
        "type": "quantitative",
        "title": "Num grades"
      },
      {
        "field": "professor_id",
        "type": "nominal",
        "title": "Professor ID"
      }
    ]
  }
}
