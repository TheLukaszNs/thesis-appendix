{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Bar chart showing number of prerequisites per course.",
  "data": {
    "name": "query_result"
  },
  "title": "Number of prerequisites per course",
  "width": 700,
  "height": 360,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "course_code",
      "type": "nominal",
      "axis": {
        "title": "Course code",
        "labelAngle": -40
      },
      "sort": {
        "field": "prereq_count",
        "order": "descending"
      }
    },
    "y": {
      "field": "prereq_count",
      "type": "quantitative",
      "axis": {
        "title": "Number of prerequisites"
      }
    },
    "tooltip": [
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Course code"
      },
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course name"
      },
      {
        "field": "prereq_count",
        "type": "quantitative",
        "title": "Prereq count"
      }
    ]
  }
}
