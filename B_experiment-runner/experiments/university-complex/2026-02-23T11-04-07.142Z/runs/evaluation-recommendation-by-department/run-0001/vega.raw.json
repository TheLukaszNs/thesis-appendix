{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Percentage of students who would recommend courses by department",
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "title": "Department"
      },
      "sort": {
        "field": "percent_recommended",
        "order": "descending"
      }
    },
    "y": {
      "field": "percent_recommended",
      "type": "quantitative",
      "axis": {
        "title": "Percent Recommended (%)"
      },
      "scale": {
        "domain": [
          0,
          100
        ]
      }
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "percent_recommended",
        "type": "quantitative",
        "title": "Percent Recommended (%)",
        "format": ".1f"
      },
      {
        "field": "recommended_count",
        "type": "quantitative",
        "title": "Recommended Count"
      },
      {
        "field": "total_evaluations",
        "type": "quantitative",
        "title": "Total Evaluations"
      }
    ]
  }
}
