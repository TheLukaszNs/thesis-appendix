{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average section capacity by department",
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "title": "Department"
      },
      "sort": {
        "field": "avg_max_section_size",
        "op": "mean",
        "order": "descending"
      }
    },
    "y": {
      "field": "avg_max_section_size",
      "type": "quantitative",
      "axis": {
        "title": "Avg max section size"
      },
      "scale": {
        "zero": true
      }
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "department_id",
        "type": "nominal",
        "title": "Department ID"
      },
      {
        "field": "avg_max_section_size",
        "type": "quantitative",
        "title": "Avg max section size",
        "format": ".2f"
      }
    ]
  }
}
