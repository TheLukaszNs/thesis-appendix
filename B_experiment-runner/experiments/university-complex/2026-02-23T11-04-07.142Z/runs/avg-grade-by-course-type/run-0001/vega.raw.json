{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Average grade by course type",
  "data": {
    "name": "query_result"
  },
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "course_type",
      "type": "nominal",
      "axis": {
        "title": "Course Type"
      }
    },
    "y": {
      "field": "average_grade",
      "type": "quantitative",
      "axis": {
        "title": "Average Grade"
      },
      "scale": {
        "zero": true
      }
    },
    "tooltip": [
      {
        "field": "course_type",
        "type": "nominal",
        "title": "Course Type"
      },
      {
        "field": "average_grade",
        "type": "quantitative",
        "title": "Average Grade",
        "format": ".2f"
      }
    ]
  }
}
