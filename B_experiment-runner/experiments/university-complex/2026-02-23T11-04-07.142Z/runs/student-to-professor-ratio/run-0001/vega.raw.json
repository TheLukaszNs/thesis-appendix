{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": {
    "text": "Student-to-Professor Ratio by Department",
    "anchor": "start"
  },
  "width": 700,
  "height": 420,
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "title": "Department",
        "labelAngle": -40
      }
    },
    "y": {
      "field": "student_to_professor_ratio",
      "type": "quantitative",
      "axis": {
        "title": "Student-to-Professor Ratio"
      }
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Student Count"
      },
      {
        "field": "professor_count",
        "type": "quantitative",
        "title": "Professor Count"
      },
      {
        "field": "student_to_professor_ratio",
        "type": "quantitative",
        "title": "Student-to-Professor Ratio",
        "format": ".2f"
      }
    ]
  }
}
