{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Exam vs Project Scores by Department",
  "width": 800,
  "height": 420,
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "title": "Department",
        "labelAngle": -40,
        "labelLimit": 300
      }
    },
    "xOffset": {
      "field": "metric",
      "type": "nominal"
    },
    "y": {
      "field": "avg_score",
      "type": "quantitative",
      "axis": {
        "title": "Average Score"
      },
      "scale": {
        "domain": [
          0,
          100
        ]
      }
    },
    "color": {
      "field": "metric",
      "type": "nominal",
      "legend": {
        "title": "Metric"
      }
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "metric",
        "type": "nominal",
        "title": "Metric"
      },
      {
        "field": "avg_score",
        "type": "quantitative",
        "title": "Average Score",
        "format": ".2f"
      }
    ]
  }
}
