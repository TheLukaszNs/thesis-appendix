{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Students by Birth Year",
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "birth_year",
      "type": "ordinal",
      "axis": {
        "title": "Birth Year",
        "labelAngle": 0
      },
      "sort": "ascending"
    },
    "y": {
      "field": "student_count",
      "type": "quantitative",
      "axis": {
        "title": "Number of Students"
      }
    },
    "tooltip": [
      {
        "field": "birth_year",
        "type": "ordinal",
        "title": "Birth Year"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Students"
      }
    ]
  }
}
