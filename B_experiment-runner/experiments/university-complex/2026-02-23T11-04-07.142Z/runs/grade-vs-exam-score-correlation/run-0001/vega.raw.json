{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average exam score by grade value",
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "grade_value",
      "type": "nominal",
      "axis": {
        "title": "Grade value"
      }
    },
    "y": {
      "field": "avg_exam_score",
      "type": "quantitative",
      "axis": {
        "title": "Average exam score"
      }
    },
    "tooltip": [
      {
        "field": "grade_value",
        "type": "nominal",
        "title": "Grade value"
      },
      {
        "field": "avg_exam_score",
        "type": "quantitative",
        "title": "Average exam score",
        "format": ".2f"
      }
    ]
  }
}
