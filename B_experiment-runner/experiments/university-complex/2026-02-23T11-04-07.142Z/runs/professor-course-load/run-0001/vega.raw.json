{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Number of course sections per professor",
  "width": 700,
  "height": 400,
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "professor_name",
      "type": "nominal",
      "axis": {
        "title": "Professor",
        "labelAngle": -45
      },
      "sort": {
        "field": "section_count",
        "op": "sum",
        "order": "descending"
      }
    },
    "y": {
      "field": "section_count",
      "type": "quantitative",
      "axis": {
        "title": "Section count"
      }
    },
    "color": {
      "value": "#4C78A8"
    },
    "tooltip": [
      {
        "field": "professor_name",
        "type": "nominal",
        "title": "Professor"
      },
      {
        "field": "section_count",
        "type": "quantitative",
        "title": "Sections"
      },
      {
        "field": "professor_id",
        "type": "nominal",
        "title": "Professor ID"
      }
    ]
  }
}
