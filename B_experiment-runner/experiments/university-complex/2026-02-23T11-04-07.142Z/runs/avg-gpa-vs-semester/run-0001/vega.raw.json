{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average GPA by Current Semester",
  "width": 600,
  "height": 320,
  "mark": {
    "type": "line",
    "point": true
  },
  "encoding": {
    "x": {
      "field": "semester",
      "type": "ordinal",
      "title": "Current Semester",
      "axis": {
        "labelAngle": 0
      }
    },
    "y": {
      "field": "avg_gpa",
      "type": "quantitative",
      "title": "Average GPA"
    },
    "tooltip": [
      {
        "field": "semester",
        "type": "ordinal",
        "title": "Semester"
      },
      {
        "field": "avg_gpa",
        "type": "quantitative",
        "title": "Average GPA",
        "format": ".3f"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Student Count"
      }
    ]
  }
}
