{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Top 10 Classrooms by Capacity",
  "width": 700,
  "height": 400,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "classroom_label",
      "type": "nominal",
      "axis": {
        "title": "Classroom",
        "labelAngle": -40
      },
      "sort": {
        "field": "capacity",
        "op": "sum",
        "order": "descending"
      }
    },
    "y": {
      "field": "capacity",
      "type": "quantitative",
      "axis": {
        "title": "Capacity"
      }
    },
    "tooltip": [
      {
        "field": "classroom_label",
        "type": "nominal",
        "title": "Classroom"
      },
      {
        "field": "capacity",
        "type": "quantitative",
        "title": "Capacity"
      },
      {
        "field": "building",
        "type": "nominal",
        "title": "Building"
      },
      {
        "field": "room_number",
        "type": "nominal",
        "title": "Room Number"
      },
      {
        "field": "classroom_id",
        "type": "nominal",
        "title": "Classroom ID"
      }
    ]
  }
}
