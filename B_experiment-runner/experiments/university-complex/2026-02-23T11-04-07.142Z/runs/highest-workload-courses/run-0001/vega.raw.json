{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Top 10 courses by average reported workload (hours)",
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "course_code",
      "type": "nominal",
      "axis": {
        "title": "Course code",
        "labelAngle": -40
      },
      "sort": "-y"
    },
    "y": {
      "field": "avg_workload_hours",
      "type": "quantitative",
      "axis": {
        "title": "Average workload (hours)"
      }
    },
    "color": {
      "field": "evaluation_count",
      "type": "quantitative",
      "legend": {
        "title": "Evaluation count"
      }
    },
    "tooltip": [
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Course code"
      },
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course name"
      },
      {
        "field": "avg_workload_hours",
        "type": "quantitative",
        "title": "Avg workload (hrs)",
        "format": ".2f"
      },
      {
        "field": "evaluation_count",
        "type": "quantitative",
        "title": "# evaluations"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": "transparent"
    }
  }
}
