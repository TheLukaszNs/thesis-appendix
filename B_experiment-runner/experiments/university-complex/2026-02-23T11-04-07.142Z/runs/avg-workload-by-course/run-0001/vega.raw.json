{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Reported Workload Hours per Course",
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "course_code",
      "type": "nominal",
      "axis": {
        "title": "Course Code",
        "labelAngle": -40
      }
    },
    "y": {
      "field": "avg_workload_hours",
      "type": "quantitative",
      "axis": {
        "title": "Average Workload Hours"
      }
    },
    "tooltip": [
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "avg_workload_hours",
        "type": "quantitative",
        "title": "Avg Workload Hours"
      }
    ]
  }
}
