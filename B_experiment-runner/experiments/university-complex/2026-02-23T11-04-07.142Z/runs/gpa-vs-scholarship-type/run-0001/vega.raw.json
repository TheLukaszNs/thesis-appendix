{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average GPA by Scholarship Type",
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "scholarship_type",
      "type": "nominal",
      "title": "Scholarship Type"
    },
    "y": {
      "field": "avg_gpa",
      "type": "quantitative",
      "title": "Average GPA",
      "scale": {
        "zero": true
      }
    },
    "color": {
      "field": "student_count",
      "type": "quantitative",
      "title": "Student Count"
    },
    "tooltip": [
      {
        "field": "scholarship_type",
        "type": "nominal",
        "title": "Scholarship Type"
      },
      {
        "field": "avg_gpa",
        "type": "quantitative",
        "title": "Avg GPA",
        "format": ".2f"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Student Count"
      }
    ]
  }
}
