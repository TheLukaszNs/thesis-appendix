{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average exam, project, and attendance scores by grade value",
  "width": 600,
  "height": 360,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "grade_value",
      "type": "nominal",
      "axis": {
        "title": "Grade value"
      }
    },
    "y": {
      "field": "avg_score",
      "type": "quantitative",
      "axis": {
        "title": "Average score"
      }
    },
    "color": {
      "field": "metric",
      "type": "nominal",
      "legend": {
        "title": "Metric"
      }
    },
    "xOffset": {
      "field": "metric",
      "type": "nominal"
    },
    "tooltip": [
      {
        "field": "grade_value",
        "type": "nominal",
        "title": "Grade value"
      },
      {
        "field": "metric",
        "type": "nominal",
        "title": "Metric"
      },
      {
        "field": "avg_score",
        "type": "quantitative",
        "title": "Average score"
      }
    ]
  }
}
