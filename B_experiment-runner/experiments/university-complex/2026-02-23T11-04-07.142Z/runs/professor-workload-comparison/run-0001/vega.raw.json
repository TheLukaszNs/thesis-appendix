{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Distinct courses taught per professor",
  "width": 900,
  "height": 420,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "professor_name",
      "type": "nominal",
      "axis": {
        "title": "Professor",
        "labelAngle": -45
      },
      "sort": {
        "field": "distinct_course_count",
        "order": "descending"
      }
    },
    "y": {
      "field": "distinct_course_count",
      "type": "quantitative",
      "axis": {
        "title": "Distinct course count"
      }
    },
    "tooltip": [
      {
        "field": "professor_name",
        "type": "nominal",
        "title": "Professor"
      },
      {
        "field": "distinct_course_count",
        "type": "quantitative",
        "title": "Distinct courses"
      },
      {
        "field": "professor_id",
        "type": "nominal",
        "title": "Professor ID"
      }
    ]
  }
}
