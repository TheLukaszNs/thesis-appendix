{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Overall Evaluation Rating by Department",
  "width": 700,
  "height": 360,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "title": "Department",
        "labelAngle": -45
      },
      "sort": {
        "field": "avg_overall_rating",
        "op": "average",
        "order": "descending"
      }
    },
    "y": {
      "field": "avg_overall_rating",
      "type": "quantitative",
      "axis": {
        "title": "Average Overall Rating"
      },
      "scale": {
        "nice": true
      }
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "avg_overall_rating",
        "type": "quantitative",
        "title": "Avg Overall Rating",
        "format": ".2f"
      }
    ]
  }
}
