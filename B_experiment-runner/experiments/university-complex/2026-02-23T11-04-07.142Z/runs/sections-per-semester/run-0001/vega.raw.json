{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Course sections by academic year and semester",
  "width": "container",
  "height": 320,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "academic_year",
      "type": "nominal",
      "axis": {
        "title": "Academic year"
      },
      "sort": "ascending"
    },
    "xOffset": {
      "field": "semester_type",
      "type": "nominal"
    },
    "y": {
      "field": "section_count",
      "type": "quantitative",
      "axis": {
        "title": "Number of sections"
      }
    },
    "color": {
      "field": "semester_type",
      "type": "nominal",
      "legend": {
        "title": "Semester type"
      }
    },
    "tooltip": [
      {
        "field": "academic_year",
        "type": "nominal",
        "title": "Academic year"
      },
      {
        "field": "semester_type",
        "type": "nominal",
        "title": "Semester"
      },
      {
        "field": "section_count",
        "type": "quantitative",
        "title": "Sections"
      }
    ]
  }
}
