{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Bar chart showing distinct student counts per scholarship type.",
  "data": {
    "name": "query_result"
  },
  "title": "Number of students by scholarship type",
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "scholarship_type",
      "type": "nominal",
      "axis": {
        "title": "Scholarship type"
      },
      "sort": "-y"
    },
    "y": {
      "field": "student_count",
      "type": "quantitative",
      "axis": {
        "title": "Student count"
      }
    },
    "tooltip": [
      {
        "field": "scholarship_type",
        "type": "nominal",
        "title": "Scholarship type"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Student count"
      }
    ]
  },
  "width": 480,
  "height": 320
}
