{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Overbooked ratio (enrolled / max) by course section",
  "width": 900,
  "height": 400,
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "section_label",
      "type": "nominal",
      "axis": {
        "labelAngle": -40,
        "labelAlign": "right",
        "title": "Course section"
      },
      "sort": {
        "field": "overbooked_ratio",
        "op": "max",
        "order": "descending"
      }
    },
    "y": {
      "field": "overbooked_ratio",
      "type": "quantitative",
      "axis": {
        "title": "Overbooked ratio (enrolled / max)",
        "format": "%"
      }
    },
    "color": {
      "value": "#4C78A8"
    },
    "tooltip": [
      {
        "field": "section_label",
        "type": "nominal",
        "title": "Section"
      },
      {
        "field": "enrolled_count",
        "type": "quantitative",
        "title": "Enrolled"
      },
      {
        "field": "max_students",
        "type": "quantitative",
        "title": "Max students"
      },
      {
        "field": "overbooked_ratio",
        "type": "quantitative",
        "title": "Overbooked ratio",
        "format": ".1%"
      }
    ]
  }
}
