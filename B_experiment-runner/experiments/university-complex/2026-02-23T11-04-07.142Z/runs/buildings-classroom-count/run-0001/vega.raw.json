{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Classrooms per Building",
  "width": 600,
  "height": 400,
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "building",
      "type": "nominal",
      "axis": {
        "title": "Building"
      },
      "sort": "ascending"
    },
    "y": {
      "field": "classroom_count",
      "type": "quantitative",
      "axis": {
        "title": "Number of Classrooms"
      }
    },
    "tooltip": [
      {
        "field": "building",
        "type": "nominal",
        "title": "Building"
      },
      {
        "field": "classroom_count",
        "type": "quantitative",
        "title": "Classroom Count"
      }
    ]
  }
}
