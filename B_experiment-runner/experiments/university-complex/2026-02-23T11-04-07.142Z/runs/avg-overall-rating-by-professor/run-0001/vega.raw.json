{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Overall Course Evaluation Rating by Professor",
  "width": 700,
  "height": 400,
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "professor_name",
      "type": "nominal",
      "axis": {
        "title": "Professor",
        "labelAngle": -45
      }
    },
    "y": {
      "field": "avg_overall_rating",
      "type": "quantitative",
      "axis": {
        "title": "Average Overall Rating"
      }
    },
    "tooltip": [
      {
        "field": "professor_name",
        "type": "nominal",
        "title": "Professor"
      },
      {
        "field": "avg_overall_rating",
        "type": "quantitative",
        "title": "Avg Rating"
      }
    ]
  }
}
