{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Course credit distribution by department",
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "credits",
      "type": "ordinal",
      "title": "Credits"
    },
    "y": {
      "field": "course_count",
      "type": "quantitative",
      "title": "Number of courses"
    },
    "color": {
      "field": "department_name",
      "type": "nominal",
      "title": "Department"
    },
    "xOffset": {
      "field": "department_name",
      "type": "nominal"
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "credits",
        "type": "ordinal",
        "title": "Credits"
      },
      {
        "field": "course_count",
        "type": "quantitative",
        "title": "Course count"
      }
    ]
  }
}
