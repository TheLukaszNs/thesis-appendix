{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average GPA per Department",
  "width": 700,
  "height": 400,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "title": "Department"
      },
      "sort": {
        "field": "department_name",
        "order": "ascending"
      }
    },
    "y": {
      "field": "avg_gpa",
      "type": "quantitative",
      "axis": {
        "title": "Average GPA"
      },
      "scale": {
        "domain": [
          0,
          4
        ]
      }
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "department_id",
        "type": "nominal",
        "title": "Department ID"
      },
      {
        "field": "avg_gpa",
        "type": "quantitative",
        "title": "Average GPA",
        "format": ".3f"
      }
    ]
  }
}
