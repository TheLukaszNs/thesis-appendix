{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Count of Mandatory vs Optional Prerequisites",
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "is_mandatory",
      "type": "nominal",
      "axis": {
        "title": "Is Mandatory",
        "labelExpr": "datum.value ? 'Mandatory' : 'Optional'"
      },
      "sort": [
        true,
        false
      ]
    },
    "y": {
      "field": "prerequisite_count",
      "type": "quantitative",
      "axis": {
        "title": "Prerequisite Count"
      }
    },
    "color": {
      "field": "is_mandatory",
      "type": "nominal",
      "legend": {
        "title": "Is Mandatory"
      },
      "scale": {
        "domain": [
          true,
          false
        ],
        "range": [
          "#1f77b4",
          "#ff7f0e"
        ]
      }
    },
    "tooltip": [
      {
        "field": "is_mandatory",
        "type": "nominal",
        "title": "Is Mandatory"
      },
      {
        "field": "prerequisite_count",
        "type": "quantitative",
        "title": "Count"
      }
    ]
  }
}
