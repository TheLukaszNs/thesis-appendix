{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Total Credits Offered by Department",
  "width": 700,
  "height": 400,
  "mark": {
    "type": "bar",
    "cornerRadius": 2
  },
  "encoding": {
    "x": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "title": "Department",
        "labelAngle": -40,
        "labelAlign": "right"
      }
    },
    "y": {
      "field": "total_credits",
      "type": "quantitative",
      "axis": {
        "title": "Total Credits"
      }
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "total_credits",
        "type": "quantitative",
        "title": "Total Credits"
      }
    ]
  }
}
