{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Courses by total number of sections offered",
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "course_code",
      "type": "nominal",
      "title": "Course code",
      "axis": {
        "labelAngle": -40
      },
      "sort": {
        "field": "section_count",
        "op": "sum",
        "order": "descending"
      }
    },
    "y": {
      "field": "section_count",
      "type": "quantitative",
      "title": "Number of sections"
    },
    "tooltip": [
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Course code"
      },
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course name"
      },
      {
        "field": "section_count",
        "type": "quantitative",
        "title": "Sections"
      }
    ]
  }
}
