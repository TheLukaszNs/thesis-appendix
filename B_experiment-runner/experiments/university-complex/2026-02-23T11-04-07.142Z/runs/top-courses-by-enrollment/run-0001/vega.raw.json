{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Top 15 Courses by Total Active Enrollments",
  "width": 800,
  "height": 400,
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "course_name",
      "type": "nominal",
      "axis": {
        "title": "Course",
        "labelAngle": -40
      },
      "sort": {
        "field": "total_enrollments",
        "order": "descending"
      }
    },
    "y": {
      "field": "total_enrollments",
      "type": "quantitative",
      "axis": {
        "title": "Total Active Enrollments"
      }
    },
    "tooltip": [
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course"
      },
      {
        "field": "total_enrollments",
        "type": "quantitative",
        "title": "Active Enrollments"
      },
      {
        "field": "course_id",
        "type": "nominal",
        "title": "Course ID"
      }
    ]
  }
}
