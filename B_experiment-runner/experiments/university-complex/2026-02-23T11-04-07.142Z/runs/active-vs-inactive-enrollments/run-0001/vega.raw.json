{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Active vs Inactive Enrollments",
  "mark": {
    "type": "arc",
    "innerRadius": 40
  },
  "encoding": {
    "theta": {
      "field": "count",
      "type": "quantitative"
    },
    "color": {
      "field": "status",
      "type": "nominal",
      "legend": {
        "title": "Status"
      }
    },
    "tooltip": [
      {
        "field": "status",
        "type": "nominal"
      },
      {
        "field": "count",
        "type": "quantitative"
      },
      {
        "field": "active_to_inactive_ratio",
        "type": "quantitative",
        "format": ".2f"
      }
    ]
  }
}
