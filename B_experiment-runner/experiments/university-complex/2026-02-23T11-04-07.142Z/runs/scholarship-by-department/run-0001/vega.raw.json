{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Total scholarship amount by department",
  "width": 700,
  "height": 400,
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "department_name",
      "type": "nominal",
      "title": "Department",
      "axis": {
        "labelAngle": -40,
        "labelLimit": 300
      },
      "sort": {
        "field": "total_scholarship",
        "order": "descending"
      }
    },
    "y": {
      "field": "total_scholarship",
      "type": "quantitative",
      "title": "Total scholarship amount",
      "axis": {
        "format": ".2f"
      }
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "total_scholarship",
        "type": "quantitative",
        "title": "Total scholarship",
        "format": ".2f"
      },
      {
        "field": "department_id",
        "type": "nominal",
        "title": "Department ID"
      }
    ]
  }
}
