{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average exam score by professor academic title",
  "width": 700,
  "height": 400,
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "academic_title",
      "type": "nominal",
      "axis": {
        "title": "Academic title",
        "labelAngle": -40,
        "labelAlign": "right"
      },
      "sort": {
        "field": "avg_exam_score",
        "order": "descending"
      }
    },
    "y": {
      "field": "avg_exam_score",
      "type": "quantitative",
      "axis": {
        "title": "Average exam score"
      },
      "scale": {
        "domain": [
          0,
          100
        ]
      }
    },
    "color": {
      "field": "avg_exam_score",
      "type": "quantitative",
      "legend": null
    },
    "tooltip": [
      {
        "field": "academic_title",
        "type": "nominal",
        "title": "Academic title"
      },
      {
        "field": "avg_exam_score",
        "type": "quantitative",
        "title": "Avg exam score",
        "format": ".2f"
      },
      {
        "field": "grade_count",
        "type": "quantitative",
        "title": "Grade count"
      }
    ]
  }
}
