{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Students per Department",
  "width": 800,
  "height": 400,
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "department",
      "type": "nominal",
      "axis": {
        "labelAngle": -40,
        "labelOverlap": "parity",
        "title": "Department"
      },
      "sort": {
        "field": "student_count",
        "order": "descending"
      }
    },
    "y": {
      "field": "student_count",
      "type": "quantitative",
      "axis": {
        "title": "Number of Students"
      }
    },
    "tooltip": [
      {
        "field": "department",
        "type": "nominal"
      },
      {
        "field": "student_count",
        "type": "quantitative"
      }
    ]
  }
}
