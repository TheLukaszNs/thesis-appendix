{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Students count by Department and Current Semester",
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 2
  },
  "encoding": {
    "x": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "title": "Department",
        "labelAngle": -40
      }
    },
    "y": {
      "field": "student_count",
      "type": "quantitative",
      "axis": {
        "title": "Student count"
      }
    },
    "color": {
      "field": "current_semester",
      "type": "nominal",
      "legend": {
        "title": "Current semester"
      }
    },
    "xOffset": {
      "field": "current_semester",
      "type": "nominal"
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "current_semester",
        "type": "nominal",
        "title": "Current semester"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Students"
      }
    ]
  }
}
