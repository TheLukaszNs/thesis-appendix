{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Distribution of Academic Titles among Professors",
  "width": 700,
  "height": 400,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "academic_title",
      "type": "nominal",
      "axis": {
        "title": "Academic Title",
        "labelAngle": -40
      }
    },
    "y": {
      "field": "professor_count",
      "type": "quantitative",
      "axis": {
        "title": "Professor Count"
      }
    },
    "tooltip": [
      {
        "field": "academic_title",
        "type": "nominal",
        "title": "Academic Title"
      },
      {
        "field": "professor_count",
        "type": "quantitative",
        "title": "Count"
      }
    ]
  },
  "encoding_sort": {},
  "config": {
    "axis": {
      "labelFontSize": 11,
      "titleFontSize": 12
    },
    "title": {
      "fontSize": 14
    }
  },
  "transform": [],
  "resolve": {}
}
