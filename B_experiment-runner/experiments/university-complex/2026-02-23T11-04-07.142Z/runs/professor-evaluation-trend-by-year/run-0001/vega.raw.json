{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Professor Rating by Academic Year",
  "width": 700,
  "height": 360,
  "mark": {
    "type": "line",
    "point": true
  },
  "encoding": {
    "x": {
      "field": "academic_year",
      "type": "ordinal",
      "axis": {
        "title": "Academic Year",
        "labelAngle": -40
      }
    },
    "y": {
      "field": "avg_professor_rating",
      "type": "quantitative",
      "axis": {
        "title": "Average Professor Rating"
      }
    },
    "tooltip": [
      {
        "field": "academic_year",
        "type": "ordinal",
        "title": "Academic Year"
      },
      {
        "field": "avg_professor_rating",
        "type": "quantitative",
        "title": "Avg Rating"
      },
      {
        "field": "eval_count",
        "type": "quantitative",
        "title": "Evaluation Count"
      }
    ],
    "order": {
      "field": "academic_year",
      "type": "ordinal"
    }
  }
}
