{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Courses with zero enrollments",
  "width": 700,
  "height": 320,
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "course_name",
      "type": "nominal",
      "axis": {
        "title": "Course name",
        "labelAngle": -40
      }
    },
    "y": {
      "field": "enrollment_count",
      "type": "quantitative",
      "axis": {
        "title": "Enrollment count"
      }
    },
    "color": {
      "field": "course_code",
      "type": "nominal",
      "legend": {
        "title": "Course code"
      }
    },
    "tooltip": [
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course name"
      },
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Course code"
      },
      {
        "field": "enrollment_count",
        "type": "quantitative",
        "title": "Enrollment count"
      },
      {
        "field": "course_id",
        "type": "nominal",
        "title": "Course ID"
      }
    ]
  }
}
