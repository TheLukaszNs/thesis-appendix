{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Project Score by Department",
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "title": "Department",
        "labelAngle": -40
      },
      "sort": "ascending"
    },
    "y": {
      "field": "avg_project_score",
      "type": "quantitative",
      "axis": {
        "title": "Average Project Score"
      }
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "avg_project_score",
        "type": "quantitative",
        "title": "Avg Project Score",
        "format": ".2f"
      }
    ]
  }
}
