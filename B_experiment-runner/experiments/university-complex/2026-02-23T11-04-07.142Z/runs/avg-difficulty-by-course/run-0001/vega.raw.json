{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Difficulty Rating by Course",
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "course_code",
      "type": "nominal",
      "axis": {
        "title": "Course Code"
      },
      "sort": "ascending"
    },
    "y": {
      "field": "avg_difficulty",
      "type": "quantitative",
      "axis": {
        "title": "Average Difficulty"
      }
    },
    "tooltip": [
      {
        "field": "course_code",
        "type": "nominal",
        "title": "Course Code"
      },
      {
        "field": "course_name",
        "type": "nominal",
        "title": "Course Name"
      },
      {
        "field": "avg_difficulty",
        "type": "quantitative",
        "title": "Avg Difficulty"
      }
    ]
  },
  "width": 700,
  "height": 400
}
