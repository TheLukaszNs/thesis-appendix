{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Professor average rating vs. years since hire",
  "width": 700,
  "height": 420,
  "mark": {
    "type": "point",
    "filled": true,
    "opacity": 0.85,
    "stroke": "gray"
  },
  "encoding": {
    "x": {
      "field": "years_since_hire",
      "type": "quantitative",
      "title": "Years since hire",
      "axis": {
        "grid": true
      }
    },
    "y": {
      "field": "avg_professor_rating",
      "type": "quantitative",
      "title": "Average professor rating",
      "scale": {
        "domain": [
          1,
          5
        ]
      },
      "axis": {
        "grid": true
      }
    },
    "color": {
      "field": "eval_count",
      "type": "quantitative",
      "title": "Number of evaluations",
      "scale": {
        "scheme": "blues"
      }
    },
    "size": {
      "field": "eval_count",
      "type": "quantitative",
      "title": "Number of evaluations",
      "scale": {
        "range": [
          40,
          600
        ]
      }
    },
    "tooltip": [
      {
        "field": "professor_id",
        "type": "nominal",
        "title": "Professor ID"
      },
      {
        "field": "hire_date",
        "type": "temporal",
        "title": "Hire date"
      },
      {
        "field": "years_since_hire",
        "type": "quantitative",
        "title": "Years since hire"
      },
      {
        "field": "avg_professor_rating",
        "type": "quantitative",
        "title": "Avg rating"
      },
      {
        "field": "eval_count",
        "type": "quantitative",
        "title": "Evaluation count"
      }
    ]
  }
}
