{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Bar chart showing count of scholarships by payment status",
  "title": "Scholarships: Paid vs Not Paid",
  "data": {
    "name": "query_result",
    "values": [
      {
        "payment_status": "Paid",
        "scholarship_count": 10
      }
    ]
  },
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "payment_status",
      "type": "nominal",
      "axis": {
        "title": "Payment Status"
      },
      "sort": [
        "Paid",
        "Not Paid"
      ]
    },
    "y": {
      "field": "scholarship_count",
      "type": "quantitative",
      "axis": {
        "title": "Number of Scholarships"
      }
    },
    "color": {
      "field": "payment_status",
      "type": "nominal",
      "legend": {
        "title": "Payment Status"
      }
    },
    "tooltip": [
      {
        "field": "payment_status",
        "type": "nominal",
        "title": "Payment Status"
      },
      {
        "field": "scholarship_count",
        "type": "quantitative",
        "title": "Scholarship Count"
      }
    ]
  },
  "datasets": {
    "query_result": [
      {
        "payment_status": "Paid",
        "scholarship_count": 10
      }
    ]
  }
}
