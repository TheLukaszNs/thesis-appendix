{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average numeric grade vs course credits",
  "mark": {
    "type": "point",
    "filled": true,
    "opacity": 0.85
  },
  "encoding": {
    "x": {
      "field": "credits",
      "type": "quantitative",
      "title": "Course credits"
    },
    "y": {
      "field": "avg_grade",
      "type": "quantitative",
      "title": "Average grade",
      "scale": {
        "domain": [
          0,
          100
        ]
      }
    },
    "color": {
      "field": "n_enrollments",
      "type": "quantitative",
      "title": "Number of enrollments",
      "scale": {
        "scheme": "blues"
      }
    },
    "size": {
      "field": "n_enrollments",
      "type": "quantitative",
      "title": "Enrollments",
      "scale": {
        "range": [
          60,
          350
        ]
      }
    },
    "tooltip": [
      {
        "field": "credits",
        "type": "quantitative",
        "title": "Credits"
      },
      {
        "field": "avg_grade",
        "type": "quantitative",
        "title": "Average grade",
        "format": ".1f"
      },
      {
        "field": "n_enrollments",
        "type": "quantitative",
        "title": "Enrollments"
      }
    ]
  }
}
