{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Top scholarship-recipient department by academic year (total amount)",
  "width": 700,
  "height": 400,
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3
  },
  "encoding": {
    "x": {
      "field": "academic_year",
      "type": "ordinal",
      "axis": {
        "title": "Academic year"
      },
      "sort": {
        "field": "academic_year",
        "order": "ascending"
      }
    },
    "y": {
      "field": "total_scholarship_amount",
      "type": "quantitative",
      "axis": {
        "title": "Total scholarship amount"
      }
    },
    "color": {
      "field": "department_name",
      "type": "nominal",
      "legend": {
        "title": "Department"
      }
    },
    "tooltip": [
      {
        "field": "academic_year",
        "type": "nominal",
        "title": "Academic year"
      },
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "total_scholarship_amount",
        "type": "quantitative",
        "title": "Total scholarship amount"
      }
    ]
  }
}
