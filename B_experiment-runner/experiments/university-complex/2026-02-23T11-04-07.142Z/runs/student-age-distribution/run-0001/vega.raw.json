{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Student age distribution",
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "age_group",
      "type": "nominal",
      "axis": {
        "title": "Age group"
      },
      "sort": [
        "<18",
        "18-20",
        "21-24",
        "25-29",
        "30-39",
        "40+"
      ]
    },
    "y": {
      "field": "student_count",
      "type": "quantitative",
      "aggregate": "sum",
      "axis": {
        "title": "Number of students"
      }
    },
    "tooltip": [
      {
        "field": "age_group",
        "type": "nominal"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "aggregate": "sum",
        "title": "student_count"
      }
    ]
  }
}
