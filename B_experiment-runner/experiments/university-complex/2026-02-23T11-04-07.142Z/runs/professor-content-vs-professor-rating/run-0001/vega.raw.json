{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average content rating vs average professor rating (per professor)",
  "width": 650,
  "height": 420,
  "mark": {
    "type": "point",
    "filled": true
  },
  "encoding": {
    "x": {
      "field": "avg_content_rating",
      "type": "quantitative",
      "title": "Avg content rating"
    },
    "y": {
      "field": "avg_prof_rating",
      "type": "quantitative",
      "title": "Avg professor rating"
    },
    "color": {
      "field": "professor_name",
      "type": "nominal",
      "title": "Professor"
    },
    "size": {
      "field": "num_evaluations",
      "type": "quantitative",
      "title": "Number of evaluations"
    },
    "tooltip": [
      {
        "field": "professor_name",
        "type": "nominal",
        "title": "Professor"
      },
      {
        "field": "professor_id",
        "type": "nominal",
        "title": "Professor ID"
      },
      {
        "field": "avg_content_rating",
        "type": "quantitative",
        "title": "Avg content rating"
      },
      {
        "field": "avg_prof_rating",
        "type": "quantitative",
        "title": "Avg professor rating"
      },
      {
        "field": "num_evaluations",
        "type": "quantitative",
        "title": "Num evaluations"
      }
    ]
  }
}
