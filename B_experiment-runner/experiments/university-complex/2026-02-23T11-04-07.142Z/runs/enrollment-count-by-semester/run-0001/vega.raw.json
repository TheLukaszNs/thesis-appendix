{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Enrollments per Semester and Academic Year",
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "academic_year",
      "type": "nominal",
      "axis": {
        "title": "Academic Year"
      },
      "sort": "ascending"
    },
    "xOffset": {
      "field": "semester"
    },
    "y": {
      "field": "enrollment_count",
      "type": "quantitative",
      "axis": {
        "title": "Enrollment Count"
      }
    },
    "color": {
      "field": "semester",
      "type": "nominal",
      "legend": {
        "title": "Semester"
      }
    },
    "tooltip": [
      {
        "field": "academic_year",
        "type": "nominal",
        "title": "Academic Year"
      },
      {
        "field": "semester",
        "type": "nominal",
        "title": "Semester"
      },
      {
        "field": "enrollment_count",
        "type": "quantitative",
        "title": "Enrollments"
      }
    ]
  }
}
