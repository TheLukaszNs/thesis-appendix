{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Distribution of final grades across all courses",
  "data": {
    "name": "query_result"
  },
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "final_grade",
      "type": "nominal",
      "axis": {
        "title": "Final grade"
      },
      "sort": "ascending"
    },
    "y": {
      "field": "grade_count",
      "type": "quantitative",
      "axis": {
        "title": "Count of grades"
      }
    },
    "tooltip": [
      {
        "field": "final_grade",
        "type": "nominal",
        "title": "Final grade"
      },
      {
        "field": "grade_count",
        "type": "quantitative",
        "title": "Count"
      }
    ]
  },
  "width": 640,
  "height": 360
}
