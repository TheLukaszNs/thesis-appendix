{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Course type breakdown by department",
  "width": 800,
  "height": 400,
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "title": "Department",
        "labelAngle": -40
      }
    },
    "y": {
      "field": "course_count",
      "type": "quantitative",
      "axis": {
        "title": "Course count"
      }
    },
    "color": {
      "field": "course_type",
      "type": "nominal",
      "legend": {
        "title": "Course type"
      }
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "course_type",
        "type": "nominal",
        "title": "Course type"
      },
      {
        "field": "course_count",
        "type": "quantitative",
        "title": "Count"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": "transparent"
    }
  }
}
