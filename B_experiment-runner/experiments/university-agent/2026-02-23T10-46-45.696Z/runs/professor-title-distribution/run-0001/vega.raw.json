{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Distribution of Academic Titles among Professors",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "academic_title",
      "type": "nominal",
      "sort": "-x",
      "title": "Academic Title"
    },
    "x": {
      "field": "count",
      "type": "quantitative",
      "title": "Number of Professors"
    },
    "color": {
      "field": "academic_title",
      "type": "nominal",
      "legend": null
    },
    "tooltip": [
      {
        "field": "academic_title",
        "type": "nominal",
        "title": "Academic Title"
      },
      {
        "field": "count",
        "type": "quantitative",
        "title": "Count"
      },
      {
        "field": "percentage",
        "type": "quantitative",
        "title": "Share (%)",
        "format": ".1f"
      }
    ]
  }
}
