{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Bar chart showing number of courses offered by each department.",
  "title": "Number of courses per department",
  "data": {
    "name": "query_result"
  },
  "width": 800,
  "height": 400,
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "department_name",
      "type": "nominal",
      "axis": {
        "title": "Department"
      },
      "sort": {
        "op": "sum",
        "field": "course_count",
        "order": "descending"
      }
    },
    "y": {
      "field": "course_count",
      "type": "quantitative",
      "axis": {
        "title": "Number of courses"
      }
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "course_count",
        "type": "quantitative",
        "title": "Course count"
      }
    ]
  }
}
