{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Top 10 students by total scholarship amount",
  "data": {
    "name": "query_result"
  },
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "student_name",
      "type": "nominal",
      "axis": {
        "labelAngle": -40,
        "title": "Student"
      },
      "sort": {
        "field": "total_amount",
        "order": "descending"
      }
    },
    "y": {
      "field": "total_amount",
      "type": "quantitative",
      "axis": {
        "title": "Total Scholarship Amount"
      }
    },
    "tooltip": [
      {
        "field": "student_name",
        "type": "nominal",
        "title": "Student"
      },
      {
        "field": "total_amount",
        "type": "quantitative",
        "title": "Total Amount",
        "format": ".2f"
      },
      {
        "field": "student_id",
        "type": "ordinal",
        "title": "Student ID"
      }
    ]
  },
  "width": 700,
  "height": 400
}
