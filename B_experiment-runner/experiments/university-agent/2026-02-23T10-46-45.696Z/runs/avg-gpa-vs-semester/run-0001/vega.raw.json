{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Average GPA by current semester",
  "title": "Average GPA by Current Semester",
  "data": {
    "name": "query_result"
  },
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "current_semester",
      "type": "ordinal",
      "axis": {
        "title": "Current Semester"
      }
    },
    "y": {
      "field": "average_gpa",
      "type": "quantitative",
      "axis": {
        "title": "Average GPA"
      }
    },
    "tooltip": [
      {
        "field": "current_semester",
        "type": "ordinal",
        "title": "Semester"
      },
      {
        "field": "average_gpa",
        "type": "quantitative",
        "title": "Avg GPA"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Students"
      }
    ]
  }
}
