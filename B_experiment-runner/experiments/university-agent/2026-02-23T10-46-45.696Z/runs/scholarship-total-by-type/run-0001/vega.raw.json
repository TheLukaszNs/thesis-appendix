{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Total scholarship amount awarded grouped by scholarship type.",
  "title": "Total Scholarship Amount Awarded by Scholarship Type",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "scholarship_type",
      "type": "nominal",
      "title": "Scholarship Type",
      "axis": {
        "labelAngle": -40
      },
      "sort": "-y"
    },
    "y": {
      "field": "total_awarded",
      "type": "quantitative",
      "title": "Total Awarded"
    },
    "color": {
      "field": "scholarship_type",
      "type": "nominal",
      "legend": null
    },
    "tooltip": [
      {
        "field": "scholarship_type",
        "type": "nominal",
        "title": "Scholarship Type"
      },
      {
        "field": "total_awarded",
        "type": "quantitative",
        "title": "Total Awarded"
      }
    ]
  }
}
