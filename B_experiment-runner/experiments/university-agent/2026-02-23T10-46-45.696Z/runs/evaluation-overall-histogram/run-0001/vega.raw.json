{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Distribution of overall course evaluation ratings (1-5)",
  "title": "Overall Course Evaluation Ratings (1–5)",
  "data": {
    "name": "query_result"
  },
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "rating",
      "type": "ordinal",
      "title": "Rating"
    },
    "y": {
      "field": "count",
      "type": "quantitative",
      "title": "Count of Responses"
    },
    "tooltip": [
      {
        "field": "rating",
        "type": "ordinal",
        "title": "Rating"
      },
      {
        "field": "count",
        "type": "quantitative",
        "title": "Count"
      }
    ],
    "color": {
      "field": "rating",
      "type": "ordinal",
      "legend": null
    }
  },
  "width": 480,
  "height": 320
}
