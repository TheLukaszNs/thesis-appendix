{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Student-to-Professor ratio per department",
  "title": "Student-to-Professor Ratio per Department",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "department_name",
      "type": "nominal",
      "title": "Department",
      "sort": {
        "field": "student_professor_ratio",
        "order": "descending"
      }
    },
    "x": {
      "field": "student_professor_ratio",
      "type": "quantitative",
      "title": "Students per Professor"
    },
    "tooltip": [
      {
        "field": "department_name",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "student_count",
        "type": "quantitative",
        "title": "Student Count"
      },
      {
        "field": "professor_count",
        "type": "quantitative",
        "title": "Professor Count"
      },
      {
        "field": "student_professor_ratio",
        "type": "quantitative",
        "title": "Students per Professor",
        "format": ".2f"
      }
    ]
  }
}
