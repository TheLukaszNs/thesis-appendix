{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Histogram showing distribution of classroom capacities",
  "title": "Distribution of classroom capacities",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "capacity",
      "type": "quantitative",
      "bin": {
        "maxbins": 20
      },
      "axis": {
        "title": "Classroom capacity"
      }
    },
    "y": {
      "aggregate": "count",
      "type": "quantitative",
      "axis": {
        "title": "Number of classrooms"
      }
    },
    "tooltip": [
      {
        "field": "capacity",
        "type": "quantitative",
        "bin": "binned",
        "title": "Capacity range"
      },
      {
        "aggregate": "count",
        "type": "quantitative",
        "title": "Count"
      }
    ]
  }
}
