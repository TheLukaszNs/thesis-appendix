{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Average Scholarship Amount per Student by Department",
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "department",
      "type": "nominal",
      "axis": {
        "labelAngle": -40,
        "title": null
      }
    },
    "y": {
      "field": "avg_scholarship_per_student",
      "type": "quantitative",
      "title": "Avg scholarship per student"
    },
    "tooltip": [
      {
        "field": "department",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "avg_scholarship_per_student",
        "type": "quantitative",
        "title": "Avg scholarship",
        "format": ".2f"
      }
    ]
  }
}
