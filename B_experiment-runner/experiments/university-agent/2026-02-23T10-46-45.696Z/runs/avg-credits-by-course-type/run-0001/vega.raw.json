{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Average number of credits grouped by course type.",
  "title": "Average Credits by Course Type",
  "data": {
    "name": "query_result"
  },
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "y": {
      "field": "course_type",
      "type": "nominal",
      "title": "Course Type",
      "sort": "-x"
    },
    "x": {
      "field": "avg_credits",
      "type": "quantitative",
      "title": "Average Credits"
    },
    "tooltip": [
      {
        "field": "course_type",
        "type": "nominal",
        "title": "Course Type"
      },
      {
        "field": "avg_credits",
        "type": "quantitative",
        "title": "Average Credits",
        "format": ".2f"
      }
    ]
  },
  "width": 600,
  "height": 300
}
