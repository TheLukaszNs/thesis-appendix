{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "name": "query_result"
  },
  "title": "Distribution of course credit values by department",
  "width": 800,
  "height": 400,
  "mark": "rect",
  "encoding": {
    "x": {
      "field": "credits",
      "type": "ordinal",
      "title": "Credits"
    },
    "y": {
      "field": "department",
      "type": "nominal",
      "title": "Department",
      "sort": {
        "op": "count",
        "field": "course_count",
        "order": "descending"
      }
    },
    "color": {
      "field": "course_count",
      "type": "quantitative",
      "title": "Number of courses",
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "department",
        "type": "nominal",
        "title": "Department"
      },
      {
        "field": "credits",
        "type": "ordinal",
        "title": "Credits"
      },
      {
        "field": "course_count",
        "type": "quantitative",
        "title": "Course count"
      }
    ]
  }
}
