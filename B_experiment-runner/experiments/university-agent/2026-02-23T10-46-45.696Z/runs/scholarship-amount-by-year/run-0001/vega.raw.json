{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Bar chart showing total scholarship amounts per academic year.",
  "title": "Total Scholarship Amounts per Academic Year",
  "data": {
    "name": "query_result"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "academic_year",
      "type": "ordinal",
      "axis": {
        "title": "Academic Year"
      }
    },
    "y": {
      "field": "total_scholarship_amount",
      "type": "quantitative",
      "axis": {
        "title": "Total Scholarship Amount"
      }
    },
    "tooltip": [
      {
        "field": "academic_year",
        "type": "ordinal",
        "title": "Academic Year"
      },
      {
        "field": "total_scholarship_amount",
        "type": "quantitative",
        "title": "Total Scholarship Amount",
        "format": "$,.2f"
      }
    ]
  }
}
