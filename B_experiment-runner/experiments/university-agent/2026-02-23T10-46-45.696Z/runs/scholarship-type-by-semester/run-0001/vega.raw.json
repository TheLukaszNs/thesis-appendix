{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Scholarship counts by scholarship type for each semester type.",
  "title": "Scholarship Counts by Type and Semester",
  "data": {
    "name": "query_result"
  },
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "semester_type",
      "type": "nominal",
      "axis": {
        "title": "Semester Type"
      }
    },
    "y": {
      "field": "scholarship_count",
      "type": "quantitative",
      "axis": {
        "title": "Scholarship Count"
      }
    },
    "color": {
      "field": "scholarship_type",
      "type": "nominal",
      "legend": {
        "title": "Scholarship Type"
      }
    },
    "tooltip": [
      {
        "field": "semester_type",
        "type": "nominal",
        "title": "Semester Type"
      },
      {
        "field": "scholarship_type",
        "type": "nominal",
        "title": "Scholarship Type"
      },
      {
        "field": "scholarship_count",
        "type": "quantitative",
        "title": "Count"
      }
    ]
  }
}
