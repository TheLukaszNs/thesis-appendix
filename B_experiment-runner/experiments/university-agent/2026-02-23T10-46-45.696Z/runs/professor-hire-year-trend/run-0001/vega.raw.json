{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Number of professors hired each year",
  "data": {
    "name": "query_result"
  },
  "title": "Professors Hired per Year",
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "hire_year",
      "type": "ordinal",
      "title": "Year"
    },
    "y": {
      "field": "hires_count",
      "type": "quantitative",
      "title": "Number Hired"
    },
    "tooltip": [
      {
        "field": "hire_year",
        "type": "ordinal",
        "title": "Year"
      },
      {
        "field": "hires_count",
        "type": "quantitative",
        "title": "Hires"
      }
    ]
  }
}
