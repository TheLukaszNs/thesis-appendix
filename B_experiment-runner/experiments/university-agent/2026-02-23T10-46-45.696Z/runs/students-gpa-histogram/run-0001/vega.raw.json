{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Histogram of student GPAs using 0.25 GPA bins",
  "data": {
    "name": "query_result"
  },
  "title": "Histogram of Student GPAs",
  "width": 600,
  "height": 300,
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "bin_start",
      "type": "quantitative",
      "title": "GPA (bin start)",
      "axis": {
        "format": ".2f"
      },
      "scale": {
        "domain": [
          0,
          4
        ]
      },
      "bin": {
        "binned": true
      }
    },
    "x2": {
      "field": "bin_end"
    },
    "y": {
      "field": "count",
      "type": "quantitative",
      "title": "Number of students"
    },
    "tooltip": [
      {
        "field": "bin_start",
        "type": "quantitative",
        "title": "Bin start"
      },
      {
        "field": "bin_end",
        "type": "quantitative",
        "title": "Bin end"
      },
      {
        "field": "count",
        "type": "quantitative",
        "title": "Students"
      }
    ]
  }
}
