{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Distribution of individual scholarship amounts",
  "data": {
    "name": "query_result"
  },
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "bucket_start",
      "type": "quantitative",
      "title": "Scholarship amount (bucket start)",
      "axis": {
        "format": "$,.0f"
      }
    },
    "x2": {
      "field": "bucket_end"
    },
    "y": {
      "field": "count",
      "type": "quantitative",
      "title": "Number of scholarships"
    },
    "tooltip": [
      {
        "field": "bucket_start",
        "type": "quantitative",
        "title": "Bucket start",
        "format": "$,.2f"
      },
      {
        "field": "bucket_end",
        "type": "quantitative",
        "title": "Bucket end",
        "format": "$,.2f"
      },
      {
        "field": "count",
        "type": "quantitative",
        "title": "Count"
      }
    ]
  }
}
